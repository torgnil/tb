bool program_uses_string_compare(ProgramIR program):
    if (!collect_used_map_types(program).is_empty()):
        return true
    for (ParsedFunction function_ir in program.functions):
        for (BlockIR block in function_ir.blocks):
            for (LinearInstruction op in block.instructions):
                if (op.kind == 'value'):
                    if (op.detail == 'binary'):
                        if (op.args[0] == '==' || op.args[0] == '!='):
