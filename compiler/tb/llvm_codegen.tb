    bool needs_strlen = LLVM_SCAN_NEEDS_STRLEN != 0
    bool needs_string_array = LLVM_SCAN_NEEDS_STRING_ARRAY != 0
    bool needs_string_array_array = LLVM_SCAN_NEEDS_STRING_ARRAY_ARRAY != 0
    bool needs_int_set = LLVM_SCAN_NEEDS_INT_SET != 0
    string[] record_set_types = program_record_set_types(program)
