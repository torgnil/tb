string mangle_backend_type(string type_name):
    type_name = normalize_llvm_type_name(type_name)
    if (type_name == 'int'):
        return 'int'
    if (type_name == 'bool'):
        return 'bool'
    if (type_name == 'string'):
        return 'string'
    if (type_name == 'string[]'):
        return 'string_array'
    if (type_name == 'string[][]'):
        return 'string_array_array'
    if (type_name == 'int[]'):
        return 'int_array'
    if (type_name == 'int[][]'):
        return 'int_array_array'
    if (type_name.starts_with('set<') && record_name_from_type(set_item_type(type_name)) != ''):
        return 'record_set_' + record_name_from_type(set_item_type(type_name))
    if (type_name.ends_with('[]') && record_name_from_type(array_item_type(type_name)) != ''):
        return 'record_array_' + record_name_from_type(array_item_type(type_name))
    if (type_name.starts_with('map<')):
        return 'map_' + mangle_backend_type(map_key_type(type_name)) + '_' + mangle_backend_type(map_value_type(type_name))
    if (record_name_from_type(type_name) != ''):
        return 'record_' + record_name_from_type(type_name)
    throw 'unsupported backend type mangling: ' + type_name

string llvm_map_suffix(string type_name):
    string key_type = normalize_llvm_type_name(map_key_type(type_name))
    string value_type = normalize_llvm_type_name(map_value_type(type_name))
    if (key_type != 'string' && key_type != 'int'):
        throw 'unsupported llvm map key type: ' + key_type
    return 'tb_bootstrap_map_' + mangle_backend_type(key_type) + '_' + mangle_backend_type(value_type)

string llvm_map_type_name(string type_name):
    return '%' + llvm_map_suffix(type_name)

string llvm_map_new_name(string type_name):
    return '@' + llvm_map_suffix(type_name) + '_new'

string llvm_map_set_name(string type_name):
    return '@' + llvm_map_suffix(type_name) + '_set_owned'

string llvm_map_length_name(string type_name):
    return '@' + llvm_map_suffix(type_name) + '_length'

string llvm_map_get_name(string type_name):
    return '@' + llvm_map_suffix(type_name) + '_get'

string llvm_map_set_by_key_name(string type_name):
    return '@' + llvm_map_suffix(type_name) + '_set_by_key'

string llvm_map_release_by_key_name(string type_name):
    return '@' + llvm_map_suffix(type_name) + '_release_by_key'

string llvm_map_keys_name(string type_name):
    return '@' + llvm_map_suffix(type_name) + '_keys'

string llvm_map_values_name(string type_name):
    return '@' + llvm_map_suffix(type_name) + '_values'

string llvm_map_clone_name(string type_name):
    return '@' + llvm_map_suffix(type_name) + '_clone'

string llvm_map_free_name(string type_name):
    return '@' + llvm_map_suffix(type_name) + '_free'

string llvm_named_int_sort_comparator_symbol(string comparator_name):
    return '@__tb_sort_cmp_int_' + comparator_name

void register_named_int_sort_comparator(string comparator_name):
    if (!(comparator_name in LLVM_NAMED_INT_SORT_COMPARATOR_NAMES)):
        LLVM_NAMED_INT_SORT_COMPARATOR_NAMES.push(comparator_name)

string llvm_record_array_type_name(string record_name):
    return '%tb_bootstrap_record_array_' + record_name

string llvm_named_record_sort_comparator_symbol(string record_name, string comparator_name):
    return '@__tb_sort_cmp_record_' + record_name + '_' + comparator_name

void register_named_record_sort_comparator(string record_name, string comparator_name):
    string key = record_name + '|' + comparator_name
    if (!(key in LLVM_NAMED_RECORD_SORT_COMPARATOR_KEYS)):
        LLVM_NAMED_RECORD_SORT_COMPARATOR_KEYS.push(key)

string llvm_zero_value(string type_name):
    type_name = normalize_llvm_type_name(type_name)
    if (type_name == 'int'):
        return '0'
    if (type_name == 'bool'):
        return 'false'
    if (type_name == 'num'):
        return 'zeroinitializer'
    if (type_name == 'string' || type_name == 'string[]' || type_name == 'string[][]' || type_name == 'int[]' || type_name == 'int[][]' || type_name.starts_with('set<') || (type_name.ends_with('[]') && record_name_from_type(array_item_type(type_name)) != '') || type_name.starts_with('map<') || record_name_from_type(type_name) != ''):
        return 'null'
    throw 'unsupported llvm zero value type: ' + type_name

string emit_map_owned_value(ParsedFunction function_ir, string temp_name, string temp_suffix):
    if (temp_needs_backend_free(function_ir, temp_name)):
        return temp_ref(temp_name)
    return '%map.clone.' + temp_suffix

string[] emit_map_materialize_if_needed(ParsedFunction function_ir, string temp_name, string temp_suffix):
    if (temp_needs_backend_free(function_ir, temp_name)):
        return []
    if (!temp_is_map(function_ir, temp_name)):
        return []
    string map_type = normalize_llvm_type_name(lookup_temp_llvm_type(function_ir, temp_name))
    return ['  ' + emit_map_owned_value(function_ir, temp_name, temp_suffix) + ' = call ptr ' + llvm_map_clone_name(map_type) + '(ptr ' + temp_ref(temp_name) + ')']

string emit_record_owned_value(ParsedFunction function_ir, string temp_name, string temp_suffix):
    if (temp_needs_backend_free(function_ir, temp_name)):
