    if (needs_int_set):
        print('declare i32 @putchar(i32)')
        emitted_any_header = true
    if (needs_print_string || needs_print_bool || needs_throw):
        print('declare i32 @puts(ptr)')
        emitted_any_header = true
    if (needs_throw || needs_read_lines || needs_read_file):
        print('declare void @exit(i32)')
        emitted_any_header = true
    if (needs_strcmp || needs_string_search || needs_string_array_helpers):
        print('declare i32 @strcmp(ptr, ptr)')
        emitted_any_header = true
    if (needs_strlen || needs_runtime_string_copy || needs_read_lines || needs_read_file || needs_string_helpers):
        print('declare i64 @strlen(ptr)')
        emitted_any_header = true
    if (needs_getenv):
        print('declare ptr @getenv(ptr)')
        emitted_any_header = true
    if (needs_string_helpers):
        print('declare ptr @strstr(ptr, ptr)')
        print('declare i64 @strtoll(ptr, ptr, i32)')
        print('declare i32 @snprintf(ptr, i64, ptr, ...)')
        emitted_any_header = true
    if (needs_popcount):
        print('declare i64 @llvm.ctpop.i64(i64)')
        emitted_any_header = true
    if (needs_num):
        print('declare double @llvm.sqrt.f64(double)')
        print('declare double @llvm.round.f64(double)')
        emitted_any_header = true
    if (needs_runtime_string_copy || needs_string_array_array || needs_bool_array || needs_int_array_array || needs_int_array || needs_string_helpers):
        print('declare void @llvm.memcpy.p0.p0.i64(ptr, ptr, i64, i1)')
        emitted_any_header = true
    if (needs_string_array_helpers || needs_string_array_array || needs_bool_array || needs_int_array || needs_int_array_array || needs_record_array || needs_maps || needs_read_lines):
        print('declare void @llvm.memset.p0.i64(ptr, i8, i64, i1)')
        emitted_any_header = true
    if (needs_read_lines || needs_read_file || needs_file_output):
        print('declare ptr @fopen(ptr, ptr)')
        emitted_any_header = true
    if (needs_time_ms):
        print('declare i32 @gettimeofday(ptr, ptr)')
        emitted_any_header = true
    if (needs_file_output):
        print('declare i32 @fputs(ptr, ptr)')
        print('declare i32 @fputc(i32, ptr)')
        emitted_any_header = true
    if (needs_read_lines || needs_read_file || needs_file_output):
        print('declare i32 @fclose(ptr)')
        emitted_any_header = true
    if (needs_read_lines):
        print('declare void @rewind(ptr)')
        emitted_any_header = true
    if (needs_read_lines || needs_read_file):
        print('declare i64 @getline(ptr, ptr, ptr)')
        emitted_any_header = true
    for (string declaration in foreign_module_llvm_declarations(foreign_modules)):
        print(declaration)
        emitted_any_header = true
    if (needs_num):
        string[] num_helper_lines = emit_num_helpers()
        for (string line in num_helper_lines):
            print(line)
    if (needs_string_helpers):
        string[] string_helper_lines = emit_string_helpers(needs_num_hash)
        for (string line in string_helper_lines):
            print(line)
    if (needs_string_array_helpers):
        string[] string_array_helper_lines = emit_string_array_helpers()
        for (string line in string_array_helper_lines):
            print(line)
    if (needs_string_array_array):
        string[] string_array_array_helper_lines = emit_string_array_array_helpers()
        for (string line in string_array_array_helper_lines):
            print(line)
    if (needs_bool_array):
        string[] bool_array_helper_lines = emit_bool_array_helpers()
        for (string line in bool_array_helper_lines):
            print(line)
    if (needs_int_array):
        string[] int_array_helper_lines = emit_int_array_helpers()
        for (string line in int_array_helper_lines):
            print(line)
    if (needs_int_set):
        string[] int_set_helper_lines = emit_int_set_helpers()
        for (string line in int_set_helper_lines):
            print(line)
    for (string record_name in record_set_types):
        string[] record_set_helper_lines = emit_record_set_helpers(program, record_name)
        for (string line in record_set_helper_lines):
            print(line)
    if (needs_int_array_array):
        string[] int_array_array_helper_lines = emit_int_array_array_helpers()
        for (string line in int_array_array_helper_lines):
            print(line)
    if (needs_record_array):
        for (RecordDeclIR record_decl in record_decls):
            string[] record_array_helper_lines = emit_record_array_helpers(strip_prefix(record_decl.header, 'record '))
            for (string line in record_array_helper_lines):
                print(line)
    else if (!record_set_types.is_empty()):
        for (string record_name in record_set_types):
            string[] record_array_helper_lines = emit_record_array_helpers(record_name)
            for (string line in record_array_helper_lines):
                print(line)
    if (needs_map_to_string_length):
        string[] string_length_map_helper_lines = emit_string_length_map_helper()
        for (string line in string_length_map_helper_lines):
            print(line)
    if (needs_map_to_parse_point):
        string[] map_to_parse_point_helper_lines = emit_map_to_parse_point_helper()
        for (string line in map_to_parse_point_helper_lines):
            print(line)
    if (needs_map_to_edge_distance):
        string[] map_to_edge_distance_helper_lines = emit_map_to_edge_distance_helper()
        for (string line in map_to_edge_distance_helper_lines):
            print(line)
    if (needs_flat_map_edges_for_point):
        string[] flat_map_edges_for_point_helper_lines = emit_flat_map_edges_for_point_helper()
        for (string line in flat_map_edges_for_point_helper_lines):
            print(line)
    if (needs_read_lines):
        string[] read_lines_helper_lines = emit_read_lines_helper()
        for (string line in read_lines_helper_lines):
            print(line)
    if (needs_read_file):
        string[] read_file_helper_lines = emit_read_file_helper()
        for (string line in read_file_helper_lines):
            print(line)
    if (needs_getenv):
        string[] getenv_helper_lines = emit_getenv_helper()
        for (string line in getenv_helper_lines):
            print(line)
    if (needs_time_ms):
        string[] time_ms_helper_lines = emit_time_ms_helper()
        for (string line in time_ms_helper_lines):
            print(line)
    if (needs_file_output):
        string[] file_output_helper_lines = emit_file_output_helpers()
        for (string line in file_output_helper_lines):
            print(line)
    if (needs_main_args):
        string[] main_args_helper_lines = emit_main_args_helpers()
        for (string line in main_args_helper_lines):
            print(line)
    for (string map_type in map_types):
        string[] map_helper_lines = emit_map_helpers(map_type)
        for (string line in map_helper_lines):
            print(line)
    for (RecordDeclIR record_decl in record_decls):
        string[] record_helper_lines = emit_record_helpers(record_decl)
        for (string line in record_helper_lines):
            print(line)
    if ((!string_constants.is_empty() || needs_maps || !record_decls.is_empty() || needs_strcmp || needs_strlen || needs_runtime_string_copy || needs_string_array || needs_string_array_array || needs_record_array) && (!program.globals.is_empty() || !program.functions.is_empty())):
        print('')
    for (GlobalDeclIR global_decl in program.globals):
        string[] global_lines = emit_global_lines(program, global_decl)
        for (string line in global_lines):
            print(line)
    for (ParsedFunction function_ir in program.functions):
        if (is_cached_function_header(function_ir.header) && supports_cached_function_backend(program, function_ir)):
            string[] cached_function_global_lines = emit_cached_function_globals(program, function_ir)
            for (string line in cached_function_global_lines):
                print(line)
    if (needs_runtime_global_init):
        string[] global_init_helper_lines = emit_global_init_helper(program)
        for (string line in global_init_helper_lines):
            print(line)
    if (!program.globals.is_empty() && !program.functions.is_empty()):
        print('')
    for (ParsedFunction function_ir in program.functions):
        string[] function_lines = emit_function(program, function_ir, needs_runtime_global_init)
        for (string line in function_lines):
            print(line)
        print('')
    for (string comparator_name in LLVM_NAMED_INT_SORT_COMPARATOR_NAMES):
        print_llvm_lines(emit_named_int_sort_helper(comparator_name))
        print('')
    for (string key in LLVM_NAMED_RECORD_SORT_COMPARATOR_KEYS):
        int split = key.index_of('|')
        string record_name = key.substring(0, split)
        string comparator_name = key.substring(split + 1)
        print_llvm_lines(emit_named_record_sort_helper(record_name, comparator_name))
        print('')

string[] llvm_codegen_source(string source):
    ProgramIR program = owned_source_ir(source)
    string[] lines = llvm_codegen_ir(program)
    string[] detached = []
    for (string line in lines):
        detached.push(line.substring(0))
    return detached
