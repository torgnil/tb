        emitted_any_header = true
    if (needs_string_helpers):
        print('@.fmt.int.text = private unnamed_addr constant [5 x i8] c"%lld\\00"')
        emitted_any_header = true
    if (!string_constants.is_empty()):
        for (StringConstIR constant in string_constants):
            print(emit_string_constant(constant))
