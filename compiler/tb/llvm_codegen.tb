    LLVM_PROFILE_VALUE_FAMILY = family

void reset_llvm_user_call_stats():
    LLVM_USER_CALL_STATS_ACTIVE = 1
    LLVM_USER_CALL_TOTAL = 0
    LLVM_USER_CALL_RECORD_CTORS = 0
    LLVM_USER_CALL_VOID = 0
    LLVM_USER_CALL_NONVOID = 0
    LLVM_USER_CALL_ARGS_TOTAL = 0
    LLVM_USER_CALL_PARAM_BINDINGS_TOTAL = 0
    LLVM_USER_CALL_EMITTED_BYTES = 0
    LLVM_USER_CALL_GENERIC_TOTAL = 0
    LLVM_USER_CALL_BUILTIN_TOTAL = 0
    LLVM_USER_CALL_BUILTIN_EMITTED_BYTES = 0
    LLVM_USER_CALL_RECORD_CTOR_EMITTED_BYTES = 0
    LLVM_RECORD_CTOR_TOTAL = 0
    LLVM_RECORD_CTOR_FIELDS_TOTAL = 0
    LLVM_RECORD_CTOR_MANAGED_FIELDS_TOTAL = 0
    LLVM_RECORD_CTOR_STRING_FIELDS = 0
    LLVM_RECORD_CTOR_STRING_ARRAY_FIELDS = 0
    LLVM_RECORD_CTOR_MAP_FIELDS = 0
    LLVM_RECORD_CTOR_RECORD_FIELDS = 0
    LLVM_RECORD_CTOR_RECORD_ARRAY_FIELDS = 0
    LLVM_RECORD_CTOR_PREFIX_LINES_TOTAL = 0
    LLVM_RECORD_CTOR_STRING_PREFIX_LINES = 0
    LLVM_RECORD_CTOR_STRING_MATERIALIZE_NONEMPTY = 0
    LLVM_RECORD_CTOR_STRING_OWNED_VALUE_CALLS = 0
    LLVM_RECORD_CTOR_STRING_BACKEND_FREE = 0
    LLVM_RECORD_CTOR_STRING_FROM_IDENTIFIER = 0
    LLVM_RECORD_CTOR_STRING_FROM_CALL = 0
    LLVM_RECORD_CTOR_STRING_FROM_METHOD_CALL = 0
    LLVM_RECORD_CTOR_STRING_FROM_STRING_LITERAL = 0
    LLVM_RECORD_CTOR_STRING_FROM_FIELD = 0
    LLVM_RECORD_CTOR_STRING_FROM_OTHER = 0
    LLVM_USER_CALL_ARG_LOOP_ITERS = 0
    LLVM_USER_CALL_ARG_PARAM_TYPE_HITS = 0
    LLVM_USER_CALL_ARG_FALLBACK_LOOKUPS = 0
    LLVM_USER_CALL_ARG_LLVM_TYPE_CALLS = 0
    LLVM_USER_CALL_RESULT_LLVM_TYPE_CALLS = 0
    LLVM_USER_CALL_TEMP_REF_CALLS = 0
    LLVM_USER_CALL_ARG_TEMP_REF_CALLS = 0
    LLVM_USER_CALL_NONVOID_LHS_TEMP_REF_CALLS = 0
    LLVM_USER_CALL_ARGS_TEXT_BYTES = 0
    LLVM_USER_CALL_SEPARATOR_APPENDS = 0
    LLVM_USER_CALL_SEPARATOR_BYTES = 0
    LLVM_USER_CALL_ARG_FRAGMENT_BYTES = 0
    LLVM_USER_CALL_VOID_LINE_BYTES = 0
    LLVM_USER_CALL_NONVOID_LINE_BYTES = 0

void record_llvm_user_call_stats(int arg_count, int param_binding_count, bool is_void, bool is_record_ctor, int emitted_bytes):
    if (LLVM_USER_CALL_STATS_ACTIVE == 0):
        return
    LLVM_USER_CALL_TOTAL += 1
    LLVM_USER_CALL_ARGS_TOTAL += arg_count
    LLVM_USER_CALL_PARAM_BINDINGS_TOTAL += param_binding_count
    LLVM_USER_CALL_EMITTED_BYTES += emitted_bytes
    if (is_void):
        LLVM_USER_CALL_VOID += 1
    else:
        LLVM_USER_CALL_NONVOID += 1
    if (is_record_ctor):
        LLVM_USER_CALL_RECORD_CTORS += 1

