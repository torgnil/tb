    if (!temp_is_string_array(function_ir, temp_name)):
        return []
    return ['  ' + emit_string_array_owned_value(function_ir, temp_name, temp_suffix) + ' = call ptr @tb_bootstrap_string_array_clone(ptr ' + temp_ref(temp_name) + ')']

string emit_string_array_array_owned_value(ParsedFunction function_ir, string temp_name, string temp_suffix):
    if (temp_needs_backend_free(function_ir, temp_name)):
