    if (temp_needs_backend_free(function_ir, temp_name)):
        return []
    if (!temp_is_record_array(function_ir, temp_name)):
        return []
    string record_name = record_name_from_type(array_item_type(lookup_temp_llvm_type(function_ir, temp_name)))
    return ['  ' + emit_record_array_owned_value(function_ir, temp_name, temp_suffix) + ' = call ptr @tb_bootstrap_record_array_clone_' + record_name + '(ptr ' + temp_ref(temp_name) + ')']

string emit_backend_release_binding(BindingIR binding, string temp_suffix):
    string type_name = normalize_llvm_type_name(binding.type_name)
    if (!is_backend_managed_type(type_name)):
        return '  ; release_local ' + binding.type_name + ' ' + binding.name
    string owned_name = '%owned.' + binding.name + '.' + temp_suffix
    string release_name = '%release.' + binding.name + '.' + temp_suffix
    string value_name = '%release.value.' + binding.name + '.' + temp_suffix
    string line = '  ' + owned_name + ' = load i1, ptr ' + owned_slot_ref(binding.name)
    line += '\n  ' + release_name + ' = load ptr, ptr ' + slot_ref(binding.name)
    line += '\n  ' + value_name + ' = select i1 ' + owned_name + ', ptr ' + release_name + ', ptr null'
    line += '\n' + emit_backend_release_ptr(type_name, value_name)
    line += '\n  store i1 false, ptr ' + owned_slot_ref(binding.name)
    line += '\n  store ptr null, ptr ' + slot_ref(binding.name)
    return line

string llvm_bool_literal(string value):
    if (value == 'true'):
        return 'true'
    return 'false'

StringConstIR encode_tb_string_literal(string symbol, string literal):
    LLVM_ENCODE_STRING_LITERAL_CALLS += 1
    LLVM_ENCODE_STRING_LITERAL_INPUT_BYTES += literal.length()
    string inner = literal.substring(1, literal.length() - 1)
    string encoded = ''
    int index = 0
    int count = 0
    while (index < inner.length()):
        string ch = inner[index]
        if (ch == '\n'):
            LLVM_ENCODE_STRING_LITERAL_ESCAPE_COUNT += 1
            encoded += '\\0A'
        else if (ch == '\r'):
            LLVM_ENCODE_STRING_LITERAL_ESCAPE_COUNT += 1
            encoded += '\\0D'
        else if (ch == '\t'):
            LLVM_ENCODE_STRING_LITERAL_ESCAPE_COUNT += 1
            encoded += '\\09'
        else if (ch == '\\'):
            LLVM_ENCODE_STRING_LITERAL_ESCAPE_COUNT += 1
            encoded += '\\5C'
        else if (ch == '"'):
            LLVM_ENCODE_STRING_LITERAL_ESCAPE_COUNT += 1
            encoded += '\\22'
        else:
            encoded += ch
        index += 1
        count += 1
    string output = encoded + '\\00'
    LLVM_ENCODE_STRING_LITERAL_OUTPUT_BYTES += output.length()
    return StringConstIR(symbol, output, count + 1)

int tb_string_literal_data_length(string literal):
    LLVM_STRING_LITERAL_LENGTH_CALLS += 1
    LLVM_STRING_LITERAL_INPUT_BYTES += literal.length()
    string inner = literal.substring(1, literal.length() - 1)
    return inner.length() + 1

string single_char_string_literal_i8(string literal):
    string inner = literal.substring(1, literal.length() - 1)
    if (inner.length() != 1):
        throw 'split separator must be a single character literal'
    string ch = inner[0]
    if (ch == ','):
        return '44'
    if (ch == '-'):
        return '45'
    if (ch == ' '):
        return '32'
    if (ch == ':'):
        return '58'
    if (ch == ';'):
        return '59'
    if (ch == '\t'):
        return '9'
    if (ch == '\n'):
        return '10'
    if (ch == '\r'):
        return '13'
    throw 'unsupported split separator literal: ' + literal

string function_string_symbol(string function_name, string temp_name):
    LLVM_FUNCTION_STRING_SYMBOL_CALLS += 1
    LLVM_FUNCTION_STRING_SYMBOL_BYTES += function_name.length() + temp_name.length()
    return '.str.' + function_name + '.' + temp_name

string function_string_symbol_prefix(string function_name):
    return '.str.' + function_name + '.'

string function_string_literal_key(string function_name, string literal):
    return function_name + '::' + literal

string lookup_function_string_literal_symbol(string function_name, string literal):
    string key = function_string_literal_key(function_name, literal)
    int index = 0
    while (index < LLVM_FUNCTION_STRING_LITERAL_KEYS.length()):
        if (LLVM_FUNCTION_STRING_LITERAL_KEYS[index] == key):
            return LLVM_FUNCTION_STRING_LITERAL_SYMBOLS[index]
        index += 1
    return ''

void remember_function_string_literal_symbol(string function_name, string literal, string symbol):
    if (lookup_function_string_literal_symbol(function_name, literal) == ''):
        LLVM_FUNCTION_STRING_LITERAL_KEYS.push(function_string_literal_key(function_name, literal))
        LLVM_FUNCTION_STRING_LITERAL_SYMBOLS.push(symbol)

string global_string_symbol(string global_name, string temp_name):
    return '.str.global.' + global_name + '.' + temp_name

string enum_string_symbol(string enum_name, string value_name):
    return '.str.enum.' + enum_name + '.' + value_name

StringConstIR[] collect_function_string_constants(ParsedFunction function_ir):
    StringConstIR[] constants = []
    string function_name = function_name_from_header_local(function_ir.header)
    string symbol_prefix = function_string_symbol_prefix(function_name)
    string[] cached_literals = []
    for (BlockIR block in function_ir.blocks):
        for (LinearInstruction op in block.instructions):
            if (op.kind == 'value' && op.detail == 'string'):
                LLVM_FUNCTION_STRING_SYMBOL_COLLECT_FUNCTION_CALLS += 1
                int cache_index = 0
                bool cache_hit = false
                while (cache_index < cached_literals.length()):
                    if (cached_literals[cache_index] == op.args[0]):
                        cache_hit = true
                        cache_index = cached_literals.length()
                    else:
                        cache_index += 1
                if (cache_hit):
                    LLVM_STRING_CONST_CACHE_HIT_COUNT += 1
                else:
                    string symbol = symbol_prefix + op.lhs
                    remember_function_string_literal_symbol(function_name, op.args[0], symbol)
                    StringConstIR encoded = encode_tb_string_literal(symbol, op.args[0])
                    constants.push(encoded)
                    LLVM_STRING_CONST_TOTAL_COUNT += 1
                    LLVM_STRING_CONST_FUNCTION_COUNT += 1
                    LLVM_STRING_CONST_CACHE_MISS_COUNT += 1
                    cached_literals.push(op.args[0])
    return constants

StringConstIR[] collect_runtime_global_string_constants(GlobalDeclIR global_decl):
    StringConstIR[] constants = []
    BindingIR binding = ir_parse_binding_decl(strip_prefix(global_decl.header, 'global '))
    string[] temp_names = collect_global_temp_names(global_decl.instructions)
    string[] cached_literals = []
    string[] cached_encoded_values = []
    int[] cached_lengths = []
    int index = 0
    while (index < global_decl.instructions.length()):
        LinearInstruction renamed = rename_global_instruction_temps(global_decl.instructions[index], temp_names, binding.name)
        if (renamed.kind == 'value' && renamed.detail == 'string'):
            LLVM_FUNCTION_STRING_SYMBOL_COLLECT_GLOBAL_CALLS += 1
            int cache_index = 0
            bool cache_hit = false
            while (cache_index < cached_literals.length()):
                if (cached_literals[cache_index] == renamed.args[0]):
                    StringConstIR reused = StringConstIR(function_string_symbol('__tb_init_globals', renamed.lhs), cached_encoded_values[cache_index], cached_lengths[cache_index])
                    constants.push(reused)
                    LLVM_STRING_CONST_TOTAL_COUNT += 1
                    LLVM_STRING_CONST_RUNTIME_GLOBAL_COUNT += 1
                    LLVM_STRING_CONST_CACHE_HIT_COUNT += 1
                    cache_hit = true
                    cache_index = cached_literals.length()
                else:
                    cache_index += 1
            if (!cache_hit):
                string symbol = function_string_symbol('__tb_init_globals', renamed.lhs)
                remember_function_string_literal_symbol('__tb_init_globals', renamed.args[0], symbol)
                StringConstIR encoded = encode_tb_string_literal(symbol, renamed.args[0])
                constants.push(encoded)
                LLVM_STRING_CONST_TOTAL_COUNT += 1
                LLVM_STRING_CONST_RUNTIME_GLOBAL_COUNT += 1
                LLVM_STRING_CONST_CACHE_MISS_COUNT += 1
                cached_literals.push(renamed.args[0])
                cached_encoded_values.push(encoded.encoded_value)
                cached_lengths.push(encoded.length)
        index += 1
    return constants

StringConstIR[] collect_string_constants(ProgramIR program):
    LLVM_FUNCTION_STRING_LITERAL_KEYS = []
    LLVM_FUNCTION_STRING_LITERAL_SYMBOLS = []
    prepare_call_llvm_metadata(program)
    StringConstIR[] constants = []
    for (EnumDeclIR enum_decl in program.enums):
        string enum_name = strip_prefix(enum_decl.header, 'enum ')
        for (string value in enum_decl.values):
            string value_name = strip_prefix(value, 'value ')
            constants.push(encode_tb_string_literal(enum_string_symbol(enum_name, value_name), '\'' + value_name + '\''))
            LLVM_STRING_CONST_TOTAL_COUNT += 1
            LLVM_STRING_CONST_ENUM_COUNT += 1
    for (GlobalDeclIR global_decl in program.globals):
        BindingIR binding = ir_parse_binding_decl(strip_prefix(global_decl.header, 'global '))
        for (LinearInstruction op in global_decl.instructions):
            if (op.kind == 'value' && op.detail == 'string'):
                constants.push(encode_tb_string_literal(global_string_symbol(binding.name, op.lhs), op.args[0]))
                LLVM_STRING_CONST_TOTAL_COUNT += 1
                LLVM_STRING_CONST_GLOBAL_COUNT += 1
        for (StringConstIR constant in collect_runtime_global_string_constants(global_decl)):
            constants.push(constant)
    for (ParsedFunction function_ir in program.functions):
        for (StringConstIR constant in collect_function_string_constants(function_ir)):
            constants.push(constant)
    return constants

string[] collect_used_map_types(ProgramIR program):
    string[] result = []
    for (GlobalDeclIR global_decl in program.globals):
        BindingIR binding = ir_parse_binding_decl(strip_prefix(global_decl.header, 'global '))
        string type_name = normalize_llvm_type_name(binding.type_name)
        if (type_name.starts_with('map<') && !(type_name in result)):
            result.push(type_name)
    for (ParsedFunction function_ir in program.functions):
        string return_type = normalize_llvm_type_name(function_ir.return_type)
        if (return_type.starts_with('map<') && !(return_type in result)):
            result.push(return_type)
        for (BindingIR param_decl in function_ir.params):
            string type_name = normalize_llvm_type_name(param_decl.type_name)
            if (type_name.starts_with('map<') && !(type_name in result)):
                result.push(type_name)
        for (BindingIR local_decl in function_ir.locals):
            string type_name = normalize_llvm_type_name(local_decl.type_name)
            if (type_name.starts_with('map<') && !(type_name in result)):
                result.push(type_name)
        for (BlockIR block in function_ir.blocks):
            for (LinearInstruction op in block.instructions):
                string result_type = normalize_llvm_type_name(op.result_type)
                if (result_type.starts_with('map<') && !(result_type in result)):
                    result.push(result_type)
    return result

void analyze_program_features(ProgramIR program, string[] map_types):
    LLVM_SCAN_NEEDS_STRCMP = 0
    LLVM_SCAN_NEEDS_STRING_SEARCH = 0
    LLVM_SCAN_NEEDS_STRLEN = 0
    LLVM_SCAN_NEEDS_STRING_ARRAY = 0
    LLVM_SCAN_NEEDS_STRING_ARRAY_ARRAY = 0
    LLVM_SCAN_NEEDS_INT_SET = 0
    LLVM_SCAN_NEEDS_BOOL_ARRAY = 0
    LLVM_SCAN_NEEDS_PRIO_Q_INT = 0
    LLVM_SCAN_NEEDS_INT_ARRAY = 0
    LLVM_SCAN_NEEDS_INT_ARRAY_ARRAY = 0
    LLVM_SCAN_NEEDS_RECORD_ARRAY = 0
    LLVM_SCAN_NEEDS_MAP_TO_PARSE_POINT = 0
    LLVM_SCAN_NEEDS_MAP_TO_STRING_LENGTH = 0
    LLVM_SCAN_NEEDS_MAP_TO_EDGE_DISTANCE = 0
    LLVM_SCAN_NEEDS_FLAT_MAP_EDGES_FOR_POINT = 0
    LLVM_SCAN_NEEDS_RUNTIME_STRING_COPY = 0
    LLVM_SCAN_NEEDS_BACKEND_FREE = 0
    LLVM_SCAN_NEEDS_MAIN_ARGS = 0
    LLVM_SCAN_NEEDS_NUM = 0
    LLVM_SCAN_NEEDS_PRINT_INT = 0
    LLVM_SCAN_NEEDS_PRINT_STRING_ARRAY = 0
    LLVM_SCAN_NEEDS_PRINT_INT_ARRAY = 0
    LLVM_SCAN_NEEDS_PRINT_BOOL = 0
    LLVM_SCAN_NEEDS_PRINT_NUM = 0
    LLVM_SCAN_NEEDS_PRINT_STRING = 0
    LLVM_SCAN_NEEDS_THROW = 0
    LLVM_SCAN_NEEDS_TRY_CATCH = 0
    LLVM_SCAN_NEEDS_READ_LINES = 0
    LLVM_SCAN_NEEDS_READ_FILE = 0
    LLVM_SCAN_NEEDS_GETENV = 0
    LLVM_SCAN_NEEDS_TIME_MS = 0
    LLVM_SCAN_NEEDS_FILE_OUTPUT = 0
    LLVM_SCAN_NEEDS_TO_INT = 0
    LLVM_SCAN_NEEDS_INT_TO_STRING = 0
    LLVM_SCAN_NEEDS_POPCOUNT = 0
    LLVM_SCAN_NEEDS_HASH = 0
    LLVM_SCAN_NEEDS_NUM_HASH = 0
    LLVM_SCAN_NEEDS_STRING_HELPERS_OPS = 0
    LLVM_SCAN_NEEDS_RUNTIME_GLOBAL_INIT = 0
    string[] record_set_types = []
    bool needs_strcmp = !map_types.is_empty()
    bool needs_string_search = false
    bool needs_strlen = false
    bool needs_string_array = false
    bool needs_string_array_array = false
    bool needs_int_set = false
    bool needs_bool_array = false
    bool needs_prio_q_int = false
    bool needs_int_array = false
    bool needs_int_array_array = false
    bool needs_record_array = false
    bool needs_map_to_parse_point = false
    bool needs_map_to_string_length = false
    bool needs_map_to_edge_distance = false
    bool needs_flat_map_edges_for_point = false
    bool needs_runtime_string_copy = !map_types.is_empty()
    bool needs_backend_free = false
    bool needs_main_args = false
    bool needs_num = false
    bool needs_print_int = false
    bool needs_print_string_array = false
    bool needs_print_int_array = false
    bool needs_print_bool = false
    bool needs_print_num = false
    bool needs_print_string = false
    bool needs_throw = false
    bool needs_try_catch = false
    bool needs_read_lines = false
    bool needs_read_file = false
    bool needs_getenv = false
    bool needs_time_ms = false
    bool needs_file_output = false
    bool needs_to_int = false
    bool needs_int_to_string = false
    bool needs_popcount = false
    bool needs_hash = false
    bool needs_num_hash = false
    bool needs_string_helpers_ops = false
    bool needs_runtime_global_init = false
    bool has_edges_for_point = false
    bool uses_edges_for_point_mapper = false
    for (string map_type in map_types):
        if (normalize_llvm_type_name(map_value_type(map_type)) == 'string[]'):
            needs_string_array = true
    for (GlobalDeclIR global_decl in program.globals):
        BindingIR global_binding = ir_parse_binding_decl(strip_prefix(global_decl.header, 'global '))
        string global_type = normalize_llvm_type_name(global_binding.type_name)
        if (global_type == 'num'):
            needs_num = true
        if (global_type == 'string' || global_type == 'string[]'):
            needs_runtime_string_copy = true
        if (global_type == 'string[]'):
            needs_string_array = true
        if (global_type == 'string[][]'):
            needs_string_array_array = true
        if (global_type == 'int[]'):
            needs_int_array = true
        if (global_type == 'int[][]'):
            needs_int_array_array = true
        if (global_type == 'bool[]'):
            needs_bool_array = true
        if (global_type == 'prio_q<int>'):
            needs_prio_q_int = true
        if (global_type == 'set<int>'):
            needs_int_set = true
        if (global_type.starts_with('set<') && record_name_from_type(set_item_type(global_type)) != ''):
            string record_name = record_name_from_type(set_item_type(global_type))
            if (!(record_name in record_set_types)):
                record_set_types.push(record_name)
        if (global_type.ends_with('[]') && record_name_from_type(array_item_type(global_type)) != ''):
            needs_record_array = true
        if (!global_has_static_initializer(program, global_decl)):
            needs_runtime_global_init = true
        for (LinearInstruction op in global_decl.instructions):
            string result_type = normalize_llvm_type_name(op.result_type)
            if (result_type == 'num'):
                needs_num = true
            if (result_type == 'string' || result_type == 'string[]'):
                needs_runtime_string_copy = true
            if (result_type == 'string[]'):
                needs_string_array = true
            if (result_type == 'string[][]'):
                needs_string_array_array = true
            if (result_type == 'int[]'):
                needs_int_array = true
            if (result_type == 'int[][]'):
                needs_int_array_array = true
            if (result_type == 'bool[]'):
                needs_bool_array = true
            if (result_type == 'prio_q<int>'):
                needs_prio_q_int = true
            if (result_type == 'set<int>'):
                needs_int_set = true
            if (result_type.starts_with('set<') && record_name_from_type(set_item_type(result_type)) != ''):
                string record_name = record_name_from_type(set_item_type(result_type))
                if (!(record_name in record_set_types)):
                    record_set_types.push(record_name)
            if (result_type.ends_with('[]') && record_name_from_type(array_item_type(result_type)) != ''):
                needs_record_array = true
            if (op.kind == 'value' && op.detail == 'call' && !op.args.is_empty()):
                if (op.args[0] == 'read_lines'):
                    needs_read_lines = true
                if (op.args[0] == 'read_file'):
                    needs_read_file = true
                if (op.args[0] == 'getenv'):
                    needs_getenv = true
                if (op.args[0] == 'time_ms'):
                    needs_time_ms = true
    for (ParsedFunction function_ir in program.functions):
        if (function_ir.name == 'edges_for_point'):
            has_edges_for_point = true
        if (function_ir.name == 'main' && function_ir.params.length() == 1):
            needs_main_args = normalize_llvm_type_name(function_ir.params[0].type_name) == 'string[]'
        string return_type = normalize_llvm_type_name(function_ir.return_type)
        if (return_type == 'num'):
            needs_num = true
        if (return_type == 'string' || return_type == 'string[]'):
            needs_runtime_string_copy = true
        if (return_type == 'prio_q<int>'):
            needs_prio_q_int = true
        for (BindingIR param_decl in function_ir.params):
            string type_name = normalize_llvm_type_name(param_decl.type_name)
            if (type_name == 'num'):
                needs_num = true
            if (type_name == 'string' || type_name == 'string[]'):
                needs_runtime_string_copy = true
            if (type_name == 'string[]'):
                needs_string_array = true
            if (type_name == 'string[][]'):
                needs_string_array_array = true
            if (type_name == 'int[]'):
                needs_int_array = true
            if (type_name == 'int[][]'):
                needs_int_array_array = true
            if (type_name == 'bool[]'):
                needs_bool_array = true
            if (type_name == 'prio_q<int>'):
                needs_prio_q_int = true
            if (type_name == 'set<int>'):
                needs_int_set = true
            if (type_name.starts_with('set<') && record_name_from_type(set_item_type(type_name)) != ''):
                string record_name = record_name_from_type(set_item_type(type_name))
                if (!(record_name in record_set_types)):
                    record_set_types.push(record_name)
            if (type_name.ends_with('[]') && record_name_from_type(array_item_type(type_name)) != ''):
                needs_record_array = true
        for (BindingIR local_decl in function_ir.locals):
            string type_name = normalize_llvm_type_name(local_decl.type_name)
            if (type_name == 'num'):
                needs_num = true
            if (type_name == 'string' || type_name == 'string[]'):
                needs_runtime_string_copy = true
            if (type_name == 'string[]'):
                needs_string_array = true
            if (type_name == 'string[][]'):
                needs_string_array_array = true
            if (type_name == 'int[]'):
                needs_int_array = true
            if (type_name == 'int[][]'):
                needs_int_array_array = true
            if (type_name == 'bool[]'):
                needs_bool_array = true
            if (type_name == 'prio_q<int>'):
                needs_prio_q_int = true
            if (type_name == 'set<int>'):
                needs_int_set = true
            if (type_name.starts_with('set<') && record_name_from_type(set_item_type(type_name)) != ''):
                string record_name = record_name_from_type(set_item_type(type_name))
                if (!(record_name in record_set_types)):
                    record_set_types.push(record_name)
            if (type_name.ends_with('[]') && record_name_from_type(array_item_type(type_name)) != ''):
                needs_record_array = true
        for (BlockIR block in function_ir.blocks):
            if (block.terminator.kind == 'throw' || block.terminator.kind == 'throw_owned'):
                needs_throw = true
            for (LinearInstruction op in block.instructions):
                string result_type = normalize_llvm_type_name(op.result_type)
                if (result_type == 'num'):
                    needs_num = true
                if (result_type == 'string' || result_type == 'string[]'):
                    needs_runtime_string_copy = true
                if (result_type == 'string[]'):
                    needs_string_array = true
                if (result_type == 'string[][]'):
                    needs_string_array_array = true
                if (result_type == 'int[]'):
                    needs_int_array = true
                if (result_type == 'int[][]'):
                    needs_int_array_array = true
                if (result_type == 'bool[]'):
                    needs_bool_array = true
                if (result_type == 'prio_q<int>'):
                    needs_prio_q_int = true
                if (result_type == 'set<int>'):
                    needs_int_set = true
                if (result_type.starts_with('set<') && record_name_from_type(set_item_type(result_type)) != ''):
                    string record_name = record_name_from_type(set_item_type(result_type))
                    if (!(record_name in record_set_types)):
                        record_set_types.push(record_name)
                if (result_type.ends_with('[]') && record_name_from_type(array_item_type(result_type)) != ''):
                    needs_record_array = true
                if (op.kind == 'try' || op.kind == 'catch'):
                    needs_try_catch = true
                if (op.kind == 'release_local'):
                    BindingIR binding = ir_parse_binding_decl(op.detail)
                    if (is_backend_managed_type(binding.type_name)):
                        needs_backend_free = true
                if (op.kind == 'release_temp' && is_backend_managed_type(op.detail)):
                    needs_backend_free = true
                if (op.kind != 'value'):
                    continue
                if (op.detail == 'binary'):
                    if (!op.args.is_empty() && (op.args[0] == '==' || op.args[0] == '!=')):
                        if (lookup_temp_llvm_type(function_ir, op.args[1]) == 'string' && lookup_temp_llvm_type(function_ir, op.args[2]) == 'string'):
                            needs_strcmp = true
                    if (!op.args.is_empty() && op.args[0] == '+'):
                        string left_type = normalize_llvm_type_name(lookup_temp_llvm_type(function_ir, op.args[1]))
                        string right_type = normalize_llvm_type_name(lookup_temp_llvm_type(function_ir, op.args[2]))
                        if ((left_type == 'string' && right_type == 'int') || (left_type == 'int' && right_type == 'string')):
                            needs_int_to_string = true
                if (op.detail == 'call' && !op.args.is_empty()):
                    if (op.args[0] == 'has_flag' || op.args[0] == 'option_value'):
                        needs_string_helpers_ops = true
                    if (op.args[0] == 'read_lines'):
                        needs_read_lines = true
                    if (op.args[0] == 'read_file'):
                        needs_read_file = true
                    if (op.args[0] == 'getenv'):
                        needs_getenv = true
                    if (op.args[0] == 'time_ms'):
                        needs_time_ms = true
                    if (op.args[0] == 'open' || op.args[0] == 'write_line'):
                        needs_file_output = true
                    if (op.args[0] == 'to_int'):
                        needs_to_int = true
                    if (op.args[0] == 'popcount'):
                        needs_popcount = true
                    if (op.args[0] == 'hash'):
                        needs_hash = true
                    if (op.args[0] == 'print' && op.args.length() == 2):
                        string print_type = normalize_llvm_type_name(lookup_temp_llvm_type(function_ir, op.args[1]))
                        if (print_type == 'int'):
                            needs_print_int = true
                        if (print_type == 'string[]'):
                            needs_print_string_array = true
                        if (print_type == 'int[]'):
                            needs_print_int_array = true
                        if (print_type == 'bool'):
                            needs_print_bool = true
                        if (print_type == 'num'):
                            needs_print_num = true
                        if (print_type == 'string'):
                            needs_print_string = true
                if (op.detail == 'index'):
                    if (normalize_llvm_type_name(lookup_temp_llvm_type(function_ir, op.args[0])) == 'string'):
                        needs_string_helpers_ops = true
                if (op.detail == 'method-call'):
                    if (!op.args.is_empty() && op.args[0] == 'hash'):
                        needs_hash = true
                    if (op.args[0] == 'values'):
                        string base_type = normalize_llvm_type_name(lookup_temp_llvm_type(function_ir, op.args[1]))
                        if (base_type.starts_with('map<') && normalize_llvm_type_name(map_value_type(base_type)) == 'int'):
                            needs_int_to_string = true
                    string method_base_type = normalize_llvm_type_name(lookup_temp_llvm_type(function_ir, op.args[1]))
                    if (op.args[0] == 'length' && method_base_type == 'string'):
                        needs_strlen = true
                    if ((op.args[0] == 'index_of' || op.args[0] == 'contains') && method_base_type == 'string'):
                        needs_string_search = true
                    if ((op.args[0] == 'trim' || op.args[0] == 'trim_left' || op.args[0] == 'trim_right' || op.args[0] == 'split' || op.args[0] == 'split_lines' || op.args[0] == 'substring' || op.args[0] == 'to_int' || op.args[0] == 'index_of' || op.args[0] == 'contains' || op.args[0] == 'starts_with' || op.args[0] == 'ends_with' || op.args[0] == 'starts_with_at' || op.args[0] == 'is_alpha' || op.args[0] == 'is_digit' || op.args[0] == 'is_alnum' || op.args[0] == 'is_space' || op.args[0] == 'is_whitespace' || op.args[0] == 'replace') && method_base_type == 'string'):
                        needs_string_helpers_ops = true
                    if (!op.args.is_empty() && op.args[0] == 'hash' && method_base_type == 'num'):
                        needs_num_hash = true
                if (op.detail == 'method-call-lambda' && op.args.length() >= 1):
                    if (op.args[0] == 'map_to_parse_point'):
                        needs_map_to_parse_point = true
                    if (op.args[0] == 'map_to_string_length'):
                        needs_map_to_string_length = true
                    if (op.args[0] == 'map_to_edge_distance'):
                        needs_map_to_edge_distance = true
                    if (op.args[0] == 'flat_map_edges_for_point'):
                        uses_edges_for_point_mapper = true
                    if (op.args[0] == 'create_prio_q_int_desc'):
                        needs_prio_q_int = true
    if (needs_int_set):
        needs_int_array = true
    if (needs_prio_q_int):
        needs_int_array = true
    needs_flat_map_edges_for_point = has_edges_for_point && uses_edges_for_point_mapper
    if (needs_strcmp):
        LLVM_SCAN_NEEDS_STRCMP = 1
    if (needs_string_search):
        LLVM_SCAN_NEEDS_STRING_SEARCH = 1
    if (needs_strlen):
        LLVM_SCAN_NEEDS_STRLEN = 1
    if (needs_string_array):
        LLVM_SCAN_NEEDS_STRING_ARRAY = 1
    if (needs_string_array_array):
        LLVM_SCAN_NEEDS_STRING_ARRAY_ARRAY = 1
    if (needs_int_set):
        LLVM_SCAN_NEEDS_INT_SET = 1
    if (needs_bool_array):
        LLVM_SCAN_NEEDS_BOOL_ARRAY = 1
    if (needs_prio_q_int):
        LLVM_SCAN_NEEDS_PRIO_Q_INT = 1
    if (needs_int_array):
        LLVM_SCAN_NEEDS_INT_ARRAY = 1
    if (needs_int_array_array):
        LLVM_SCAN_NEEDS_INT_ARRAY_ARRAY = 1
    if (needs_record_array):
        LLVM_SCAN_NEEDS_RECORD_ARRAY = 1
    if (needs_map_to_parse_point):
        LLVM_SCAN_NEEDS_MAP_TO_PARSE_POINT = 1
    if (needs_map_to_string_length):
        LLVM_SCAN_NEEDS_MAP_TO_STRING_LENGTH = 1
    if (needs_map_to_edge_distance):
        LLVM_SCAN_NEEDS_MAP_TO_EDGE_DISTANCE = 1
    if (needs_flat_map_edges_for_point):
        LLVM_SCAN_NEEDS_FLAT_MAP_EDGES_FOR_POINT = 1
    if (needs_runtime_string_copy):
        LLVM_SCAN_NEEDS_RUNTIME_STRING_COPY = 1
    if (needs_backend_free):
        LLVM_SCAN_NEEDS_BACKEND_FREE = 1
    if (needs_main_args):
        LLVM_SCAN_NEEDS_MAIN_ARGS = 1
    if (needs_num):
        LLVM_SCAN_NEEDS_NUM = 1
    if (needs_print_int):
        LLVM_SCAN_NEEDS_PRINT_INT = 1
    if (needs_print_string_array):
        LLVM_SCAN_NEEDS_PRINT_STRING_ARRAY = 1
    if (needs_print_int_array):
        LLVM_SCAN_NEEDS_PRINT_INT_ARRAY = 1
    if (needs_print_bool):
        LLVM_SCAN_NEEDS_PRINT_BOOL = 1
    if (needs_print_num):
        LLVM_SCAN_NEEDS_PRINT_NUM = 1
    if (needs_print_string):
        LLVM_SCAN_NEEDS_PRINT_STRING = 1
    if (needs_throw):
        LLVM_SCAN_NEEDS_THROW = 1
    if (needs_try_catch):
