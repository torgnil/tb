string join_llvm_strings(string[] items, string separator):
    if (LLVM_BACKEND_PROFILE_ACTIVE != 0):
        LLVM_JOIN_CALLS += 1
        LLVM_JOIN_ITEMS_TOTAL += items.length()
    string result = ''
    int index = 0
    while (index < items.length()):
        if (index > 0):
            result += separator
        result += items[index]
        index += 1
    return result

bool string_contains_char(string value, string ch):
    int index = 0
    while (index < value.length()):
        if (value[index] == ch):
            return true
        index += 1
    return false

int num_literal_scale(string value):
    int dot_index = -1
    int index = 0
    while (index < value.length()):
        if (value[index] == '.'):
            dot_index = index
        index += 1
    if (dot_index < 0):
        return 0
    return value.length() - dot_index - 1

string num_literal_value_text(string value):
    string result = ''
    int index = 0
    while (index < value.length()):
        string ch = value[index]
        if (ch != '.'):
            result += ch
        index += 1
    return result

string normalize_llvm_type_name(string type_name):
    if (type_name.starts_with('const ')):
        return type_name.substring(6)
    if (type_name == 'exception'):
        return 'string'
    return type_name

