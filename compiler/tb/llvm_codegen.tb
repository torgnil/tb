    string clone_name = '%record.clone.' + temp_suffix
    return clone_name

string emit_num_store_value(ParsedFunction function_ir, string temp_name, string temp_suffix):
    if (normalize_llvm_type_name(lookup_temp_llvm_type(function_ir, temp_name)) == 'int'):
        return '%num.coerce.' + temp_suffix
    return temp_ref(temp_name)

string[] emit_num_materialize_if_needed(ParsedFunction function_ir, string temp_name, string temp_suffix):
    if (normalize_llvm_type_name(lookup_temp_llvm_type(function_ir, temp_name)) == 'int'):
        return ['  ' + emit_num_store_value(function_ir, temp_name, temp_suffix) + ' = call %tb_bootstrap_num @tb_bootstrap_num_make(i64 ' + temp_ref(temp_name) + ', i64 0)']
    return []

void track_num_binary_lines(string[] left_lines, string[] right_lines, int trailing_lines):
    LLVM_NUM_BINARY_COUNT += 1
    LLVM_NUM_BINARY_LEFT_MATERIALIZE_LINES += left_lines.length()
    LLVM_NUM_BINARY_RIGHT_MATERIALIZE_LINES += right_lines.length()
    LLVM_NUM_BINARY_LINES_TOTAL += left_lines.length() + right_lines.length() + trailing_lines

string track_string_compare_binary(string emitted):
    LLVM_STRING_COMPARE_BINARY_COUNT += 1
    LLVM_STRING_COMPARE_BINARY_BYTES += emitted.length()
    return emitted

string track_scalar_binary(string emitted):
    LLVM_SCALAR_BINARY_COUNT += 1
    LLVM_SCALAR_BINARY_BYTES += emitted.length()
    return emitted

string track_string_value(string emitted):
    if (LLVM_BACKEND_PROFILE_ACTIVE != 0):
        LLVM_STRING_VALUE_COUNT += 1
        LLVM_STRING_VALUE_BYTES += emitted.length()
    return emitted

string track_identifier_value(string emitted):
    if (LLVM_BACKEND_PROFILE_ACTIVE != 0):
        LLVM_IDENTIFIER_VALUE_COUNT += 1
