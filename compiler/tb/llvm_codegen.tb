string llvm_i32_index_temp(string temp_suffix):
    return '%index32.' + temp_suffix

string[] emit_i32_index_materialize(string temp_name, string temp_suffix):
    return ['  ' + llvm_i32_index_temp(temp_suffix) + ' = trunc i64 ' + temp_ref(temp_name) + ' to i32']


string[] emit_record_materialize_if_needed(ProgramIR program, ParsedFunction function_ir, string temp_name, string temp_suffix):
    if (temp_needs_backend_free(function_ir, temp_name)):
        return []
    if (!temp_is_record(function_ir, temp_name)):
        return []
    string record_name = record_name_from_type(lookup_temp_llvm_type(function_ir, temp_name))
    return ['  ' + emit_record_owned_value(function_ir, temp_name, temp_suffix) + ' = call ptr @tb_bootstrap_record_clone_' + record_name + '(ptr ' + temp_ref(temp_name) + ')']

string emit_record_array_owned_value(ParsedFunction function_ir, string temp_name, string temp_suffix):
    if (temp_needs_backend_free(function_ir, temp_name)):
        return temp_ref(temp_name)
    return '%record_array.clone.' + temp_suffix

