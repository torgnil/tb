bool program_uses_int_array_array(ProgramIR program):
    for (GlobalDeclIR global_decl in program.globals):
        BindingIR global_binding = ir_parse_binding_decl(strip_prefix(global_decl.header, 'global '))
        if (normalize_llvm_type_name(global_binding.type_name) == 'int[][]'):
            return true
    for (ParsedFunction function_ir in program.functions):
        for (BindingIR param_decl in function_ir.params):
            if (normalize_llvm_type_name(param_decl.type_name) == 'int[][]'):
                return true
        for (BindingIR local_decl in function_ir.locals):
            if (normalize_llvm_type_name(local_decl.type_name) == 'int[][]'):
                return true
        for (BlockIR block in function_ir.blocks):
            for (LinearInstruction op in block.instructions):
                if (normalize_llvm_type_name(op.result_type) == 'int[][]'):
                    return true
                if (op.kind == 'value' && op.detail == 'index'):
                    if (normalize_llvm_type_name(lookup_temp_llvm_type(function_ir, op.args[0])) == 'int[][]'):
                        return true
    return false

bool program_uses_prio_q_int(ProgramIR program):
    for (GlobalDeclIR global_decl in program.globals):
        BindingIR global_binding = ir_parse_binding_decl(strip_prefix(global_decl.header, 'global '))
        if (normalize_llvm_type_name(global_binding.type_name) == 'prio_q<int>'):
            return true
    for (ParsedFunction function_ir in program.functions):
        if (normalize_llvm_type_name(function_ir.return_type) == 'prio_q<int>'):
            return true
        for (BindingIR param_decl in function_ir.params):
            if (normalize_llvm_type_name(param_decl.type_name) == 'prio_q<int>'):
                return true
        for (BindingIR local_decl in function_ir.locals):
            if (normalize_llvm_type_name(local_decl.type_name) == 'prio_q<int>'):
                return true
        for (BlockIR block in function_ir.blocks):
            for (LinearInstruction op in block.instructions):
                if (normalize_llvm_type_name(op.result_type) == 'prio_q<int>'):
                    return true
                if (op.detail == 'method-call-lambda'):
                    if (op.args.length() >= 1):
                        if (op.args[0] == 'create_prio_q_int_desc'):
                            return true
                if (op.detail == 'method-call'):
                    if (op.args.length() >= 2):
                        if (normalize_llvm_type_name(lookup_temp_llvm_type(function_ir, op.args[1])) == 'prio_q<int>'):
                            return true
    return false

bool program_uses_record_array(ProgramIR program):
    for (GlobalDeclIR global_decl in program.globals):
        BindingIR global_binding = ir_parse_binding_decl(strip_prefix(global_decl.header, 'global '))
        string type_name = normalize_llvm_type_name(global_binding.type_name)
        if (type_name.ends_with('[]') && record_name_from_type(array_item_type(type_name)) != ''):
            return true
    for (ParsedFunction function_ir in program.functions):
        for (BindingIR param_decl in function_ir.params):
            string type_name = normalize_llvm_type_name(param_decl.type_name)
            if (type_name.ends_with('[]') && record_name_from_type(array_item_type(type_name)) != ''):
                return true
        for (BindingIR local_decl in function_ir.locals):
            string type_name = normalize_llvm_type_name(local_decl.type_name)
            if (type_name.ends_with('[]') && record_name_from_type(array_item_type(type_name)) != ''):
                return true
        for (BlockIR block in function_ir.blocks):
            for (LinearInstruction op in block.instructions):
                string result_type = normalize_llvm_type_name(op.result_type)
                if (result_type.ends_with('[]') && record_name_from_type(array_item_type(result_type)) != ''):
                    return true
                if (op.kind == 'value' && op.detail == 'index'):
                    string base_type = normalize_llvm_type_name(lookup_temp_llvm_type(function_ir, op.args[0]))
                    if (base_type.ends_with('[]') && record_name_from_type(array_item_type(base_type)) != ''):
                        return true
    return false

bool program_uses_map_to_parse_point(ProgramIR program):
    for (ParsedFunction function_ir in program.functions):
        for (BlockIR block in function_ir.blocks):
            for (LinearInstruction op in block.instructions):
                if (op.kind == 'value'):
                    if (op.detail == 'method-call-lambda'):
                        if (op.args.length() >= 1):
                            if (op.args[0] == 'map_to_parse_point'):
                                return true
    return false

bool program_uses_map_to_string_length(ProgramIR program):
    for (ParsedFunction function_ir in program.functions):
        for (BlockIR block in function_ir.blocks):
            for (LinearInstruction op in block.instructions):
                if (op.detail != 'method-call-lambda'):
                    continue
                if (op.args.length() < 1):
                    continue
                if (op.args[0] == 'map_to_string_length'):
                    return true
    return false

bool program_uses_map_to_edge_distance(ProgramIR program):
    for (ParsedFunction function_ir in program.functions):
        for (BlockIR block in function_ir.blocks):
            for (LinearInstruction op in block.instructions):
                if (op.kind == 'value'):
                    if (op.detail == 'method-call-lambda'):
                        if (op.args.length() >= 1):
                            if (op.args[0] == 'map_to_edge_distance'):
                                return true
    return false

bool program_uses_flat_map_edges_for_point(ProgramIR program):
    bool has_edges_for_point = call_return_type(program, 'edges_for_point') != 'unknown'
    if (!has_edges_for_point):
        return false
    for (ParsedFunction function_ir in program.functions):
        for (BlockIR block in function_ir.blocks):
            for (LinearInstruction op in block.instructions):
                if (op.kind == 'value'):
                    if (op.detail == 'method-call-lambda'):
                        if (op.args.length() >= 1):
                            if (op.args[0] == 'flat_map_edges_for_point'):
                                return true
    return false

bool program_uses_map(ProgramIR program):
    return !collect_used_map_types(program).is_empty()

RecordDeclIR lookup_record_decl(ProgramIR program, string name):
    int name_length = name.length()
    int index = LLVM_PROGRAM_CACHE_RECORD_NAMES.length() - 1
    while (index >= 0):
        if (LLVM_PROGRAM_CACHE_RECORD_NAMES[index].length() == name_length && LLVM_PROGRAM_CACHE_RECORD_NAMES[index] == name):
            return LLVM_PROGRAM_CACHE_RECORD_DECLS[index]
        index -= 1
    return RecordDeclIR('', [])

bool record_decl_list_has_name(RecordDeclIR[] records, string name):
    for (RecordDeclIR record_decl in records):
        if (strip_prefix(record_decl.header, 'record ') == name):
            return true
    return false

RecordDeclIR[] effective_record_decls(ProgramIR program):
    RecordDeclIR[] records = []
    for (RecordDeclIR record_decl in program.records):
        records.push(record_decl)
    if ((program_uses_map_to_parse_point(program) || program_uses_map_to_edge_distance(program) || program_uses_flat_map_edges_for_point(program)) && !record_decl_list_has_name(records, 'Point')):
        records.push(RecordDeclIR('record Point', ['field int x', 'field int y']))
    if ((program_uses_map_to_parse_point(program) || program_uses_map_to_edge_distance(program) || program_uses_flat_map_edges_for_point(program)) && !record_decl_list_has_name(records, 'Edge')):
        records.push(RecordDeclIR('record Edge', ['field int a', 'field int b', 'field int distance']))
    return records

RecordDeclIR[] effective_record_decls_for_scan(ProgramIR program, bool needs_map_to_parse_point, bool needs_map_to_edge_distance, bool needs_flat_map_edges_for_point):
    RecordDeclIR[] records = []
    for (RecordDeclIR record_decl in program.records):
        records.push(record_decl)
    if ((needs_map_to_parse_point || needs_map_to_edge_distance || needs_flat_map_edges_for_point) && !record_decl_list_has_name(records, 'Point')):
        records.push(RecordDeclIR('record Point', ['field int x', 'field int y']))
    if ((needs_map_to_parse_point || needs_map_to_edge_distance || needs_flat_map_edges_for_point) && !record_decl_list_has_name(records, 'Edge')):
        records.push(RecordDeclIR('record Edge', ['field int a', 'field int b', 'field int distance']))
    return records

bool enum_decl_exists(ProgramIR program, string name):
    for (EnumDeclIR enum_decl in program.enums):
        if (strip_prefix(enum_decl.header, 'enum ') == name):
            return true
    return false

BindingIR[] record_field_bindings(RecordDeclIR record_decl):
    BindingIR[] bindings = []
    for (string field in record_decl.fields):
        bindings.push(ir_parse_binding_decl(strip_prefix(field, 'field ')))
    return bindings

int managed_record_field_count(RecordDeclIR record_decl):
    int count = 0
    for (BindingIR field in record_field_bindings(record_decl)):
        if (is_backend_managed_type(field.type_name)):
            count += 1
    return count

int managed_record_field_slot(RecordDeclIR record_decl, string field_name):
    int slot = 0
    for (BindingIR field in record_field_bindings(record_decl)):
        if (field.name == field_name):
            if (is_backend_managed_type(field.type_name)):
                return slot
            return -1
        if (is_backend_managed_type(field.type_name)):
            slot += 1
    return -1

int record_field_index(RecordDeclIR record_decl, string field_name):
    BindingIR[] bindings = record_field_bindings(record_decl)
    int index = 0
    while (index < bindings.length()):
        if (bindings[index].name == field_name):
            return index
        index += 1
    return -1

BindingIR record_field_binding(RecordDeclIR record_decl, string field_name):
    BindingIR[] bindings = record_field_bindings(record_decl)
    for (BindingIR binding in bindings):
        if (binding.name == field_name):
            return binding
    return BindingIR('', '')

string llvm_record_type_name(string record_name):
    return '%tb_bootstrap_record_' + record_name

int llvm_record_owned_field_index(RecordDeclIR record_decl, string field_name):
    int slot = managed_record_field_slot(record_decl, field_name)
    if (slot < 0):
        return -1
    return record_field_bindings(record_decl).length() + slot

string emit_record_release_ptr(string record_name, string ptr_name):
    return '  call void @tb_bootstrap_record_free_' + record_name + '(ptr ' + ptr_name + ')'

BindingIR record_field_binding_from_temp(ProgramIR program, ParsedFunction function_ir, string temp_name, string field_name):
    string base_type = normalize_llvm_type_name(lookup_temp_llvm_type(function_ir, temp_name))
    string record_name = record_name_from_type(base_type)
    if (record_name == ''):
        throw 'unsupported llvm record field base type: ' + base_type
    RecordDeclIR record_decl = lookup_record_decl(program, record_name)
    if (record_decl.header == ''):
        throw 'unknown llvm record type: ' + record_name
    BindingIR field = record_field_binding(record_decl, field_name)
    if (field.name == ''):
        throw 'unknown llvm record field: ' + field_name
    return field

int record_field_index_from_temp(ProgramIR program, ParsedFunction function_ir, string temp_name, string field_name):
    string base_type = normalize_llvm_type_name(lookup_temp_llvm_type(function_ir, temp_name))
    string record_name = record_name_from_type(base_type)
    if (record_name == ''):
        throw 'unsupported llvm record field base type: ' + base_type
    RecordDeclIR record_decl = lookup_record_decl(program, record_name)
    if (record_decl.header == ''):
        throw 'unknown llvm record type: ' + record_name
    int index = record_field_index(record_decl, field_name)
    if (index < 0):
        throw 'unknown llvm record field: ' + field_name
    return index

string llvm_record_type_name_from_temp(ParsedFunction function_ir, string temp_name):
    string base_type = normalize_llvm_type_name(lookup_temp_llvm_type(function_ir, temp_name))
    string record_name = record_name_from_type(base_type)
    if (record_name == ''):
        throw 'unsupported llvm record field base type: ' + base_type
    return llvm_record_type_name(record_name)

string emit_record_field_ptr(ProgramIR program, ParsedFunction function_ir, string base_temp_name, string field_name, string ptr_name):
    return '  ' + ptr_name + ' = getelementptr inbounds ' + llvm_record_type_name_from_temp(function_ir, base_temp_name) + ', ptr ' + temp_ref(base_temp_name) + ', i32 0, i32 ' + record_field_index_from_temp(program, function_ir, base_temp_name, field_name)

string emit_record_owned_field_ptr(ProgramIR program, ParsedFunction function_ir, string base_temp_name, string field_name, string ptr_name):
    string base_type = normalize_llvm_type_name(lookup_temp_llvm_type(function_ir, base_temp_name))
    string record_name = record_name_from_type(base_type)
    if (record_name == ''):
        throw 'unsupported llvm record owned field base type: ' + base_type
    RecordDeclIR record_decl = lookup_record_decl(program, record_name)
    if (record_decl.header == ''):
        throw 'unknown llvm record type: ' + record_name
    int owned_index = llvm_record_owned_field_index(record_decl, field_name)
    if (owned_index < 0):
        throw 'requested owned field for unmanaged record field: ' + field_name
    return '  ' + ptr_name + ' = getelementptr inbounds ' + llvm_record_type_name(record_name) + ', ptr ' + temp_ref(base_temp_name) + ', i32 0, i32 ' + owned_index

bool program_uses_backend_free(ProgramIR program):
    for (ParsedFunction function_ir in program.functions):
        for (BlockIR block in function_ir.blocks):
            for (LinearInstruction op in block.instructions):
                if (op.kind == 'release_local'):
                    BindingIR binding = ir_parse_binding_decl(op.detail)
                    if (is_backend_managed_type(binding.type_name)):
                        return true
                if (op.kind == 'release_temp' && is_backend_managed_type(op.detail)):
                    return true
                if (op.kind == 'release_field'):
                    return true
                if (op.kind == 'release_index'):
                    return true
    return false

string emit_string_constant(StringConstIR constant):
    string line = string_symbol_ref(constant.symbol) + ' = private unnamed_addr constant [' + constant.length + ' x i8] c"' + constant.encoded_value + '"'
    LLVM_EMIT_STRING_CONSTANT_CALLS += 1
    LLVM_EMIT_STRING_CONSTANT_BYTES += line.length()
    return line

string[] emit_read_lines_helper():
    string[] lines = []
    lines.push('@.mode.read_lines = private unnamed_addr constant [2 x i8] c"r\\00"')
    lines.push('@.fmt.read_lines.open.error = private unnamed_addr constant [8 x i8] c"%s: %s\\0A\\00"')
    lines.push('@.msg.read_lines = private unnamed_addr constant [11 x i8] c"read_lines\\00"')
    lines.push('define private ptr @tb_bootstrap_read_lines(ptr %path) {')
    lines.push('entry:')
    lines.push('  %mode = getelementptr inbounds [2 x i8], ptr @.mode.read_lines, i32 0, i32 0')
    lines.push('  %file = call ptr @fopen(ptr %path, ptr %mode)')
    lines.push('  %file.ok = icmp ne ptr %file, null')
    lines.push('  br i1 %file.ok, label %count.setup, label %open.fail')
    lines.push('open.fail:')
    lines.push('  %handler = load ptr, ptr ' + exception_handler_symbol())
    lines.push('  %has.handler = icmp ne ptr %handler, null')
    lines.push('  br i1 %has.handler, label %open.unwind, label %open.fatal')
    lines.push('open.unwind:')
    lines.push('  %path.copy = call ptr @tb_bootstrap_string_copy(ptr %path)')
    lines.push('  store ptr %path.copy, ptr ' + exception_message_symbol())
    lines.push('  call void @longjmp(ptr %handler, i32 1)')
    lines.push('  unreachable')
    lines.push('open.fatal:')
    lines.push('  %fmt = getelementptr inbounds [8 x i8], ptr @.fmt.read_lines.open.error, i32 0, i32 0')
    lines.push('  %msg = getelementptr inbounds [11 x i8], ptr @.msg.read_lines, i32 0, i32 0')
    lines.push('  %print = call i32 @printf(ptr %fmt, ptr %msg, ptr %path)')
    lines.push('  call void @exit(i32 1)')
    lines.push('  unreachable')
    lines.push('count.setup:')
    lines.push('  %line.slot = alloca ptr')
    lines.push('  %cap.slot = alloca i64')
    lines.push('  %count.slot = alloca i32')
    lines.push('  store ptr null, ptr %line.slot')
    lines.push('  store i64 0, ptr %cap.slot')
    lines.push('  store i32 0, ptr %count.slot')
    lines.push('  br label %count.cond')
    lines.push('count.cond:')
    lines.push('  %read.1 = call i64 @getline(ptr %line.slot, ptr %cap.slot, ptr %file)')
    lines.push('  %has.line.1 = icmp sge i64 %read.1, 0')
    lines.push('  br i1 %has.line.1, label %count.body, label %count.done')
    lines.push('count.body:')
    lines.push('  %count.old = load i32, ptr %count.slot')
    lines.push('  %count.new = add i32 %count.old, 1')
    lines.push('  store i32 %count.new, ptr %count.slot')
    lines.push('  br label %count.cond')
    lines.push('count.done:')
    lines.push('  %count = load i32, ptr %count.slot')
    lines.push('  call void @rewind(ptr %file)')
    lines.push('  %array = call ptr @tb_bootstrap_string_array_new(i32 %count)')
    lines.push('  br label %fill.cond')
    lines.push('fill.cond:')
    lines.push('  %index = phi i32 [0, %count.done], [%next.index, %fill.step]')
    lines.push('  %keep.fill = icmp slt i32 %index, %count')
    lines.push('  br i1 %keep.fill, label %fill.body, label %fill.done')
    lines.push('fill.body:')
    lines.push('  %line.ptr.2 = load ptr, ptr %line.slot')
    lines.push('  %cap.2 = load i64, ptr %cap.slot')
    lines.push('  %read.2 = call i64 @getline(ptr %line.slot, ptr %cap.slot, ptr %file)')
    lines.push('  %raw.line = load ptr, ptr %line.slot')
    lines.push('  %trim.check = icmp sgt i64 %read.2, 0')
    lines.push('  br i1 %trim.check, label %trim.body, label %trim.skip')
    lines.push('trim.body:')
    lines.push('  %last.index = sub i64 %read.2, 1')
    lines.push('  %last.ptr = getelementptr inbounds i8, ptr %raw.line, i64 %last.index')
    lines.push('  %last.char = load i8, ptr %last.ptr')
    lines.push('  %is.nl = icmp eq i8 %last.char, 10')
    lines.push('  br i1 %is.nl, label %trim.nl, label %trim.skip')
    lines.push('trim.nl:')
    lines.push('  store i8 0, ptr %last.ptr')
    lines.push('  br label %trim.skip')
    lines.push('trim.skip:')
    lines.push('  %line.copy = call ptr @tb_bootstrap_string_copy(ptr %raw.line)')
    lines.push('  call void @tb_bootstrap_string_array_set_owned(ptr %array, i32 %index, ptr %line.copy, i1 true)')
    lines.push('  br label %fill.step')
    lines.push('fill.step:')
    lines.push('  %next.index = add i32 %index, 1')
    lines.push('  br label %fill.cond')
    lines.push('fill.done:')
    lines.push('  %line.final = load ptr, ptr %line.slot')
    lines.push('  %line.final.ok = icmp ne ptr %line.final, null')
    lines.push('  br i1 %line.final.ok, label %free.line, label %close.file')
    lines.push('free.line:')
    lines.push('  call void @free(ptr %line.final)')
    lines.push('  br label %close.file')
    lines.push('close.file:')
    lines.push('  %close.result = call i32 @fclose(ptr %file)')
    lines.push('  ret ptr %array')
    lines.push('}')
    return lines

string[] emit_read_file_helper():
    string[] lines = []
    lines.push('@.mode.read_file = private unnamed_addr constant [2 x i8] c"r\\00"')
    lines.push('@.fmt.read_file.open.error = private unnamed_addr constant [8 x i8] c"%s: %s\\0A\\00"')
    lines.push('@.msg.read_file = private unnamed_addr constant [10 x i8] c"read_file\\00"')
    lines.push('define private ptr @tb_bootstrap_read_file(ptr %path) {')
    lines.push('entry:')
    lines.push('  %mode = getelementptr inbounds [2 x i8], ptr @.mode.read_file, i32 0, i32 0')
    lines.push('  %file = call ptr @fopen(ptr %path, ptr %mode)')
    lines.push('  %file.ok = icmp ne ptr %file, null')
    lines.push('  br i1 %file.ok, label %setup, label %open.fail')
    lines.push('open.fail:')
    lines.push('  %handler = load ptr, ptr ' + exception_handler_symbol())
    lines.push('  %has.handler = icmp ne ptr %handler, null')
    lines.push('  br i1 %has.handler, label %open.unwind, label %open.fatal')
    lines.push('open.unwind:')
    lines.push('  %path.copy = call ptr @tb_bootstrap_string_copy(ptr %path)')
    lines.push('  store ptr %path.copy, ptr ' + exception_message_symbol())
    lines.push('  call void @longjmp(ptr %handler, i32 1)')
    lines.push('  unreachable')
    lines.push('open.fatal:')
    lines.push('  %fmt = getelementptr inbounds [8 x i8], ptr @.fmt.read_file.open.error, i32 0, i32 0')
    lines.push('  %msg = getelementptr inbounds [10 x i8], ptr @.msg.read_file, i32 0, i32 0')
    lines.push('  %print = call i32 @printf(ptr %fmt, ptr %msg, ptr %path)')
    lines.push('  call void @exit(i32 1)')
    lines.push('  unreachable')
    lines.push('setup:')
    lines.push('  %line.slot = alloca ptr')
    lines.push('  %cap.slot = alloca i64')
    lines.push('  %result.slot = alloca ptr')
    lines.push('  store ptr null, ptr %line.slot')
    lines.push('  store i64 0, ptr %cap.slot')
    lines.push('  %result.init = call ptr @tb_string_new(i64 0)')
    lines.push('  store ptr %result.init, ptr %result.slot')
    lines.push('  br label %loop.cond')
    lines.push('loop.cond:')
    lines.push('  %read = call i64 @getline(ptr %line.slot, ptr %cap.slot, ptr %file)')
    lines.push('  %has.line = icmp sge i64 %read, 0')
    lines.push('  br i1 %has.line, label %loop.body, label %done')
    lines.push('loop.body:')
    lines.push('  %result.old = load ptr, ptr %result.slot')
    lines.push('  %line = load ptr, ptr %line.slot')
    lines.push('  %result.new = call ptr @tb_bootstrap_string_concat(ptr %result.old, ptr %line)')
    lines.push('  call void @tb_release(ptr %result.old)')
    lines.push('  store ptr %result.new, ptr %result.slot')
    lines.push('  br label %loop.cond')
    lines.push('done:')
    lines.push('  %line.final = load ptr, ptr %line.slot')
    lines.push('  %line.final.ok = icmp ne ptr %line.final, null')
    lines.push('  br i1 %line.final.ok, label %free.line, label %close.file')
    lines.push('free.line:')
    lines.push('  call void @free(ptr %line.final)')
    lines.push('  br label %close.file')
    lines.push('close.file:')
    lines.push('  %close.result = call i32 @fclose(ptr %file)')
    lines.push('  %result.final = load ptr, ptr %result.slot')
    lines.push('  ret ptr %result.final')
    lines.push('}')
    return lines

string[] emit_getenv_helper():
    string[] lines = []
    lines.push('define private ptr @tb_bootstrap_getenv(ptr %name) {')
    lines.push('entry:')
    lines.push('  %value = call ptr @getenv(ptr %name)')
    lines.push('  %missing = icmp eq ptr %value, null')
    lines.push('  br i1 %missing, label %empty, label %copy')
    lines.push('empty:')
    lines.push('  %empty.data = call ptr @tb_string_new(i64 0)')
    lines.push('  ret ptr %empty.data')
    lines.push('copy:')
    lines.push('  %value.copy = call ptr @tb_bootstrap_string_copy(ptr %value)')
    lines.push('  ret ptr %value.copy')
    lines.push('}')
    return lines

string[] emit_file_output_helpers():
    string[] lines = []
    lines.push('@.mode.write = private unnamed_addr constant [2 x i8] c"w\\00"')
    lines.push('define private ptr @tb_bootstrap_open_write(ptr %path) {')
    lines.push('entry:')
    lines.push('  %mode = getelementptr inbounds [2 x i8], ptr @.mode.write, i32 0, i32 0')
    lines.push('  %file = call ptr @fopen(ptr %path, ptr %mode)')
    lines.push('  ret ptr %file')
    lines.push('}')
    lines.push('define private void @tb_bootstrap_write_line(ptr %file, ptr %line) {')
    lines.push('entry:')
    lines.push('  %write = call i32 @fputs(ptr %line, ptr %file)')
    lines.push('  %nl = call i32 @fputc(i32 10, ptr %file)')
    lines.push('  ret void')
    lines.push('}')
    lines.push('define private void @tb_bootstrap_write_lines(ptr %file, ptr %lines) {')
    lines.push('entry:')
    lines.push('  %len.ptr = getelementptr inbounds { i32, i32, ptr, ptr }, ptr %lines, i32 0, i32 0')
    lines.push('  %len = load i32, ptr %len.ptr')
    lines.push('  %data.ptr.ptr = getelementptr inbounds { i32, i32, ptr, ptr }, ptr %lines, i32 0, i32 2')
    lines.push('  %data.ptr = load ptr, ptr %data.ptr.ptr')
    lines.push('  br label %loop.cond')
    lines.push('loop.cond:')
    lines.push('  %index = phi i32 [0, %entry], [%next.index, %loop.step]')
    lines.push('  %keep.loop = icmp slt i32 %index, %len')
    lines.push('  br i1 %keep.loop, label %loop.body, label %done')
    lines.push('loop.body:')
    lines.push('  %line.slot = getelementptr inbounds ptr, ptr %data.ptr, i32 %index')
    lines.push('  %line = load ptr, ptr %line.slot')
    lines.push('  %write = call i32 @fputs(ptr %line, ptr %file)')
    lines.push('  %nl = call i32 @fputc(i32 10, ptr %file)')
    lines.push('  br label %loop.step')
    lines.push('loop.step:')
    lines.push('  %next.index = add i32 %index, 1')
    lines.push('  br label %loop.cond')
    lines.push('done:')
    lines.push('  ret void')
    lines.push('}')
    lines.push('define private void @tb_bootstrap_close_write(ptr %file) {')
    lines.push('entry:')
    lines.push('  %close = call i32 @fclose(ptr %file)')
    lines.push('  ret void')
    lines.push('}')
    return lines

string emit_string_array_value_instruction(ParsedFunction function_ir, LinearInstruction op):
    string lhs = temp_ref(op.lhs)
    string[] lines = ['  ' + lhs + ' = call ptr @tb_bootstrap_string_array_new(i32 ' + op.args.length() + ')']
    int index = 0
    while (index < op.args.length()):
        string item_name = op.args[index]
        string stored_value = temp_ref(item_name)
        string owned_flag = 'false'
        if (temp_is_string(function_ir, item_name)):
            if (temp_needs_backend_free(function_ir, item_name)):
                owned_flag = 'true'
            else:
                string copy_name = '%array.elem.' + op.lhs + '.' + index
                lines.push('  ' + copy_name + ' = call ptr @tb_bootstrap_string_copy(ptr ' + temp_ref(item_name) + ')')
                stored_value = copy_name
                owned_flag = 'true'
        lines.push('  call void @tb_bootstrap_string_array_set_owned(ptr ' + lhs + ', i32 ' + index + ', ptr ' + stored_value + ', i1 ' + owned_flag + ')')
        index += 1
    return join_llvm_strings(lines, '\n')

string emit_string_array_array_value_instruction(ParsedFunction function_ir, LinearInstruction op):
    string lhs = temp_ref(op.lhs)
    string[] lines = ['  ' + lhs + ' = call ptr @tb_bootstrap_string_array_array_new(i32 ' + op.args.length() + ')']
    int index = 0
    while (index < op.args.length()):
        string item_name = op.args[index]
        string stored_value = temp_ref(item_name)
        string owned_flag = 'false'
        string item_type = normalize_llvm_type_name(lookup_temp_llvm_type(function_ir, item_name))
        if (item_type == '[]'):
            string empty_name = '%string_array_array.item.' + op.lhs + '.' + index
            lines.push('  ' + empty_name + ' = call ptr @tb_bootstrap_string_array_new(i32 0)')
            stored_value = empty_name
            owned_flag = 'true'
        else if (temp_is_string_array(function_ir, item_name)):
            if (temp_needs_backend_free(function_ir, item_name)):
                owned_flag = 'true'
            else:
                string clone_name = '%string_array.clone.' + op.lhs + '.' + index
                lines.push('  ' + clone_name + ' = call ptr @tb_bootstrap_string_array_clone(ptr ' + temp_ref(item_name) + ')')
                stored_value = clone_name
                owned_flag = 'true'
        lines.push('  call void @tb_bootstrap_string_array_array_set_owned(ptr ' + lhs + ', i32 ' + index + ', ptr ' + stored_value + ', i1 ' + owned_flag + ')')
        index += 1
    return join_llvm_strings(lines, '\n')

string emit_bool_array_value_instruction(LinearInstruction op):
    string lhs = temp_ref(op.lhs)
    string[] lines = ['  ' + lhs + ' = call ptr @tb_bootstrap_bool_array_new(i32 ' + op.args.length() + ')']
    int index = 0
    while (index < op.args.length()):
        lines.push('  call void @tb_bootstrap_bool_array_set(ptr ' + lhs + ', i32 ' + index + ', i1 ' + temp_ref(op.args[index]) + ')')
        index += 1
    return join_llvm_strings(lines, '\n')

string emit_int_array_value_instruction(LinearInstruction op):
    string lhs = temp_ref(op.lhs)
    string[] lines = ['  ' + lhs + ' = call ptr @tb_bootstrap_int_array_new(i32 ' + op.args.length() + ')']
    int index = 0
    while (index < op.args.length()):
        string item_name = op.args[index]
        lines.push('  call void @tb_bootstrap_int_array_set(ptr ' + lhs + ', i32 ' + index + ', i64 ' + temp_ref(item_name) + ')')
        index += 1
    return join_llvm_strings(lines, '\n')

string emit_int_set_value_instruction(LinearInstruction op):
    string lhs = temp_ref(op.lhs)
    string[] lines = ['  ' + lhs + ' = call ptr @tb_bootstrap_int_set_new()']
    int index = 0
    while (index < op.args.length()):
        lines.push('  call void @tb_bootstrap_int_set_add(ptr ' + lhs + ', i64 ' + temp_ref(op.args[index]) + ')')
        index += 1
    return join_llvm_strings(lines, '\n')

string emit_record_set_value_instruction(ProgramIR program, ParsedFunction function_ir, LinearInstruction op):
    string set_type = normalize_llvm_type_name(op.result_type)
    string record_name = record_name_from_type(set_item_type(set_type))
    string lhs = temp_ref(op.lhs)
    string[] lines = ['  ' + lhs + ' = call ptr @tb_bootstrap_record_set_new_' + record_name + '()']
    int index = 0
    while (index < op.args.length()):
        string value_name = op.args[index]
        string value_suffix = op.lhs + '.set.' + index
        string stored_value = temp_ref(value_name)
        string owned_flag = 'false'
        for (string line in emit_record_materialize_if_needed(program, function_ir, value_name, value_suffix)):
            lines.push(line)
        if (temp_is_record(function_ir, value_name)):
            if (temp_needs_backend_free(function_ir, value_name)):
                owned_flag = 'true'
            else:
                stored_value = emit_record_owned_value(function_ir, value_name, value_suffix)
                owned_flag = 'true'
        lines.push('  call void @tb_bootstrap_record_set_add_' + record_name + '(ptr ' + lhs + ', ptr ' + stored_value + ', i1 ' + owned_flag + ')')
        index += 1
    return join_llvm_strings(lines, '\n')

string emit_int_array_map_to_lambda_instruction(ParsedFunction function_ir, LinearInstruction op):
    string lhs = temp_ref(op.lhs)
    string op_name = op.args[3]
    if (op_name == '+'):
        return '  ' + lhs + ' = call ptr @tb_bootstrap_int_array_map_add(ptr ' + temp_ref(op.args[1]) + ', i64 ' + temp_ref(op.args[4]) + ')'
    if (op_name == '-'):
        return '  ' + lhs + ' = call ptr @tb_bootstrap_int_array_map_sub(ptr ' + temp_ref(op.args[1]) + ', i64 ' + temp_ref(op.args[4]) + ')'
    if (op_name == '*'):
        return '  ' + lhs + ' = call ptr @tb_bootstrap_int_array_map_mul(ptr ' + temp_ref(op.args[1]) + ', i64 ' + temp_ref(op.args[4]) + ')'
    if (op_name == '/'):
        return '  ' + lhs + ' = call ptr @tb_bootstrap_int_array_map_div(ptr ' + temp_ref(op.args[1]) + ', i64 ' + temp_ref(op.args[4]) + ')'
    if (op_name == '%'):
        return '  ' + lhs + ' = call ptr @tb_bootstrap_int_array_map_mod(ptr ' + temp_ref(op.args[1]) + ', i64 ' + temp_ref(op.args[4]) + ')'
    throw 'unsupported llvm int[] map_to lambda op: ' + op_name

string emit_bootstrap_fixture_lambda_instruction(ProgramIR program, ParsedFunction function_ir, LinearInstruction op):
    string lhs = temp_ref(op.lhs)
    if (op.args[0] == 'map_to_string_length'):
        return '  ' + lhs + ' = call ptr @tb_bootstrap_string_array_map_to_length(ptr ' + temp_ref(op.args[1]) + ')'
    if (op.args[0] == 'map_to_parse_point'):
        return '  ' + lhs + ' = call ptr @tb_bootstrap_string_array_map_to_parse_point(ptr ' + temp_ref(op.args[1]) + ')'
    if (op.args[0] == 'map_to_edge_distance'):
        return '  ' + lhs + ' = call ptr @tb_bootstrap_int_array_map_to_Edge_distance(ptr ' + temp_ref(op.args[1]) + ', i64 ' + temp_ref(op.args[3]) + ', ptr ' + temp_ref(op.args[4]) + ', ptr ' + temp_ref(op.args[5]) + ')'
    if (op.args[0] == 'flat_map_edges_for_point'):
        return '  ' + lhs + ' = call ptr @tb_bootstrap_int_array_flat_map_edges_for_point(ptr ' + temp_ref(op.args[1]) + ', ptr ' + temp_ref(op.args[3]) + ')'
    throw 'unsupported llvm fixture lambda op: ' + join_llvm_strings(op.args, ' ')

string emit_sort_lambda_instruction(ProgramIR program, ParsedFunction function_ir, LinearInstruction op):
    string lhs = temp_ref(op.lhs)
    if (op.args[0] == 'sort_int_asc'):
        return '  ' + lhs + ' = call ptr @tb_bootstrap_int_array_sort_asc(ptr ' + temp_ref(op.args[1]) + ')'
    if (op.args[0] == 'sort_int_desc'):
        return '  ' + lhs + ' = call ptr @tb_bootstrap_int_array_sort_desc(ptr ' + temp_ref(op.args[1]) + ')'
    if (op.args[0] == 'sort_record_field_asc'):
        string base_type = normalize_llvm_type_name(lookup_temp_llvm_type(function_ir, op.args[1]))
        string record_name = record_name_from_type(array_item_type(base_type))
        return '  ' + lhs + ' = call ptr @tb_bootstrap_record_array_sort_' + record_name + '_by_' + op.args[4] + '(ptr ' + temp_ref(op.args[1]) + ')'
    throw 'unsupported llvm sort lambda op: ' + join_llvm_strings(op.args, ' ')

string emit_prio_q_lambda_instruction(ParsedFunction function_ir, LinearInstruction op):
    string lhs = temp_ref(op.lhs)
    if (op.args[0] == 'create_prio_q_int_desc'):
        return '  ' + lhs + ' = call ptr @tb_bootstrap_create_prio_q_int_by(ptr ' + temp_ref(op.args[1]) + ', ptr @tb_bootstrap_cmp_int_desc)'
    if (op.args[0] == 'create_prio_q_record_field_desc'):
        string base_type = normalize_llvm_type_name(lookup_temp_llvm_type(function_ir, op.args[1]))
        string record_name = record_name_from_type(array_item_type(base_type))
        return '  ' + lhs + ' = call ptr @tb_bootstrap_create_prio_q_generic_' + record_name + '_by(ptr ' + temp_ref(op.args[1]) + ', ptr @tb_bootstrap_cmp_record_pair_' + record_name + '_by_' + op.args[4] + ')'
    throw 'unsupported llvm prio_q lambda op: ' + join_llvm_strings(op.args, ' ')

string[] emit_string_length_map_helper():
    string[] lines = []
    lines.push('define private ptr @tb_bootstrap_string_array_map_to_length(ptr %array) {')
    lines.push('entry:')
    lines.push('  %len = call i32 @tb_bootstrap_string_array_length(ptr %array)')
    lines.push('  %result = call ptr @tb_bootstrap_int_array_new(i32 %len)')
    lines.push('  br label %loop.cond')
    lines.push('loop.cond:')
    lines.push('  %index = phi i32 [0, %entry], [%next.index, %loop.step]')
    lines.push('  %keep.loop = icmp slt i32 %index, %len')
    lines.push('  br i1 %keep.loop, label %loop.body, label %done')
    lines.push('loop.body:')
    lines.push('  %item = call ptr @tb_bootstrap_string_array_get(ptr %array, i32 %index)')
    lines.push('  %item.len = call i64 @strlen(ptr %item)')
    lines.push('  call void @tb_bootstrap_int_array_set(ptr %result, i32 %index, i64 %item.len)')
    lines.push('  br label %loop.step')
    lines.push('loop.step:')
    lines.push('  %next.index = add i32 %index, 1')
    lines.push('  br label %loop.cond')
    lines.push('done:')
    lines.push('  ret ptr %result')
    lines.push('}')
    return lines

string[] emit_time_ms_helper():
    string[] lines = []
    lines.push('%tb_bootstrap_timeval = type { i64, i64 }')
    lines.push('define private i64 @tb_bootstrap_time_ms() {')
    lines.push('entry:')
    lines.push('  %tv = alloca %tb_bootstrap_timeval')
    lines.push('  %status = call i32 @gettimeofday(ptr %tv, ptr null)')
    lines.push('  %sec.ptr = getelementptr inbounds %tb_bootstrap_timeval, ptr %tv, i32 0, i32 0')
    lines.push('  %usec.ptr = getelementptr inbounds %tb_bootstrap_timeval, ptr %tv, i32 0, i32 1')
    lines.push('  %sec = load i64, ptr %sec.ptr')
    lines.push('  %usec = load i64, ptr %usec.ptr')
    lines.push('  %sec.ms = mul i64 %sec, 1000')
    lines.push('  %usec.ms = sdiv i64 %usec, 1000')
    lines.push('  %total = add i64 %sec.ms, %usec.ms')
    lines.push('  ret i64 %total')
    lines.push('}')
    return lines

string[] emit_map_to_parse_point_helper():
    string[] lines = []
    lines.push('define private ptr @tb_bootstrap_string_array_map_to_parse_point(ptr %array) {')
    lines.push('entry:')
    lines.push('  %len = call i32 @tb_bootstrap_string_array_length(ptr %array)')
    lines.push('  %result = call ptr @tb_bootstrap_record_array_new_Point(i32 %len)')
    lines.push('  br label %loop.cond')
    lines.push('loop.cond:')
    lines.push('  %index = phi i32 [0, %entry], [%next.index, %loop.step]')
    lines.push('  %keep.loop = icmp slt i32 %index, %len')
    lines.push('  br i1 %keep.loop, label %loop.body, label %done')
    lines.push('loop.body:')
    lines.push('  %item = call ptr @tb_bootstrap_string_array_get(ptr %array, i32 %index)')
    lines.push('  %mapped = call ptr @parse_point(ptr %item)')
    lines.push('  call void @tb_bootstrap_record_array_set_owned_Point(ptr %result, i32 %index, ptr %mapped, i1 true)')
    lines.push('  br label %loop.step')
    lines.push('loop.step:')
    lines.push('  %next.index = add i32 %index, 1')
    lines.push('  br label %loop.cond')
    lines.push('done:')
    lines.push('  ret ptr %result')
    lines.push('}')
    return lines

string[] emit_map_to_edge_distance_helper():
    string[] lines = []
    lines.push('define private ptr @tb_bootstrap_int_array_map_to_Edge_distance(ptr %array, i64 %capture_i, ptr %left, ptr %points) {')
    lines.push('entry:')
    lines.push('  %len = call i32 @tb_bootstrap_int_array_length(ptr %array)')
    lines.push('  %result = call ptr @tb_bootstrap_record_array_new_Edge(i32 %len)')
    lines.push('  br label %loop.cond')
    lines.push('loop.cond:')
    lines.push('  %index = phi i32 [0, %entry], [%next.index, %loop.step]')
    lines.push('  %keep.loop = icmp slt i32 %index, %len')
    lines.push('  br i1 %keep.loop, label %loop.body, label %done')
    lines.push('loop.body:')
    lines.push('  %j = call i64 @tb_bootstrap_int_array_get(ptr %array, i32 %index)')
    lines.push('  %j.index = trunc i64 %j to i32')
    lines.push('  %point = call ptr @tb_bootstrap_record_array_get_Point(ptr %points, i32 %j.index)')
    lines.push('  %distance = call i64 @point_distance(ptr %left, ptr %point)')
    lines.push('  %edge.size.ptr = getelementptr %tb_bootstrap_record_Edge, ptr null, i32 1')
    lines.push('  %edge.size = ptrtoint ptr %edge.size.ptr to i64')
    lines.push('  %edge = call ptr @malloc(i64 %edge.size)')
    lines.push('  %edge.field.0 = getelementptr inbounds %tb_bootstrap_record_Edge, ptr %edge, i32 0, i32 0')
    lines.push('  store i64 %capture_i, ptr %edge.field.0')
    lines.push('  %edge.field.1 = getelementptr inbounds %tb_bootstrap_record_Edge, ptr %edge, i32 0, i32 1')
    lines.push('  store i64 %j, ptr %edge.field.1')
    lines.push('  %edge.field.2 = getelementptr inbounds %tb_bootstrap_record_Edge, ptr %edge, i32 0, i32 2')
    lines.push('  store i64 %distance, ptr %edge.field.2')
    lines.push('  call void @tb_bootstrap_record_array_set_owned_Edge(ptr %result, i32 %index, ptr %edge, i1 true)')
    lines.push('  br label %loop.step')
    lines.push('loop.step:')
    lines.push('  %next.index = add i32 %index, 1')
    lines.push('  br label %loop.cond')
    lines.push('done:')
    lines.push('  ret ptr %result')
    lines.push('}')
    return lines

string[] emit_flat_map_edges_for_point_helper():
    string[] lines = []
    lines.push('define private ptr @tb_bootstrap_int_array_flat_map_edges_for_point(ptr %array, ptr %points) {')
    lines.push('entry:')
    lines.push('  %result = call ptr @tb_bootstrap_record_array_new_Edge(i32 0)')
    lines.push('  %len = call i32 @tb_bootstrap_int_array_length(ptr %array)')
    lines.push('  br label %outer.cond')
    lines.push('outer.cond:')
    lines.push('  %outer.index = phi i32 [0, %entry], [%outer.next, %outer.step]')
    lines.push('  %keep.outer = icmp slt i32 %outer.index, %len')
    lines.push('  br i1 %keep.outer, label %outer.body, label %done')
    lines.push('outer.body:')
    lines.push('  %item = call i64 @tb_bootstrap_int_array_get(ptr %array, i32 %outer.index)')
    lines.push('  %chunk = call ptr @edges_for_point(ptr %points, i64 %item)')
    lines.push('  %chunk.len = call i32 @tb_bootstrap_record_array_length_Edge(ptr %chunk)')
    lines.push('  br label %inner.cond')
    lines.push('inner.cond:')
    lines.push('  %inner.index = phi i32 [0, %outer.body], [%inner.next, %inner.step]')
    lines.push('  %keep.inner = icmp slt i32 %inner.index, %chunk.len')
    lines.push('  br i1 %keep.inner, label %inner.body, label %inner.done')
    lines.push('inner.body:')
    lines.push('  %chunk.item = call ptr @tb_bootstrap_record_array_get_Edge(ptr %chunk, i32 %inner.index)')
    lines.push('  %chunk.copy = call ptr @tb_bootstrap_record_clone_Edge(ptr %chunk.item)')
    lines.push('  %push.len = call i32 @tb_bootstrap_record_array_push_Edge(ptr %result, ptr %chunk.copy, i1 true)')
    lines.push('  br label %inner.step')
    lines.push('inner.step:')
    lines.push('  %inner.next = add i32 %inner.index, 1')
    lines.push('  br label %inner.cond')
    lines.push('inner.done:')
    lines.push('  call void @tb_bootstrap_record_array_free_Edge(ptr %chunk)')
    lines.push('  br label %outer.step')
    lines.push('outer.step:')
    lines.push('  %outer.next = add i32 %outer.index, 1')
    lines.push('  br label %outer.cond')
    lines.push('done:')
    lines.push('  ret ptr %result')
    lines.push('}')
    return lines

string emit_int_array_array_value_instruction(ParsedFunction function_ir, LinearInstruction op):
    string lhs = temp_ref(op.lhs)
    string[] lines = ['  ' + lhs + ' = call ptr @tb_bootstrap_int_array_array_new(i32 ' + op.args.length() + ')']
    int index = 0
    while (index < op.args.length()):
        string item_name = op.args[index]
        string stored_value = temp_ref(item_name)
        string owned_flag = 'false'
        string item_type = normalize_llvm_type_name(lookup_temp_llvm_type(function_ir, item_name))
        if (item_type == '[]'):
            string empty_name = '%int_array_array.item.' + op.lhs + '.' + index
            lines.push('  ' + empty_name + ' = call ptr @tb_bootstrap_int_array_new(i32 0)')
            stored_value = empty_name
            owned_flag = 'true'
        else if (temp_is_int_array(function_ir, item_name)):
            if (temp_needs_backend_free(function_ir, item_name)):
                owned_flag = 'true'
            else:
                string clone_name = '%int_array.clone.' + op.lhs + '.' + index
                lines.push('  ' + clone_name + ' = call ptr @tb_bootstrap_int_array_clone(ptr ' + temp_ref(item_name) + ')')
                stored_value = clone_name
                owned_flag = 'true'
        lines.push('  call void @tb_bootstrap_int_array_array_set_owned(ptr ' + lhs + ', i32 ' + index + ', ptr ' + stored_value + ', i1 ' + owned_flag + ')')
        index += 1
    return join_llvm_strings(lines, '\n')

string emit_record_array_value_instruction(ProgramIR program, ParsedFunction function_ir, LinearInstruction op):
    string array_type = normalize_llvm_type_name(lookup_temp_llvm_type(function_ir, op.lhs))
    string record_name = record_name_from_type(array_item_type(array_type))
    string lhs = temp_ref(op.lhs)
    string[] lines = ['  ' + lhs + ' = call ptr @tb_bootstrap_record_array_new_' + record_name + '(i32 ' + op.args.length() + ')']
    int index = 0
    while (index < op.args.length()):
        string item_name = op.args[index]
        string stored_value = temp_ref(item_name)
        if (temp_is_record(function_ir, item_name) && !temp_needs_backend_free(function_ir, item_name)):
            string item_suffix = record_name + '.array.' + op.lhs + '.' + item_name
            for (string line in emit_record_materialize_if_needed(program, function_ir, item_name, item_suffix)):
                lines.push(line)
            stored_value = emit_record_owned_value(function_ir, item_name, item_suffix)
        lines.push('  call void @tb_bootstrap_record_array_set_owned_' + record_name + '(ptr ' + lhs + ', i32 ' + index + ', ptr ' + stored_value + ', i1 true)')
        index += 1
    return join_llvm_strings(lines, '\n')

string emit_map_value_instruction(ProgramIR program, ParsedFunction function_ir, LinearInstruction op):
    string map_type = normalize_llvm_type_name(op.result_type)
    string key_type = normalize_llvm_type_name(map_key_type(map_type))
    string value_type = normalize_llvm_type_name(map_value_type(map_type))
    string lhs = temp_ref(op.lhs)
    string[] lines = ['  ' + lhs + ' = call ptr ' + llvm_map_new_name(map_type) + '(i32 ' + (op.args.length() / 2).to_string() + ')']
    int index = 0
    int item_index = 0
    while (index + 1 < op.args.length()):
        string key_name = op.args[index]
        string value_name = op.args[index + 1]
        string stored_key = temp_ref(key_name)
        string stored_value = temp_ref(value_name)
        string stored_owned = 'false'
        string key_suffix = op.lhs + '.key.' + item_index
        string value_suffix = op.lhs + '.value.' + item_index
        if (key_type == 'string'):
            for (string line in emit_string_materialize_if_needed(function_ir, key_name, key_suffix)):
                lines.push(line)
            if (temp_is_string(function_ir, key_name) && !temp_needs_backend_free(function_ir, key_name)):
                stored_key = emit_string_owned_value(function_ir, key_name, key_suffix)
        if (value_type == 'string'):
            for (string line in emit_string_materialize_if_needed(function_ir, value_name, value_suffix)):
                lines.push(line)
            if (temp_is_string(function_ir, value_name) && !temp_needs_backend_free(function_ir, value_name)):
                stored_value = emit_string_owned_value(function_ir, value_name, value_suffix)
            stored_owned = 'true'
        else if (value_type == 'string[]'):
            for (string line in emit_string_array_materialize_if_needed(function_ir, value_name, value_suffix)):
                lines.push(line)
            if (temp_is_string_array(function_ir, value_name) && !temp_needs_backend_free(function_ir, value_name)):
                stored_value = emit_string_array_owned_value(function_ir, value_name, value_suffix)
            stored_owned = 'true'
        else if (value_type.starts_with('map<')):
            for (string line in emit_map_materialize_if_needed(function_ir, value_name, value_suffix)):
                lines.push(line)
            if (temp_is_map(function_ir, value_name) && !temp_needs_backend_free(function_ir, value_name)):
                stored_value = emit_map_owned_value(function_ir, value_name, value_suffix)
            stored_owned = 'true'
        else if (record_name_from_type(value_type) != ''):
            for (string line in emit_record_materialize_if_needed(program, function_ir, value_name, value_suffix)):
                lines.push(line)
            if (temp_is_record(function_ir, value_name) && !temp_needs_backend_free(function_ir, value_name)):
                stored_value = emit_record_owned_value(function_ir, value_name, value_suffix)
            stored_owned = 'true'
        if (key_type == 'int'):
            lines.push('  call void ' + llvm_map_set_name(map_type) + '(ptr ' + lhs + ', i32 ' + item_index + ', i64 ' + stored_key + ', ' + llvm_type(value_type) + ' ' + stored_value + ', i1 ' + stored_owned + ')')
        else:
            lines.push('  call void ' + llvm_map_set_name(map_type) + '(ptr ' + lhs + ', i32 ' + item_index + ', ptr ' + stored_key + ', ' + llvm_type(value_type) + ' ' + stored_value + ', i1 ' + stored_owned + ')')
        index += 2
        item_index += 1
    return join_llvm_strings(lines, '\n')

string emit_record_value_instruction_core(ProgramIR program, ParsedFunction function_ir, LinearInstruction op):
    string record_name = op.args[0]
    RecordDeclIR record_decl = lookup_record_decl(program, record_name)
    if (record_decl.header == ''):
        throw 'unknown llvm record constructor: ' + record_name
    BindingIR[] fields = record_field_bindings(record_decl)
    if (fields.length() != op.args.length() - 1):
        throw 'record constructor arity mismatch: ' + record_name
    string lhs = temp_ref(op.lhs)
    string record_type = llvm_record_type_name(record_name)
    string[] lines = []
    if (LLVM_USER_CALL_STATS_ACTIVE != 0):
        LLVM_RECORD_CTOR_TOTAL += 1
        LLVM_RECORD_CTOR_FIELDS_TOTAL += fields.length()
    lines.push('  %' + op.lhs + '.size.ptr = getelementptr ' + record_type + ', ptr null, i32 1')
    lines.push('  %' + op.lhs + '.size = ptrtoint ptr %' + op.lhs + '.size.ptr to i64')
    lines.push('  ' + lhs + ' = call ptr @malloc(i64 %' + op.lhs + '.size)')
    int index = 0
    while (index < fields.length()):
        BindingIR field = fields[index]
        string arg_name = op.args[index + 1]
        string stored_value = temp_ref(arg_name)
        string field_owned_flag = '1'
        string field_type = normalize_llvm_type_name(field.type_name)
        LinearInstruction arg_op = lookup_temp_instruction(function_ir, arg_name)
        if (is_backend_managed_type(field.type_name) && LLVM_USER_CALL_STATS_ACTIVE != 0):
            LLVM_RECORD_CTOR_MANAGED_FIELDS_TOTAL += 1
        if (field_type == 'string'):
            if (LLVM_USER_CALL_STATS_ACTIVE != 0):
                LLVM_RECORD_CTOR_STRING_FIELDS += 1
                if (arg_op.detail == 'identifier'):
                    LLVM_RECORD_CTOR_STRING_FROM_IDENTIFIER += 1
                else if (arg_op.detail == 'call'):
                    LLVM_RECORD_CTOR_STRING_FROM_CALL += 1
                else if (arg_op.detail == 'method-call'):
                    LLVM_RECORD_CTOR_STRING_FROM_METHOD_CALL += 1
                else if (arg_op.detail == 'string'):
                    LLVM_RECORD_CTOR_STRING_FROM_STRING_LITERAL += 1
                else if (arg_op.detail == 'field'):
                    LLVM_RECORD_CTOR_STRING_FROM_FIELD += 1
                else:
                    LLVM_RECORD_CTOR_STRING_FROM_OTHER += 1
                if (temp_needs_backend_free(function_ir, arg_name)):
                    LLVM_RECORD_CTOR_STRING_BACKEND_FREE += 1
            string[] prefix = emit_string_materialize_if_needed(function_ir, arg_name, record_name + '.' + field.name + '.' + op.lhs)
            if (LLVM_USER_CALL_STATS_ACTIVE != 0):
                LLVM_RECORD_CTOR_PREFIX_LINES_TOTAL += prefix.length()
                LLVM_RECORD_CTOR_STRING_PREFIX_LINES += prefix.length()
                if (!prefix.is_empty()):
                    LLVM_RECORD_CTOR_STRING_MATERIALIZE_NONEMPTY += 1
            for (string line in prefix):
                lines.push(line)
            if (temp_is_string(function_ir, arg_name)):
                if (LLVM_USER_CALL_STATS_ACTIVE != 0):
                    LLVM_RECORD_CTOR_STRING_OWNED_VALUE_CALLS += 1
                stored_value = emit_string_owned_value(function_ir, arg_name, record_name + '.' + field.name + '.' + op.lhs)
        else if (field_type == 'string[]'):
            if (LLVM_USER_CALL_STATS_ACTIVE != 0):
                LLVM_RECORD_CTOR_STRING_ARRAY_FIELDS += 1
            string[] prefix = emit_string_array_materialize_if_needed(function_ir, arg_name, record_name + '.' + field.name + '.' + op.lhs)
            if (LLVM_USER_CALL_STATS_ACTIVE != 0):
                LLVM_RECORD_CTOR_PREFIX_LINES_TOTAL += prefix.length()
            for (string line in prefix):
                lines.push(line)
            if (temp_is_string_array(function_ir, arg_name)):
                stored_value = emit_string_array_owned_value(function_ir, arg_name, record_name + '.' + field.name + '.' + op.lhs)
        else if (field_type.starts_with('map<')):
            if (LLVM_USER_CALL_STATS_ACTIVE != 0):
                LLVM_RECORD_CTOR_MAP_FIELDS += 1
            string[] prefix = emit_map_materialize_if_needed(function_ir, arg_name, record_name + '.' + field.name + '.' + op.lhs)
            if (LLVM_USER_CALL_STATS_ACTIVE != 0):
                LLVM_RECORD_CTOR_PREFIX_LINES_TOTAL += prefix.length()
            for (string line in prefix):
                lines.push(line)
            if (temp_is_map(function_ir, arg_name)):
                stored_value = emit_map_owned_value(function_ir, arg_name, record_name + '.' + field.name + '.' + op.lhs)
        else if (record_name_from_type(field_type) != ''):
            if (LLVM_USER_CALL_STATS_ACTIVE != 0):
                LLVM_RECORD_CTOR_RECORD_FIELDS += 1
            string[] prefix = emit_record_materialize_if_needed(program, function_ir, arg_name, record_name + '.' + field.name + '.' + op.lhs)
            if (LLVM_USER_CALL_STATS_ACTIVE != 0):
                LLVM_RECORD_CTOR_PREFIX_LINES_TOTAL += prefix.length()
            for (string line in prefix):
                lines.push(line)
            if (temp_is_record(function_ir, arg_name)):
                stored_value = emit_record_owned_value(function_ir, arg_name, record_name + '.' + field.name + '.' + op.lhs)
        else if (field_type.ends_with('[]') && record_name_from_type(array_item_type(field_type)) != ''):
            if (LLVM_USER_CALL_STATS_ACTIVE != 0):
                LLVM_RECORD_CTOR_RECORD_ARRAY_FIELDS += 1
            string[] prefix = emit_record_array_materialize_if_needed(function_ir, arg_name, record_name + '.' + field.name + '.' + op.lhs)
            if (LLVM_USER_CALL_STATS_ACTIVE != 0):
                LLVM_RECORD_CTOR_PREFIX_LINES_TOTAL += prefix.length()
            for (string line in prefix):
                lines.push(line)
            if (temp_is_record_array(function_ir, arg_name)):
                stored_value = emit_record_array_owned_value(function_ir, arg_name, record_name + '.' + field.name + '.' + op.lhs)
        lines.push('  %' + op.lhs + '.field.' + index + ' = getelementptr inbounds ' + record_type + ', ptr ' + lhs + ', i32 0, i32 ' + index)
        lines.push('  store ' + llvm_type(field.type_name) + ' ' + stored_value + ', ptr %' + op.lhs + '.field.' + index)
        if (is_backend_managed_type(field.type_name)):
            int owned_index = llvm_record_owned_field_index(record_decl, field.name)
            lines.push('  %' + op.lhs + '.field.' + index + '.owned = getelementptr inbounds ' + record_type + ', ptr ' + lhs + ', i32 0, i32 ' + owned_index)
            lines.push('  store i8 ' + field_owned_flag + ', ptr %' + op.lhs + '.field.' + index + '.owned')
        index += 1
    return join_llvm_strings(lines, '\n')

string emit_record_value_instruction(ProgramIR program, ParsedFunction function_ir, LinearInstruction op):
    int start_ms = 0
    if (LLVM_BACKEND_PROFILE_ACTIVE != 0):
        start_ms = time_ms()
    string line = emit_record_value_instruction_core(program, function_ir, op)
    if (LLVM_BACKEND_PROFILE_ACTIVE != 0):
        LLVM_EMIT_RECORD_VALUE_MS += time_ms() - start_ms
        LLVM_EMIT_RECORD_VALUE_COUNT += 1
    return line

string emit_call_value_instruction_core(ProgramIR program, ParsedFunction function_ir, LinearInstruction op):
    string lhs = temp_ref(op.lhs)
    string call_name = op.args[0]
    string call_arg1_type = ''
    if (op.args.length() >= 2):
        call_arg1_type = normalize_llvm_type_name(lookup_temp_llvm_type(function_ir, op.args[1]))
    if (call_name == 'print'):
        if (op.args.length() != 2):
            throw 'unsupported llvm print arity'
        if (call_arg1_type == 'int'):
            return emit_tracked_builtin_call_line('  ' + lhs + ' = call i32 (ptr, ...) @printf(ptr @.fmt.int, i64 ' + temp_ref(op.args[1]) + ')')
        if (call_arg1_type == 'bool'):
            return emit_tracked_builtin_call_line('  ' + lhs + '.text = select i1 ' + temp_ref(op.args[1]) + ', ptr @.bool.true, ptr @.bool.false\n  ' + lhs + ' = call i32 @puts(ptr ' + temp_ref(op.lhs + '.text') + ')')
        if (call_arg1_type == 'num'):
            return emit_tracked_builtin_call_line('  ' + lhs + ' = call i32 @tb_bootstrap_num_print(%tb_bootstrap_num ' + temp_ref(op.args[1]) + ')')
        if (call_arg1_type == 'string'):
            return emit_tracked_builtin_call_line('  ' + lhs + ' = call i32 @puts(ptr ' + temp_ref(op.args[1]) + ')')
        if (call_arg1_type == 'string[]'):
            return emit_tracked_builtin_call_line('  ' + lhs + ' = call i32 @tb_bootstrap_print_string_array(ptr ' + temp_ref(op.args[1]) + ')')
        if (call_arg1_type == 'int[]'):
            return emit_tracked_builtin_call_line('  ' + lhs + ' = call i32 @tb_bootstrap_print_int_array(ptr ' + temp_ref(op.args[1]) + ')')
        if (call_arg1_type == 'set<int>'):
            return emit_tracked_builtin_call_line('  ' + lhs + ' = call i32 @tb_bootstrap_print_int_set(ptr ' + temp_ref(op.args[1]) + ')')
        throw 'unsupported llvm print arg type: ' + call_arg1_type
    if (call_name == 'read_lines'):
        if (op.args.length() != 2):
            throw 'unsupported llvm read_lines arity'
        return emit_tracked_builtin_call_line('  ' + lhs + ' = call ptr @tb_bootstrap_read_lines(ptr ' + temp_ref(op.args[1]) + ')')
    if (call_name == 'read_file'):
        if (op.args.length() != 2):
            throw 'unsupported llvm read_file arity'
        return emit_tracked_builtin_call_line('  ' + lhs + ' = call ptr @tb_bootstrap_read_file(ptr ' + temp_ref(op.args[1]) + ')')
    if (call_name == 'getenv'):
        if (op.args.length() != 2):
            throw 'unsupported llvm getenv arity'
        return emit_tracked_builtin_call_line('  ' + lhs + ' = call ptr @tb_bootstrap_getenv(ptr ' + temp_ref(op.args[1]) + ')')
    if (call_name == 'time_ms'):
        if (op.args.length() != 1):
            throw 'unsupported llvm time_ms arity'
        return emit_tracked_builtin_call_line('  ' + lhs + ' = call i64 @tb_bootstrap_time_ms()')
    if (call_name == 'has_flag'):
        if (op.args.length() != 3):
            throw 'unsupported llvm has_flag arity'
        return emit_tracked_builtin_call_line('  ' + lhs + ' = call i1 @tb_bootstrap_has_flag(ptr ' + temp_ref(op.args[1]) + ', ptr ' + temp_ref(op.args[2]) + ')')
    if (call_name == 'option_value'):
        if (op.args.length() != 3):
            throw 'unsupported llvm option_value arity'
        return emit_tracked_builtin_call_line('  ' + lhs + ' = call ptr @tb_bootstrap_option_value(ptr ' + temp_ref(op.args[1]) + ', ptr ' + temp_ref(op.args[2]) + ')')
    if (call_name == 'range'):
        if (op.args.length() == 2):
            return emit_tracked_builtin_call_line('  ' + lhs + ' = call ptr @tb_bootstrap_range(i64 0, i64 ' + temp_ref(op.args[1]) + ')')
        if (op.args.length() == 3):
            return emit_tracked_builtin_call_line('  ' + lhs + ' = call ptr @tb_bootstrap_range(i64 ' + temp_ref(op.args[1]) + ', i64 ' + temp_ref(op.args[2]) + ')')
        throw 'bootstrap range currently requires one or two integer arguments'
    if (call_name == 'to_set'):
        if (op.args.length() != 2):
            throw 'unsupported llvm to_set arity'
        return emit_tracked_builtin_call_line('  ' + lhs + ' = call ptr @tb_bootstrap_to_set_int_array(ptr ' + temp_ref(op.args[1]) + ')')
    string builtin_query_result = emit_builtin_query_call_value_instruction(function_ir, op, call_name, call_arg1_type)
    if (builtin_query_result != ''):
        return emit_tracked_builtin_call_line(builtin_query_result)
    if (call_name == 'open'):
        if (op.args.length() != 2):
            throw 'unsupported llvm open arity'
        return emit_tracked_builtin_call_line('  ' + lhs + ' = call ptr @tb_bootstrap_open_write(ptr ' + temp_ref(op.args[1]) + ')')
    if (call_name == 'close'):
        if (op.args.length() != 2):
            throw 'unsupported llvm close arity'
        return emit_tracked_builtin_call_line('  call void @tb_bootstrap_close_write(ptr ' + temp_ref(op.args[1]) + ')')
    if (call_name == 'to_int'):
        if (op.args.length() != 2):
            throw 'unsupported llvm to_int arity'
        return emit_tracked_builtin_call_line('  ' + lhs + ' = call i64 @tb_bootstrap_to_int(ptr ' + temp_ref(op.args[1]) + ')')
    if (call_name == 'to_string'):
        if (op.args.length() != 2):
            throw 'unsupported llvm to_string arity'
        if (call_arg1_type == 'int'):
            return emit_tracked_builtin_call_line('  ' + lhs + ' = call ptr @tb_bootstrap_int_to_string(i64 ' + temp_ref(op.args[1]) + ')')
        throw 'unsupported llvm to_string arg type: ' + call_arg1_type
    if (call_name == 'substring'):
        if (op.args.length() == 3):
            return emit_tracked_builtin_call_line('  ' + lhs + ' = call ptr @tb_bootstrap_substring_start(ptr ' + temp_ref(op.args[1]) + ', i64 ' + temp_ref(op.args[2]) + ')')
        if (op.args.length() == 4):
            return emit_tracked_builtin_call_line('  ' + lhs + ' = call ptr @tb_bootstrap_substring_range(ptr ' + temp_ref(op.args[1]) + ', i64 ' + temp_ref(op.args[2]) + ', i64 ' + temp_ref(op.args[3]) + ')')
        throw 'bootstrap substring currently requires one or two integer arguments'
    if (call_name == 'trim'):
        if (op.args.length() != 2):
            throw 'unsupported llvm trim arity'
        return emit_tracked_builtin_call_line('  ' + lhs + ' = call ptr @tb_bootstrap_trim(ptr ' + temp_ref(op.args[1]) + ')')
    if (call_name == 'trim_left'):
        if (op.args.length() != 2):
            throw 'unsupported llvm trim_left arity'
        return emit_tracked_builtin_call_line('  ' + lhs + ' = call ptr @tb_bootstrap_trim_left(ptr ' + temp_ref(op.args[1]) + ')')
    if (call_name == 'trim_right'):
        if (op.args.length() != 2):
            throw 'unsupported llvm trim_right arity'
        return emit_tracked_builtin_call_line('  ' + lhs + ' = call ptr @tb_bootstrap_trim_right(ptr ' + temp_ref(op.args[1]) + ')')
    if (call_name == 'split'):
        if (op.args.length() != 3):
            throw 'unsupported llvm split arity'
        LinearInstruction sep_op = lookup_temp_instruction(function_ir, op.args[2])
        if (sep_op.kind == 'value' && sep_op.detail == 'string'):
            if (sep_op.args[0].length() == 2 && sep_op.args[0][0] == '\'' && sep_op.args[0][1] == '\''):
                return emit_tracked_builtin_call_line('  ' + lhs + ' = call ptr @tb_bootstrap_split_chars(ptr ' + temp_ref(op.args[1]) + ')')
            if (sep_op.args[0].length() == 3):
                return emit_tracked_builtin_call_line('  ' + lhs + ' = call ptr @tb_bootstrap_split_char(ptr ' + temp_ref(op.args[1]) + ', i8 ' + single_char_string_literal_i8(sep_op.args[0]) + ')')
        return emit_tracked_builtin_call_line('  ' + lhs + ' = call ptr @tb_bootstrap_split_string(ptr ' + temp_ref(op.args[1]) + ', ptr ' + temp_ref(op.args[2]) + ')')
    if (call_name == 'split_lines'):
        if (op.args.length() != 2):
            throw 'unsupported llvm split_lines arity'
        return emit_tracked_builtin_call_line('  ' + lhs + ' = call ptr @tb_bootstrap_split_lines(ptr ' + temp_ref(op.args[1]) + ')')
    if (call_name == 'round'):
        if (op.args.length() != 3):
            throw 'unsupported llvm round arity'
        string[] lines = emit_num_materialize_if_needed(function_ir, op.args[1], op.lhs + '.round.left')
        lines.push('  ' + lhs + ' = call %tb_bootstrap_num @tb_bootstrap_num_round(%tb_bootstrap_num ' + emit_num_store_value(function_ir, op.args[1], op.lhs + '.round.left') + ', i64 ' + temp_ref(op.args[2]) + ')')
        return emit_tracked_builtin_call_line(join_llvm_strings(lines, '\n'))
    if (call_name == 'min' || call_name == 'max'):
        if (op.args.length() != 3):
            throw 'unsupported llvm ' + op.args[0] + ' arity'
        string left_type = normalize_llvm_type_name(lookup_temp_llvm_type(function_ir, op.args[1]))
        string right_type = normalize_llvm_type_name(lookup_temp_llvm_type(function_ir, op.args[2]))
        if (left_type == 'int' && right_type == 'int'):
            string cmp_name = temp_ref(op.lhs + '.cmp')
            string predicate = 'icmp slt i64 '
            if (call_name == 'max'):
                predicate = 'icmp sgt i64 '
            return emit_tracked_builtin_call_line('  ' + cmp_name + ' = ' + predicate + temp_ref(op.args[1]) + ', ' + temp_ref(op.args[2]) + '\n  ' + lhs + ' = select i1 ' + cmp_name + ', i64 ' + temp_ref(op.args[1]) + ', i64 ' + temp_ref(op.args[2]))
        if (left_type == 'num' && right_type == 'num'):
            string[] lines = emit_num_materialize_if_needed(function_ir, op.args[1], op.lhs + '.minmax.left')
            for (string line in emit_num_materialize_if_needed(function_ir, op.args[2], op.lhs + '.minmax.right')):
                lines.push(line)
            lines.push('  ' + lhs + '.cmp = call i64 @tb_bootstrap_num_cmp(%tb_bootstrap_num ' + emit_num_store_value(function_ir, op.args[1], op.lhs + '.minmax.left') + ', %tb_bootstrap_num ' + emit_num_store_value(function_ir, op.args[2], op.lhs + '.minmax.right') + ')')
            string pred = 'icmp slt i64 '
            if (call_name == 'max'):
                pred = 'icmp sgt i64 '
            lines.push('  ' + lhs + '.take_left = ' + pred + temp_ref(op.lhs + '.cmp') + ', 0')
            lines.push('  ' + lhs + ' = select i1 ' + temp_ref(op.lhs + '.take_left') + ', %tb_bootstrap_num ' + temp_ref(op.args[1]) + ', %tb_bootstrap_num ' + temp_ref(op.args[2]))
            return emit_tracked_builtin_call_line(join_llvm_strings(lines, '\n'))
        throw 'unsupported llvm ' + call_name + ' arg types: ' + left_type + ' ' + right_type
    if (call_name == 'sqrt'):
        if (op.args.length() != 2):
            throw 'unsupported llvm sqrt arity'
        string[] lines = emit_num_materialize_if_needed(function_ir, op.args[1], op.lhs + '.sqrt')
        lines.push('  ' + lhs + ' = call %tb_bootstrap_num @tb_bootstrap_num_sqrt(%tb_bootstrap_num ' + emit_num_store_value(function_ir, op.args[1], op.lhs + '.sqrt') + ')')
        return emit_tracked_builtin_call_line(join_llvm_strings(lines, '\n'))
    if (call_name == 'abs'):
        if (op.args.length() != 2):
            throw 'unsupported llvm abs arity'
        return emit_tracked_builtin_call_line('  ' + lhs + '.neg = sub i64 0, ' + temp_ref(op.args[1]) + '\n  ' + lhs + '.is_neg = icmp slt i64 ' + temp_ref(op.args[1]) + ', 0\n  ' + lhs + ' = select i1 ' + temp_ref(op.lhs + '.is_neg') + ', i64 ' + temp_ref(op.lhs + '.neg') + ', i64 ' + temp_ref(op.args[1]))
    if (call_name == 'popcount'):
        if (op.args.length() != 2):
            throw 'unsupported llvm popcount arity'
        return emit_tracked_builtin_call_line('  ' + lhs + ' = call i64 @llvm.ctpop.i64(i64 ' + temp_ref(op.args[1]) + ')')
    if (call_name == 'write_line'):
        if (op.args.length() != 3):
            throw 'unsupported llvm write_line arity'
        return emit_tracked_builtin_call_line('  call void @tb_bootstrap_write_line(ptr ' + temp_ref(op.args[1]) + ', ptr ' + temp_ref(op.args[2]) + ')')
    if (call_name == 'write_lines'):
        if (op.args.length() != 3):
            throw 'unsupported llvm write_lines arity'
        return emit_tracked_builtin_call_line('  call void @tb_bootstrap_write_lines(ptr ' + temp_ref(op.args[1]) + ', ptr ' + temp_ref(op.args[2]) + ')')
    if (call_name == 'dump_runtime_activity'):
        if (op.args.length() != 1):
            throw 'unsupported llvm dump_runtime_activity arity'
        return emit_tracked_builtin_call_line('  call void @tb_bootstrap_dump_runtime_activity()')
    int call_meta_index = lookup_call_meta_index(call_name)
    string result_type = lookup_call_meta_return_type(call_meta_index)
    string result_llvm_type = lookup_call_meta_return_llvm_type(call_meta_index)
    if (lookup_record_decl(program, call_name).header != ''):
        string record_line = emit_record_value_instruction(program, function_ir, op)
        if (LLVM_USER_CALL_STATS_ACTIVE != 0):
            LLVM_USER_CALL_RECORD_CTOR_EMITTED_BYTES += record_line.length()
        record_llvm_user_call_stats(op.args.length() - 1, 0, false, true, record_line.length())
        return record_line
    if (!is_backend_value_type(result_type)):
        throw 'unsupported llvm call result type: [' + result_type + '] call=' + call_name + ' lhs=' + op.lhs + ' fn=' + function_ir.header + ' meta=' + call_meta_index.to_string()
    if (result_llvm_type == ''):
        if (LLVM_USER_CALL_STATS_ACTIVE != 0):
            LLVM_USER_CALL_RESULT_LLVM_TYPE_CALLS += 1
        result_llvm_type = llvm_type(result_type)
    string args_text = ''
    if (LLVM_USER_CALL_STATS_ACTIVE != 0):
        LLVM_USER_CALL_GENERIC_TOTAL += 1
    int param_count = lookup_call_meta_param_count(call_meta_index)
    int index = 1
    while (index < op.args.length()):
        if (LLVM_USER_CALL_STATS_ACTIVE != 0):
            LLVM_USER_CALL_ARG_LOOP_ITERS += 1
        string arg_llvm_type = ''
        if (index - 1 < param_count):
            arg_llvm_type = lookup_call_meta_param_llvm_type(call_meta_index, index - 1)
            if (LLVM_USER_CALL_STATS_ACTIVE != 0):
                LLVM_USER_CALL_ARG_PARAM_TYPE_HITS += 1
        else:
            string arg_type = lookup_temp_llvm_type(function_ir, op.args[index])
            if (LLVM_USER_CALL_STATS_ACTIVE != 0):
                LLVM_USER_CALL_ARG_FALLBACK_LOOKUPS += 1
            require_backend_value_type(arg_type, 'call arg')
            if (LLVM_USER_CALL_STATS_ACTIVE != 0):
                LLVM_USER_CALL_ARG_LLVM_TYPE_CALLS += 1
            arg_llvm_type = llvm_type(arg_type)
        if (index > 1):
            if (LLVM_USER_CALL_STATS_ACTIVE != 0):
                LLVM_USER_CALL_SEPARATOR_APPENDS += 1
                LLVM_USER_CALL_SEPARATOR_BYTES += 2
            args_text += ', '
        if (LLVM_USER_CALL_STATS_ACTIVE != 0):
            LLVM_USER_CALL_TEMP_REF_CALLS += 1
            LLVM_USER_CALL_ARG_TEMP_REF_CALLS += 1
        string arg_fragment = arg_llvm_type + ' ' + temp_ref(op.args[index])
        if (LLVM_USER_CALL_STATS_ACTIVE != 0):
            LLVM_USER_CALL_ARG_FRAGMENT_BYTES += arg_fragment.length()
        args_text += arg_fragment
        index += 1
    if (result_llvm_type == 'void'):
        if (LLVM_USER_CALL_STATS_ACTIVE != 0):
            LLVM_USER_CALL_ARGS_TEXT_BYTES += args_text.length()
        string line = '  call void @' + call_name + '(' + args_text + ')'
        if (LLVM_USER_CALL_STATS_ACTIVE != 0):
            LLVM_USER_CALL_VOID_LINE_BYTES += line.length()
        record_llvm_user_call_stats(op.args.length() - 1, param_count, true, false, line.length())
        return line
    if (LLVM_USER_CALL_STATS_ACTIVE != 0):
        LLVM_USER_CALL_TEMP_REF_CALLS += 1
        LLVM_USER_CALL_NONVOID_LHS_TEMP_REF_CALLS += 1
        LLVM_USER_CALL_ARGS_TEXT_BYTES += args_text.length()
    string line = '  ' + lhs + ' = call ' + result_llvm_type + ' @' + call_name + '(' + args_text + ')'
    if (LLVM_USER_CALL_STATS_ACTIVE != 0):
        LLVM_USER_CALL_NONVOID_LINE_BYTES += line.length()
    record_llvm_user_call_stats(op.args.length() - 1, param_count, false, false, line.length())
    return line

string emit_call_value_instruction(ProgramIR program, ParsedFunction function_ir, LinearInstruction op):
    int start_ms = 0
    if (LLVM_BACKEND_PROFILE_ACTIVE != 0):
        start_ms = time_ms()
    string line = emit_call_value_instruction_core(program, function_ir, op)
    if (LLVM_BACKEND_PROFILE_ACTIVE != 0):
        LLVM_EMIT_CALL_VALUE_MS += time_ms() - start_ms
        LLVM_EMIT_CALL_VALUE_COUNT += 1
    return line

string emit_tracked_builtin_call_line(string line):
    if (LLVM_USER_CALL_STATS_ACTIVE != 0):
        LLVM_USER_CALL_BUILTIN_TOTAL += 1
        LLVM_USER_CALL_BUILTIN_EMITTED_BYTES += line.length()
    return line

string emit_string_method_call_value_instruction(ProgramIR program, ParsedFunction function_ir, LinearInstruction op, string method_name, string method_base_type):
    string lhs = temp_ref(op.lhs)
    if (method_name == 'length' && method_base_type == 'string'):
        return '  ' + lhs + ' = call i64 @strlen(ptr ' + temp_ref(op.args[1]) + ')'
    if (method_name == 'is_empty' && method_base_type == 'string'):
        return '  ' + lhs + '.len = call i64 @strlen(ptr ' + temp_ref(op.args[1]) + ')\n  ' + lhs + ' = icmp eq i64 ' + temp_ref(op.lhs + '.len') + ', 0'
    if (method_name == 'length' && method_base_type == 'string[]'):
        return '  ' + lhs + '.len32 = call i32 @tb_bootstrap_string_array_length(ptr ' + temp_ref(op.args[1]) + ')\n  ' + lhs + ' = sext i32 ' + temp_ref(op.lhs + '.len32') + ' to i64'
    if (method_name == 'is_empty' && method_base_type == 'string[]'):
        return '  ' + lhs + '.len32 = call i32 @tb_bootstrap_string_array_length(ptr ' + temp_ref(op.args[1]) + ')\n  ' + lhs + ' = icmp eq i32 ' + temp_ref(op.lhs + '.len32') + ', 0'
    if (method_name == 'join' && method_base_type == 'string[]'):
        if (op.args.length() != 3):
            throw 'unsupported llvm string[] join arity'
        return '  ' + lhs + ' = call ptr @tb_bootstrap_join_strings(ptr ' + temp_ref(op.args[1]) + ', ptr ' + temp_ref(op.args[2]) + ')'
    if (method_name == 'length' && method_base_type == 'string[][]'):
        return '  ' + lhs + '.len32 = call i32 @tb_bootstrap_string_array_array_length(ptr ' + temp_ref(op.args[1]) + ')\n  ' + lhs + ' = sext i32 ' + temp_ref(op.lhs + '.len32') + ' to i64'
    if (method_name == 'is_empty' && method_base_type == 'string[][]'):
        return '  ' + lhs + '.len32 = call i32 @tb_bootstrap_string_array_array_length(ptr ' + temp_ref(op.args[1]) + ')\n  ' + lhs + ' = icmp eq i32 ' + temp_ref(op.lhs + '.len32') + ', 0'
    if (method_name == 'push' && method_base_type == 'string[][]'):
        if (op.args.length() != 3):
            throw 'unsupported llvm string[][] push arity'
        string[] lines = emit_string_array_materialize_if_needed(function_ir, op.args[2], op.lhs + '.push')
        string stored_value = temp_ref(op.args[2])
        string owned_flag = 'false'
        if (temp_is_string_array(function_ir, op.args[2])):
            if (temp_needs_backend_free(function_ir, op.args[2])):
                owned_flag = 'true'
            else:
                stored_value = emit_string_array_owned_value(function_ir, op.args[2], op.lhs + '.push')
                owned_flag = 'true'
        lines.push('  ' + lhs + '.len32 = call i32 @tb_bootstrap_string_array_array_push(ptr ' + temp_ref(op.args[1]) + ', ptr ' + stored_value + ', i1 ' + owned_flag + ')')
        lines.push('  ' + lhs + ' = sext i32 ' + temp_ref(op.lhs + '.len32') + ' to i64')
        return join_llvm_strings(lines, '\n')
    if (method_name == 'push' && method_base_type == 'string[]'):
        if (op.args.length() != 3):
            throw 'unsupported llvm string[] push arity'
        string[] lines = emit_string_materialize_if_needed(function_ir, op.args[2], op.lhs + '.push')
        string stored_value = temp_ref(op.args[2])
        string owned_flag = 'false'
        if (temp_is_string(function_ir, op.args[2])):
            if (temp_needs_backend_free(function_ir, op.args[2])):
                owned_flag = 'true'
            else:
                stored_value = emit_string_owned_value(function_ir, op.args[2], op.lhs + '.push')
                owned_flag = 'true'
        lines.push('  ' + lhs + '.len32 = call i32 @tb_bootstrap_string_array_push(ptr ' + temp_ref(op.args[1]) + ', ptr ' + stored_value + ', i1 ' + owned_flag + ')')
        lines.push('  ' + lhs + ' = sext i32 ' + temp_ref(op.lhs + '.len32') + ' to i64')
        return join_llvm_strings(lines, '\n')
    if (method_name == 'trim'):
        return '  ' + lhs + ' = call ptr @tb_bootstrap_trim(ptr ' + temp_ref(op.args[1]) + ')'
    if (method_name == 'trim_left'):
        return '  ' + lhs + ' = call ptr @tb_bootstrap_trim_left(ptr ' + temp_ref(op.args[1]) + ')'
    if (method_name == 'trim_right'):
        return '  ' + lhs + ' = call ptr @tb_bootstrap_trim_right(ptr ' + temp_ref(op.args[1]) + ')'
    if (method_name == 'starts_with'):
        if (op.args.length() != 3):
            throw 'bootstrap starts_with currently requires one prefix argument'
        return '  ' + lhs + ' = call i1 @tb_bootstrap_starts_with(ptr ' + temp_ref(op.args[1]) + ', ptr ' + temp_ref(op.args[2]) + ')'
    if (method_name == 'ends_with'):
        if (op.args.length() != 3):
            throw 'bootstrap ends_with currently requires one suffix argument'
        return '  ' + lhs + ' = call i1 @tb_bootstrap_ends_with(ptr ' + temp_ref(op.args[1]) + ', ptr ' + temp_ref(op.args[2]) + ')'
    if (method_name == 'starts_with_at'):
        if (op.args.length() != 4):
            throw 'bootstrap starts_with_at currently requires prefix and index arguments'
        return '  ' + lhs + ' = call i1 @tb_bootstrap_starts_with_at(ptr ' + temp_ref(op.args[1]) + ', ptr ' + temp_ref(op.args[2]) + ', i64 ' + temp_ref(op.args[3]) + ')'
    if (method_name == 'is_alpha'):
        return '  ' + lhs + ' = call i1 @tb_bootstrap_string_is_alpha(ptr ' + temp_ref(op.args[1]) + ')'
    if (method_name == 'is_digit'):
        return '  ' + lhs + ' = call i1 @tb_bootstrap_string_is_digit(ptr ' + temp_ref(op.args[1]) + ')'
    if (method_name == 'is_alnum'):
        return '  ' + lhs + '.alpha = call i1 @tb_bootstrap_string_is_alpha(ptr ' + temp_ref(op.args[1]) + ')\n  ' + lhs + '.digit = call i1 @tb_bootstrap_string_is_digit(ptr ' + temp_ref(op.args[1]) + ')\n  ' + lhs + ' = or i1 ' + temp_ref(op.lhs + '.alpha') + ', ' + temp_ref(op.lhs + '.digit')
    if (method_name == 'is_space' || method_name == 'is_whitespace'):
        return '  ' + lhs + ' = call i1 @tb_bootstrap_string_is_space(ptr ' + temp_ref(op.args[1]) + ')'
    if (method_name == 'replace'):
        if (op.args.length() != 4):
            throw 'bootstrap replace currently requires old and new string arguments'
        return '  ' + lhs + ' = call ptr @tb_bootstrap_string_replace(ptr ' + temp_ref(op.args[1]) + ', ptr ' + temp_ref(op.args[2]) + ', ptr ' + temp_ref(op.args[3]) + ')'
    if (method_name == 'to_string' && method_base_type == 'int'):
        return '  ' + lhs + ' = call ptr @tb_bootstrap_int_to_string(i64 ' + temp_ref(op.args[1]) + ')'
    if (method_name == 'hash'):
        if (method_base_type == 'int'):
            return '  ' + lhs + '.text = call ptr @tb_bootstrap_int_to_string(i64 ' + temp_ref(op.args[1]) + ')\n  ' + lhs + ' = call i64 @tb_bootstrap_hash_string(ptr ' + temp_ref(op.lhs + '.text') + ')\n  call void @tb_release(ptr ' + temp_ref(op.lhs + '.text') + ')'
        if (method_base_type == 'string'):
            return '  ' + lhs + ' = call i64 @tb_bootstrap_hash_string(ptr ' + temp_ref(op.args[1]) + ')'
        if (method_base_type == 'num'):
            return '  ' + lhs + '.text = call ptr @tb_bootstrap_num_to_string(%tb_bootstrap_num ' + temp_ref(op.args[1]) + ')\n  ' + lhs + ' = call i64 @tb_bootstrap_hash_string(ptr ' + temp_ref(op.lhs + '.text') + ')\n  call void @tb_release(ptr ' + temp_ref(op.lhs + '.text') + ')'
    if (method_name == 'to_int'):
        return '  ' + lhs + ' = call i64 @tb_bootstrap_to_int(ptr ' + temp_ref(op.args[1]) + ')'
    if (method_name == 'index_of' && method_base_type == 'string'):
        if (op.args.length() != 3):
            throw 'bootstrap index_of currently requires one needle argument'
        return '  ' + lhs + ' = call i64 @tb_bootstrap_string_index_of(ptr ' + temp_ref(op.args[1]) + ', ptr ' + temp_ref(op.args[2]) + ')'
    if (method_name == 'contains' && method_base_type == 'string'):
        if (op.args.length() != 3):
            throw 'bootstrap contains currently requires one needle argument'
        return '  ' + lhs + '.index = call i64 @tb_bootstrap_string_index_of(ptr ' + temp_ref(op.args[1]) + ', ptr ' + temp_ref(op.args[2]) + ')\n  ' + lhs + ' = icmp ne i64 ' + temp_ref(op.lhs + '.index') + ', -1'
    if (method_name == 'char_at' && method_base_type == 'string'):
        if (op.args.length() != 3):
            throw 'bootstrap char_at currently requires one index argument'
        return '  ' + lhs + ' = call ptr @tb_bootstrap_string_char_at(ptr ' + temp_ref(op.args[1]) + ', i64 ' + temp_ref(op.args[2]) + ')'
    if (method_name == 'substring' && method_base_type == 'string'):
        if (op.args.length() == 3):
            return '  ' + lhs + ' = call ptr @tb_bootstrap_substring_start(ptr ' + temp_ref(op.args[1]) + ', i64 ' + temp_ref(op.args[2]) + ')'
        if (op.args.length() == 4):
            return '  ' + lhs + ' = call ptr @tb_bootstrap_substring_range(ptr ' + temp_ref(op.args[1]) + ', i64 ' + temp_ref(op.args[2]) + ', i64 ' + temp_ref(op.args[3]) + ')'
        throw 'bootstrap substring currently requires one or two integer arguments'
    if (method_name == 'split' && method_base_type == 'string'):
        LinearInstruction sep_op = lookup_temp_instruction(function_ir, op.args[2])
        if (sep_op.kind == 'value' && sep_op.detail == 'string'):
            if (sep_op.args[0].length() == 2 && sep_op.args[0][0] == '\'' && sep_op.args[0][1] == '\''):
                return '  ' + lhs + ' = call ptr @tb_bootstrap_split_chars(ptr ' + temp_ref(op.args[1]) + ')'
            if (sep_op.args[0].length() == 3):
                return '  ' + lhs + ' = call ptr @tb_bootstrap_split_char(ptr ' + temp_ref(op.args[1]) + ', i8 ' + single_char_string_literal_i8(sep_op.args[0]) + ')'
        return '  ' + lhs + ' = call ptr @tb_bootstrap_split_string(ptr ' + temp_ref(op.args[1]) + ', ptr ' + temp_ref(op.args[2]) + ')'
    if (method_name == 'split_lines' && method_base_type == 'string'):
        return '  ' + lhs + ' = call ptr @tb_bootstrap_split_lines(ptr ' + temp_ref(op.args[1]) + ')'
    return ''

string emit_builtin_query_call_value_instruction(ParsedFunction function_ir, LinearInstruction op, string call_name, string call_arg1_type):
    string lhs = temp_ref(op.lhs)
    if (call_name == 'length'):
        if (op.args.length() != 2):
            throw 'unsupported llvm length arity'
        if (call_arg1_type == 'int[]'):
            return '  ' + lhs + '.len32 = call i32 @tb_bootstrap_int_array_length(ptr ' + temp_ref(op.args[1]) + ')\n  ' + lhs + ' = sext i32 ' + temp_ref(op.lhs + '.len32') + ' to i64'
        if (call_arg1_type == 'set<int>'):
            return '  ' + lhs + '.len32 = call i32 @tb_bootstrap_int_set_length(ptr ' + temp_ref(op.args[1]) + ')\n  ' + lhs + ' = sext i32 ' + temp_ref(op.lhs + '.len32') + ' to i64'
        if (call_arg1_type.ends_with('[]') && record_name_from_type(array_item_type(call_arg1_type)) != ''):
            string record_name = record_name_from_type(array_item_type(call_arg1_type))
            return '  ' + lhs + '.len32 = call i32 @tb_bootstrap_record_array_length_' + record_name + '(ptr ' + temp_ref(op.args[1]) + ')\n  ' + lhs + ' = sext i32 ' + temp_ref(op.lhs + '.len32') + ' to i64'
        return ''
    if (call_name == 'hash'):
        if (op.args.length() != 2):
            throw 'unsupported llvm hash arity'
        if (call_arg1_type == 'int'):
            return '  ' + lhs + '.text = call ptr @tb_bootstrap_int_to_string(i64 ' + temp_ref(op.args[1]) + ')\n  ' + lhs + ' = call i64 @tb_bootstrap_hash_string(ptr ' + temp_ref(op.lhs + '.text') + ')\n  call void @tb_release(ptr ' + temp_ref(op.lhs + '.text') + ')'
        if (call_arg1_type == 'string'):
            return '  ' + lhs + ' = call i64 @tb_bootstrap_hash_string(ptr ' + temp_ref(op.args[1]) + ')'
        throw 'unsupported llvm hash arg type: ' + call_arg1_type
    if (call_name == 'is_empty'):
        if (op.args.length() != 2):
            throw 'unsupported llvm is_empty arity'
        if (call_arg1_type == 'string'):
            return '  ' + lhs + '.len = call i64 @strlen(ptr ' + temp_ref(op.args[1]) + ')\n  ' + lhs + ' = icmp eq i64 ' + temp_ref(op.lhs + '.len') + ', 0'
        if (call_arg1_type == 'string[]'):
            return '  ' + lhs + '.len32 = call i32 @tb_bootstrap_string_array_length(ptr ' + temp_ref(op.args[1]) + ')\n  ' + lhs + ' = icmp eq i32 ' + temp_ref(op.lhs + '.len32') + ', 0'
        if (call_arg1_type == 'int[]'):
            return '  ' + lhs + '.len32 = call i32 @tb_bootstrap_int_array_length(ptr ' + temp_ref(op.args[1]) + ')\n  ' + lhs + ' = icmp eq i32 ' + temp_ref(op.lhs + '.len32') + ', 0'
        if (call_arg1_type == 'set<int>'):
            return '  ' + lhs + '.len32 = call i32 @tb_bootstrap_int_set_length(ptr ' + temp_ref(op.args[1]) + ')\n  ' + lhs + ' = icmp eq i32 ' + temp_ref(op.lhs + '.len32') + ', 0'
        if (call_arg1_type.ends_with('[]') && record_name_from_type(array_item_type(call_arg1_type)) != ''):
            string record_name = record_name_from_type(array_item_type(call_arg1_type))
            return '  ' + lhs + '.len32 = call i32 @tb_bootstrap_record_array_length_' + record_name + '(ptr ' + temp_ref(op.args[1]) + ')\n  ' + lhs + ' = icmp eq i32 ' + temp_ref(op.lhs + '.len32') + ', 0'
        if (call_arg1_type.starts_with('map<')):
            return '  ' + lhs + '.len32 = call i32 ' + llvm_map_length_name(call_arg1_type) + '(ptr ' + temp_ref(op.args[1]) + ')\n  ' + lhs + ' = icmp eq i32 ' + temp_ref(op.lhs + '.len32') + ', 0'
        return ''
    return ''

string emit_map_method_call_value_instruction(LinearInstruction op, string method_name, string method_base_type):
    if (!method_base_type.starts_with('map<')):
        return ''
    string lhs = temp_ref(op.lhs)
    if (method_name == 'length'):
        return '  ' + lhs + '.len32 = call i32 ' + llvm_map_length_name(method_base_type) + '(ptr ' + temp_ref(op.args[1]) + ')\n  ' + lhs + ' = sext i32 ' + temp_ref(op.lhs + '.len32') + ' to i64'
    if (method_name == 'is_empty'):
        return '  ' + lhs + '.len32 = call i32 ' + llvm_map_length_name(method_base_type) + '(ptr ' + temp_ref(op.args[1]) + ')\n  ' + lhs + ' = icmp eq i32 ' + temp_ref(op.lhs + '.len32') + ', 0'
    if (method_name == 'keys'):
        return '  ' + lhs + ' = call ptr ' + llvm_map_keys_name(method_base_type) + '(ptr ' + temp_ref(op.args[1]) + ')'
    if (method_name == 'values'):
        return '  ' + lhs + ' = call ptr ' + llvm_map_values_name(method_base_type) + '(ptr ' + temp_ref(op.args[1]) + ')'
    return ''

string emit_prio_q_method_call_value_instruction(ProgramIR program, ParsedFunction function_ir, LinearInstruction op, string method_name, string method_base_type):
    string lhs = temp_ref(op.lhs)
    if (method_base_type == 'prio_q<int>'):
        if (method_name == 'is_empty'):
            return '  ' + lhs + ' = call i1 @tb_bootstrap_prio_q_int_is_empty(ptr ' + temp_ref(op.args[1]) + ')'
        if (method_name == 'push'):
            if (op.args.length() != 3):
                throw 'unsupported llvm prio_q<int> push arity'
            return '  ' + lhs + '.len32 = call i32 @tb_bootstrap_prio_q_int_push(ptr ' + temp_ref(op.args[1]) + ', i64 ' + temp_ref(op.args[2]) + ')\n  ' + lhs + ' = sext i32 ' + temp_ref(op.lhs + '.len32') + ' to i64'
        if (method_name == 'pop'):
            if (op.args.length() != 2):
                throw 'unsupported llvm prio_q<int> pop arity'
            return '  ' + lhs + ' = call i64 @tb_bootstrap_prio_q_int_pop(ptr ' + temp_ref(op.args[1]) + ')'
    if (!method_base_type.starts_with('prio_q<')):
        return ''
    string record_name = record_name_from_type(prio_q_item_type(method_base_type))
    if (record_name == ''):
        return ''
    if (method_name == 'is_empty'):
        return '  ' + lhs + ' = call i1 @tb_bootstrap_prio_q_generic_' + record_name + '_is_empty(ptr ' + temp_ref(op.args[1]) + ')'
    if (method_name == 'push'):
        if (op.args.length() != 3):
            throw 'unsupported llvm prio_q<' + record_name + '> push arity'
        string[] lines = emit_record_materialize_if_needed(program, function_ir, op.args[2], record_name + '.push.' + op.lhs)
        string stored_value = temp_ref(op.args[2])
        string owned_flag = 'false'
        if (temp_is_record(function_ir, op.args[2])):
            if (temp_needs_backend_free(function_ir, op.args[2])):
                owned_flag = 'true'
            else:
                stored_value = emit_record_owned_value(function_ir, op.args[2], record_name + '.push.' + op.lhs)
                owned_flag = 'true'
        lines.push('  ' + lhs + '.len32 = call i32 @tb_bootstrap_prio_q_generic_' + record_name + '_push(ptr ' + temp_ref(op.args[1]) + ', ptr ' + stored_value + ', i1 ' + owned_flag + ')')
        lines.push('  ' + lhs + ' = sext i32 ' + temp_ref(op.lhs + '.len32') + ' to i64')
        return join_llvm_strings(lines, '\n')
    if (method_name == 'pop'):
        if (op.args.length() != 2):
            throw 'unsupported llvm prio_q<' + record_name + '> pop arity'
        return '  ' + lhs + ' = call ptr @tb_bootstrap_prio_q_generic_' + record_name + '_pop(ptr ' + temp_ref(op.args[1]) + ')'
    return ''

string emit_set_method_call_value_instruction(ProgramIR program, ParsedFunction function_ir, LinearInstruction op, string method_name, string method_base_type):
    string lhs = temp_ref(op.lhs)
    if (method_base_type == 'set<int>'):
        if (method_name == 'length'):
            return '  ' + lhs + '.len32 = call i32 @tb_bootstrap_int_set_length(ptr ' + temp_ref(op.args[1]) + ')\n  ' + lhs + ' = sext i32 ' + temp_ref(op.lhs + '.len32') + ' to i64'
        if (method_name == 'is_empty'):
            return '  ' + lhs + '.len32 = call i32 @tb_bootstrap_int_set_length(ptr ' + temp_ref(op.args[1]) + ')\n  ' + lhs + ' = icmp eq i32 ' + temp_ref(op.lhs + '.len32') + ', 0'
        if (method_name == 'add'):
            if (op.args.length() != 3):
                throw 'unsupported llvm set<int> add arity'
            return '  ' + lhs + '.len32 = call i32 @tb_bootstrap_int_set_add(ptr ' + temp_ref(op.args[1]) + ', i64 ' + temp_ref(op.args[2]) + ')\n  ' + lhs + ' = sext i32 ' + temp_ref(op.lhs + '.len32') + ' to i64'
        if (method_name == 'union'):
            if (op.args.length() != 3):
                throw 'unsupported llvm set<int> union arity'
            return '  ' + lhs + ' = call ptr @tb_bootstrap_int_set_union(ptr ' + temp_ref(op.args[1]) + ', ptr ' + temp_ref(op.args[2]) + ')'
        if (method_name == 'contains'):
            if (op.args.length() != 3):
                throw 'unsupported llvm set<int> contains arity'
            return '  ' + lhs + ' = call i1 @tb_bootstrap_int_set_contains(ptr ' + temp_ref(op.args[1]) + ', i64 ' + temp_ref(op.args[2]) + ')'
        return ''
    if (!method_base_type.starts_with('set<')):
        return ''
    string record_name = record_name_from_type(set_item_type(method_base_type))
    if (record_name == ''):
        return ''
    if (method_name == 'length'):
        return '  ' + lhs + '.len32 = call i32 @tb_bootstrap_record_set_length_' + record_name + '(ptr ' + temp_ref(op.args[1]) + ')\n  ' + lhs + ' = sext i32 ' + temp_ref(op.lhs + '.len32') + ' to i64'
    if (method_name == 'is_empty'):
        return '  ' + lhs + '.len32 = call i32 @tb_bootstrap_record_set_length_' + record_name + '(ptr ' + temp_ref(op.args[1]) + ')\n  ' + lhs + ' = icmp eq i32 ' + temp_ref(op.lhs + '.len32') + ', 0'
    if (method_name == 'add'):
        if (op.args.length() != 3):
            throw 'unsupported llvm record set add arity'
        string[] lines = emit_record_materialize_if_needed(program, function_ir, op.args[2], 'set.' + op.lhs)
        string stored_value = temp_ref(op.args[2])
        string owned_flag = 'false'
        if (temp_is_record(function_ir, op.args[2])):
            if (temp_needs_backend_free(function_ir, op.args[2])):
                owned_flag = 'true'
            else:
                stored_value = emit_record_owned_value(function_ir, op.args[2], 'set.' + op.lhs)
                owned_flag = 'true'
        lines.push('  ' + lhs + '.len32 = call i32 @tb_bootstrap_record_set_add_' + record_name + '(ptr ' + temp_ref(op.args[1]) + ', ptr ' + stored_value + ', i1 ' + owned_flag + ')')
        lines.push('  ' + lhs + ' = sext i32 ' + temp_ref(op.lhs + '.len32') + ' to i64')
        return join_llvm_strings(lines, '\n')
    if (method_name == 'contains'):
        if (op.args.length() != 3):
            throw 'unsupported llvm record set contains arity'
        string[] lines = emit_record_materialize_if_needed(program, function_ir, op.args[2], 'set.contains.' + op.lhs)
        string probe_value = temp_ref(op.args[2])
        if (temp_is_record(function_ir, op.args[2]) && !temp_needs_backend_free(function_ir, op.args[2])):
            probe_value = emit_record_owned_value(function_ir, op.args[2], 'set.contains.' + op.lhs)
        lines.push('  ' + lhs + ' = call i1 @tb_bootstrap_record_set_contains_' + record_name + '(ptr ' + temp_ref(op.args[1]) + ', ptr ' + probe_value + ')')
        return join_llvm_strings(lines, '\n')
    return ''

string emit_method_call_value_instruction_core(ProgramIR program, ParsedFunction function_ir, LinearInstruction op):
    string lhs = temp_ref(op.lhs)
    string method_name = op.args[0]
    string method_base_type = normalize_llvm_type_name(lookup_temp_llvm_type(function_ir, op.args[1]))
    string string_result = emit_string_method_call_value_instruction(program, function_ir, op, method_name, method_base_type)
    if (string_result != ''):
        return string_result
    string map_result = emit_map_method_call_value_instruction(op, method_name, method_base_type)
    if (map_result != ''):
        return map_result
    string prio_q_result = emit_prio_q_method_call_value_instruction(program, function_ir, op, method_name, method_base_type)
    if (prio_q_result != ''):
        return prio_q_result
    string set_result = emit_set_method_call_value_instruction(program, function_ir, op, method_name, method_base_type)
    if (set_result != ''):
        return set_result
    if (method_name == 'sort' && method_base_type == 'int[]'):
        if (op.args.length() != 3):
            throw 'unsupported llvm int[] sort arity'
        LinearInstruction comparator = lookup_temp_instruction(function_ir, op.args[2])
        if (comparator.kind == 'value' && comparator.detail == 'identifier' && comparator.args[0] == 'compare_desc'):
            return '  ' + lhs + ' = call ptr @tb_bootstrap_int_array_sort_desc(ptr ' + temp_ref(op.args[1]) + ')'
        if (comparator.kind == 'value' && comparator.detail == 'identifier'):
            register_named_int_sort_comparator(comparator.args[0])
            return '  ' + lhs + ' = call ptr @tb_bootstrap_int_array_sort_by(ptr ' + temp_ref(op.args[1]) + ', ptr ' + llvm_named_int_sort_comparator_symbol(comparator.args[0]) + ')'
        throw 'unsupported llvm int[] sort comparator'
    if (method_name == 'create_prio_q' && method_base_type == 'int[]'):
        if (op.args.length() != 3):
            throw 'unsupported llvm int[] create_prio_q arity'
        LinearInstruction comparator = lookup_temp_instruction(function_ir, op.args[2])
        if (comparator.kind == 'value' && comparator.detail == 'identifier' && comparator.args[0] == 'compare_desc'):
            return '  ' + lhs + ' = call ptr @tb_bootstrap_create_prio_q_int_by(ptr ' + temp_ref(op.args[1]) + ', ptr @tb_bootstrap_cmp_int_desc)'
        if (comparator.kind == 'value' && comparator.detail == 'identifier'):
            register_named_int_sort_comparator(comparator.args[0])
            return '  ' + lhs + ' = call ptr @tb_bootstrap_create_prio_q_int_by(ptr ' + temp_ref(op.args[1]) + ', ptr ' + llvm_named_int_sort_comparator_symbol(comparator.args[0]) + ')'
        throw 'unsupported llvm int[] create_prio_q comparator'
    if (method_name == 'sort' && method_base_type.ends_with('[]') && record_name_from_type(array_item_type(method_base_type)) != ''):
        if (op.args.length() != 3):
            throw 'unsupported llvm record[] sort arity'
        string record_name = record_name_from_type(array_item_type(method_base_type))
        LinearInstruction comparator = lookup_temp_instruction(function_ir, op.args[2])
        if (comparator.kind == 'value' && comparator.detail == 'identifier' && comparator.args[0] == 'compare_edges' && record_name == 'Edge'):
            return '  ' + lhs + ' = call ptr @tb_bootstrap_record_array_sort_Edge_compare_edges(ptr ' + temp_ref(op.args[1]) + ')'
        if (comparator.kind == 'value' && comparator.detail == 'identifier'):
            register_named_record_sort_comparator(record_name, comparator.args[0])
            return '  ' + lhs + ' = call ptr @tb_bootstrap_record_array_sort_by_' + record_name + '(ptr ' + temp_ref(op.args[1]) + ', ptr ' + llvm_named_record_sort_comparator_symbol(record_name, comparator.args[0]) + ')'
        throw 'unsupported llvm record[] sort comparator'
    if (method_name == 'create_prio_q' && method_base_type.ends_with('[]') && record_name_from_type(array_item_type(method_base_type)) != ''):
        if (op.args.length() != 3):
            throw 'unsupported llvm record[] create_prio_q arity'
        string record_name = record_name_from_type(array_item_type(method_base_type))
        LinearInstruction comparator = lookup_temp_instruction(function_ir, op.args[2])
        if (comparator.kind == 'value' && comparator.detail == 'identifier' && comparator.args[0] == 'compare_edges' && record_name == 'Edge'):
            return '  ' + lhs + ' = call ptr @tb_bootstrap_create_prio_q_generic_' + record_name + '_by(ptr ' + temp_ref(op.args[1]) + ', ptr @tb_bootstrap_cmp_record_pair_' + record_name + '_compare_edges)'
        if (comparator.kind == 'value' && comparator.detail == 'identifier'):
            register_named_record_sort_comparator(record_name, comparator.args[0])
            return '  ' + lhs + ' = call ptr @tb_bootstrap_create_prio_q_generic_' + record_name + '_by(ptr ' + temp_ref(op.args[1]) + ', ptr ' + llvm_named_record_sort_comparator_symbol(record_name, comparator.args[0]) + ')'
        throw 'unsupported llvm record[] create_prio_q comparator'
    if (method_name == 'length' && method_base_type == 'bool[]'):
        return '  ' + lhs + '.len32 = call i32 @tb_bootstrap_bool_array_length(ptr ' + temp_ref(op.args[1]) + ')\n  ' + lhs + ' = sext i32 ' + temp_ref(op.lhs + '.len32') + ' to i64'
    if (method_name == 'is_empty' && method_base_type == 'bool[]'):
        return '  ' + lhs + '.len32 = call i32 @tb_bootstrap_bool_array_length(ptr ' + temp_ref(op.args[1]) + ')\n  ' + lhs + ' = icmp eq i32 ' + temp_ref(op.lhs + '.len32') + ', 0'
    if (method_name == 'push' && method_base_type == 'bool[]'):
        if (op.args.length() != 3):
            throw 'unsupported llvm bool[] push arity'
        return '  ' + lhs + '.len32 = call i32 @tb_bootstrap_bool_array_push(ptr ' + temp_ref(op.args[1]) + ', i1 ' + temp_ref(op.args[2]) + ')\n  ' + lhs + ' = sext i32 ' + temp_ref(op.lhs + '.len32') + ' to i64'
    if (method_name == 'length' && method_base_type == 'int[]'):
        return '  ' + lhs + '.len32 = call i32 @tb_bootstrap_int_array_length(ptr ' + temp_ref(op.args[1]) + ')\n  ' + lhs + ' = sext i32 ' + temp_ref(op.lhs + '.len32') + ' to i64'
    if (method_name == 'is_empty' && method_base_type == 'int[]'):
        return '  ' + lhs + '.len32 = call i32 @tb_bootstrap_int_array_length(ptr ' + temp_ref(op.args[1]) + ')\n  ' + lhs + ' = icmp eq i32 ' + temp_ref(op.lhs + '.len32') + ', 0'
    if (method_name == 'push' && method_base_type == 'int[]'):
        if (op.args.length() != 3):
            throw 'unsupported llvm int[] push arity'
        return '  ' + lhs + '.len32 = call i32 @tb_bootstrap_int_array_push(ptr ' + temp_ref(op.args[1]) + ', i64 ' + temp_ref(op.args[2]) + ')\n  ' + lhs + ' = sext i32 ' + temp_ref(op.lhs + '.len32') + ' to i64'
    if (method_name == 'insert' && method_base_type == 'int[]'):
        if (op.args.length() != 4):
            throw 'unsupported llvm int[] insert arity'
        return '  ' + lhs + '.index32 = trunc i64 ' + temp_ref(op.args[2]) + ' to i32\n  ' + lhs + '.len32 = call i32 @tb_bootstrap_int_array_insert(ptr ' + temp_ref(op.args[1]) + ', i32 ' + temp_ref(op.lhs + '.index32') + ', i64 ' + temp_ref(op.args[3]) + ')\n  ' + lhs + ' = sext i32 ' + temp_ref(op.lhs + '.len32') + ' to i64'
    if (method_name == 'sum' && method_base_type == 'int[]'):
        if (op.args.length() != 2):
            throw 'unsupported llvm int[] sum arity'
        return '  ' + lhs + ' = call i64 @tb_bootstrap_int_array_sum(ptr ' + temp_ref(op.args[1]) + ')'
    if (method_name == 'pop' && method_base_type == 'int[]'):
        if (op.args.length() != 2):
            throw 'unsupported llvm int[] pop arity'
        return '  ' + lhs + ' = call i64 @tb_bootstrap_int_array_pop(ptr ' + temp_ref(op.args[1]) + ')'
    if (method_name == 'remove_at' && method_base_type == 'int[]'):
        if (op.args.length() != 3):
            throw 'unsupported llvm int[] remove_at arity'
        return '  ' + lhs + '.index32 = trunc i64 ' + temp_ref(op.args[2]) + ' to i32\n  ' + lhs + ' = call i64 @tb_bootstrap_int_array_remove_at(ptr ' + temp_ref(op.args[1]) + ', i32 ' + temp_ref(op.lhs + '.index32') + ')'
    if (method_name == 'clear' && method_base_type == 'int[]'):
        if (op.args.length() != 2):
            throw 'unsupported llvm int[] clear arity'
        return '  call void @tb_bootstrap_int_array_clear(ptr ' + temp_ref(op.args[1]) + ')'
    if (method_name == 'length' && method_base_type == 'int[][]'):
        return '  ' + lhs + '.len32 = call i32 @tb_bootstrap_int_array_array_length(ptr ' + temp_ref(op.args[1]) + ')\n  ' + lhs + ' = sext i32 ' + temp_ref(op.lhs + '.len32') + ' to i64'
    if (method_name == 'is_empty' && method_base_type == 'int[][]'):
        return '  ' + lhs + '.len32 = call i32 @tb_bootstrap_int_array_array_length(ptr ' + temp_ref(op.args[1]) + ')\n  ' + lhs + ' = icmp eq i32 ' + temp_ref(op.lhs + '.len32') + ', 0'
    if (method_name == 'push' && method_base_type == 'int[][]'):
        if (op.args.length() != 3):
            throw 'unsupported llvm int[][] push arity'
        string[] lines = emit_int_array_materialize_if_needed(function_ir, op.args[2], op.lhs + '.push')
        string stored_value = temp_ref(op.args[2])
        string owned_flag = 'false'
        if (temp_is_int_array(function_ir, op.args[2])):
            if (temp_needs_backend_free(function_ir, op.args[2])):
                owned_flag = 'true'
            else:
                stored_value = emit_int_array_owned_value(function_ir, op.args[2], op.lhs + '.push')
                owned_flag = 'true'
        lines.push('  ' + lhs + '.len32 = call i32 @tb_bootstrap_int_array_array_push(ptr ' + temp_ref(op.args[1]) + ', ptr ' + stored_value + ', i1 ' + owned_flag + ')')
        lines.push('  ' + lhs + ' = sext i32 ' + temp_ref(op.lhs + '.len32') + ' to i64')
        return join_llvm_strings(lines, '\n')
    if (method_name == 'length' && method_base_type.ends_with('[]') && record_name_from_type(array_item_type(method_base_type)) != ''):
        string record_name = record_name_from_type(array_item_type(method_base_type))
        return '  ' + lhs + '.len32 = call i32 @tb_bootstrap_record_array_length_' + record_name + '(ptr ' + temp_ref(op.args[1]) + ')\n  ' + lhs + ' = sext i32 ' + temp_ref(op.lhs + '.len32') + ' to i64'
    if (method_name == 'is_empty' && method_base_type.ends_with('[]') && record_name_from_type(array_item_type(method_base_type)) != ''):
        string record_name = record_name_from_type(array_item_type(method_base_type))
        return '  ' + lhs + '.len32 = call i32 @tb_bootstrap_record_array_length_' + record_name + '(ptr ' + temp_ref(op.args[1]) + ')\n  ' + lhs + ' = icmp eq i32 ' + temp_ref(op.lhs + '.len32') + ', 0'
    if (method_name == 'push' && method_base_type.ends_with('[]') && record_name_from_type(array_item_type(method_base_type)) != ''):
        if (op.args.length() != 3):
            throw 'unsupported llvm record[] push arity'
        string record_name = record_name_from_type(array_item_type(method_base_type))
        string[] lines = emit_record_materialize_if_needed(program, function_ir, op.args[2], record_name + '.push.' + op.lhs)
        string stored_value = temp_ref(op.args[2])
        string owned_flag = 'false'
        if (temp_is_record(function_ir, op.args[2])):
            if (temp_needs_backend_free(function_ir, op.args[2])):
                owned_flag = 'true'
            else:
                stored_value = emit_record_owned_value(function_ir, op.args[2], record_name + '.push.' + op.lhs)
                owned_flag = 'true'
        lines.push('  ' + lhs + '.len32 = call i32 @tb_bootstrap_record_array_push_' + record_name + '(ptr ' + temp_ref(op.args[1]) + ', ptr ' + stored_value + ', i1 ' + owned_flag + ')')
        lines.push('  ' + lhs + ' = sext i32 ' + temp_ref(op.lhs + '.len32') + ' to i64')
        return join_llvm_strings(lines, '\n')
    string result_type = lookup_temp_llvm_type(function_ir, op.lhs)
    require_backend_value_type(result_type, 'method-call result')
    string[] args = []
    int index = 1
    while (index < op.args.length()):
        string arg_type = lookup_temp_llvm_type(function_ir, op.args[index])
        require_backend_value_type(arg_type, 'method-call arg')
        args.push(llvm_type(arg_type) + ' ' + temp_ref(op.args[index]))
        index += 1
    if (normalize_llvm_type_name(result_type) == 'void'):
        return '  call void @' + op.args[0] + '(' + join_llvm_strings(args, ', ') + ')'
    return '  ' + lhs + ' = call ' + llvm_type(result_type) + ' @' + op.args[0] + '(' + join_llvm_strings(args, ', ') + ')'

string emit_method_call_value_instruction(ProgramIR program, ParsedFunction function_ir, LinearInstruction op):
    int start_ms = 0
    if (LLVM_BACKEND_PROFILE_ACTIVE != 0):
        start_ms = time_ms()
    string line = emit_method_call_value_instruction_core(program, function_ir, op)
    if (LLVM_BACKEND_PROFILE_ACTIVE != 0):
        LLVM_EMIT_METHOD_VALUE_MS += time_ms() - start_ms
        LLVM_EMIT_METHOD_VALUE_COUNT += 1
    return line

string emit_index_value_instruction(ParsedFunction function_ir, LinearInstruction op):
    string lhs = temp_ref(op.lhs)
    string base_type = normalize_llvm_type_name(lookup_temp_llvm_type(function_ir, op.args[0]))
    if (base_type == 'string'):
        return '  ' + lhs + ' = call ptr @tb_bootstrap_string_char_at(ptr ' + temp_ref(op.args[0]) + ', i64 ' + temp_ref(op.args[1]) + ')'
    if (base_type == 'string[]'):
        return '  ' + llvm_i32_index_temp(op.lhs) + ' = trunc i64 ' + temp_ref(op.args[1]) + ' to i32\n  ' + lhs + ' = call ptr @tb_bootstrap_string_array_get(ptr ' + temp_ref(op.args[0]) + ', i32 ' + llvm_i32_index_temp(op.lhs) + ')'
    if (base_type == 'string[][]'):
        return '  ' + llvm_i32_index_temp(op.lhs) + ' = trunc i64 ' + temp_ref(op.args[1]) + ' to i32\n  ' + lhs + ' = call ptr @tb_bootstrap_string_array_array_get(ptr ' + temp_ref(op.args[0]) + ', i32 ' + llvm_i32_index_temp(op.lhs) + ')'
    if (base_type == 'bool[]'):
        return '  ' + llvm_i32_index_temp(op.lhs) + ' = trunc i64 ' + temp_ref(op.args[1]) + ' to i32\n  ' + lhs + ' = call i1 @tb_bootstrap_bool_array_get(ptr ' + temp_ref(op.args[0]) + ', i32 ' + llvm_i32_index_temp(op.lhs) + ')'
    if (base_type == 'int[]'):
        return '  ' + llvm_i32_index_temp(op.lhs) + ' = trunc i64 ' + temp_ref(op.args[1]) + ' to i32\n  ' + lhs + ' = call i64 @tb_bootstrap_int_array_get(ptr ' + temp_ref(op.args[0]) + ', i32 ' + llvm_i32_index_temp(op.lhs) + ')'
    if (base_type == 'set<int>'):
        return '  ' + llvm_i32_index_temp(op.lhs) + ' = trunc i64 ' + temp_ref(op.args[1]) + ' to i32\n  ' + lhs + ' = call i64 @tb_bootstrap_int_set_get(ptr ' + temp_ref(op.args[0]) + ', i32 ' + llvm_i32_index_temp(op.lhs) + ')'
    if (base_type.starts_with('set<') && record_name_from_type(set_item_type(base_type)) != ''):
        string record_name = record_name_from_type(set_item_type(base_type))
        return '  ' + llvm_i32_index_temp(op.lhs) + ' = trunc i64 ' + temp_ref(op.args[1]) + ' to i32\n  ' + lhs + ' = call ptr @tb_bootstrap_record_set_get_' + record_name + '(ptr ' + temp_ref(op.args[0]) + ', i32 ' + llvm_i32_index_temp(op.lhs) + ')'
    if (base_type == 'int[][]'):
        return '  ' + llvm_i32_index_temp(op.lhs) + ' = trunc i64 ' + temp_ref(op.args[1]) + ' to i32\n  ' + lhs + ' = call ptr @tb_bootstrap_int_array_array_get(ptr ' + temp_ref(op.args[0]) + ', i32 ' + llvm_i32_index_temp(op.lhs) + ')'
    if (base_type.ends_with('[]') && record_name_from_type(array_item_type(base_type)) != ''):
        string record_name = record_name_from_type(array_item_type(base_type))
        return '  ' + llvm_i32_index_temp(op.lhs) + ' = trunc i64 ' + temp_ref(op.args[1]) + ' to i32\n  ' + lhs + ' = call ptr @tb_bootstrap_record_array_get_' + record_name + '(ptr ' + temp_ref(op.args[0]) + ', i32 ' + llvm_i32_index_temp(op.lhs) + ')'
    if (base_type.starts_with('map<')):
        if (normalize_llvm_type_name(map_key_type(base_type)) == 'int'):
            return '  ' + lhs + ' = call ' + llvm_type(map_value_type(base_type)) + ' ' + llvm_map_get_name(base_type) + '(ptr ' + temp_ref(op.args[0]) + ', i64 ' + temp_ref(op.args[1]) + ')'
        return '  ' + lhs + ' = call ' + llvm_type(map_value_type(base_type)) + ' ' + llvm_map_get_name(base_type) + '(ptr ' + temp_ref(op.args[0]) + ', ptr ' + temp_ref(op.args[1]) + ')'
    throw 'unsupported llvm index base type: ' + lookup_temp_llvm_type(function_ir, op.args[0])

string emit_slice_value_instruction(ParsedFunction function_ir, LinearInstruction op):
    string lhs = temp_ref(op.lhs)
    string base_type = normalize_llvm_type_name(lookup_temp_llvm_type(function_ir, op.args[0]))
    if (base_type == 'string'):
        if (op.args.length() == 2):
            return '  ' + lhs + ' = call ptr @tb_bootstrap_substring_start(ptr ' + temp_ref(op.args[0]) + ', i64 ' + temp_ref(op.args[1]) + ')'
        if (op.args.length() == 3):
            return '  ' + lhs + ' = call ptr @tb_bootstrap_substring_range(ptr ' + temp_ref(op.args[0]) + ', i64 ' + temp_ref(op.args[1]) + ', i64 ' + temp_ref(op.args[2]) + ')'
        throw 'unsupported llvm string slice arity'
    if (base_type == 'string[]'):
        if (op.args.length() == 2):
            return '  %slice_len32_' + op.lhs + ' = call i32 @tb_bootstrap_string_array_length(ptr ' + temp_ref(op.args[0]) + ')\n  %slice_len64_' + op.lhs + ' = sext i32 %slice_len32_' + op.lhs + ' to i64\n  ' + lhs + ' = call ptr @tb_bootstrap_string_array_slice(ptr ' + temp_ref(op.args[0]) + ', i64 ' + temp_ref(op.args[1]) + ', i64 %slice_len64_' + op.lhs + ')'
        if (op.args.length() == 3):
            return '  ' + lhs + ' = call ptr @tb_bootstrap_string_array_slice(ptr ' + temp_ref(op.args[0]) + ', i64 ' + temp_ref(op.args[1]) + ', i64 ' + temp_ref(op.args[2]) + ')'
        throw 'unsupported llvm string[] slice arity'
    if (base_type == 'int[]'):
        if (op.args.length() == 2):
            return '  %slice_len32_' + op.lhs + ' = call i32 @tb_bootstrap_int_array_length(ptr ' + temp_ref(op.args[0]) + ')\n  %slice_len64_' + op.lhs + ' = sext i32 %slice_len32_' + op.lhs + ' to i64\n  ' + lhs + ' = call ptr @tb_bootstrap_int_array_slice(ptr ' + temp_ref(op.args[0]) + ', i64 ' + temp_ref(op.args[1]) + ', i64 %slice_len64_' + op.lhs + ')'
        if (op.args.length() == 3):
            return '  ' + lhs + ' = call ptr @tb_bootstrap_int_array_slice(ptr ' + temp_ref(op.args[0]) + ', i64 ' + temp_ref(op.args[1]) + ', i64 ' + temp_ref(op.args[2]) + ')'
        throw 'unsupported llvm int[] slice arity'
    throw 'unsupported llvm slice base type: ' + lookup_temp_llvm_type(function_ir, op.args[0])

string emit_value_instruction(ProgramIR program, ParsedFunction function_ir, LinearInstruction op):
    string lhs = temp_ref(op.lhs)
    if (op.detail == 'int'):
        return '  ' + lhs + ' = add i64 0, ' + op.args[0]
    if (op.detail == 'num'):
        return '  ' + lhs + ' = call %tb_bootstrap_num @tb_bootstrap_num_make(i64 ' + num_literal_value_text(op.args[0]) + ', i64 ' + num_literal_scale(op.args[0]).to_string() + ')'
    if (op.detail == 'bool'):
        return '  ' + lhs + ' = or i1 false, ' + llvm_bool_literal(op.args[0])
    if (op.detail == 'string'):
        LLVM_FUNCTION_STRING_SYMBOL_VALUE_EMIT_CALLS += 1
        string symbol = lookup_function_string_literal_symbol(function_ir.name, op.args[0])
        if (symbol == ''):
            throw 'missing function string literal symbol for ' + function_ir.name
        return track_string_value('  ' + lhs + ' = getelementptr inbounds [' + tb_string_literal_data_length(op.args[0]) + ' x i8], ptr ' + string_symbol_ref(symbol) + ', i32 0, i32 0')
    if (op.detail == 'array'):
        string array_result_type = normalize_llvm_type_name(lookup_temp_llvm_type(function_ir, op.lhs))
        if (array_result_type == 'string[]'):
            return emit_string_array_value_instruction(function_ir, op)
        if (array_result_type == 'string[][]'):
            return emit_string_array_array_value_instruction(function_ir, op)
        if (array_result_type == 'bool[]'):
            return emit_bool_array_value_instruction(op)
        if (array_result_type == 'int[]'):
            return emit_int_array_value_instruction(op)
        if (array_result_type == 'int[][]'):
            return emit_int_array_array_value_instruction(function_ir, op)
        if (array_result_type.ends_with('[]') && record_name_from_type(array_item_type(array_result_type)) != ''):
            return emit_record_array_value_instruction(program, function_ir, op)
        throw 'unsupported llvm array result type: ' + op.result_type + ' inferred=' + array_result_type + ' lhs=' + op.lhs + ' fn=' + function_ir.header
    if (op.detail == 'set'):
        if (normalize_llvm_type_name(op.result_type) == 'set<int>'):
            return emit_int_set_value_instruction(op)
        if (normalize_llvm_type_name(op.result_type).starts_with('set<') && record_name_from_type(set_item_type(normalize_llvm_type_name(op.result_type))) != ''):
            return emit_record_set_value_instruction(program, function_ir, op)
        throw 'unsupported llvm set result type: ' + op.result_type
    if (op.detail == 'map'):
        if (normalize_llvm_type_name(op.result_type) == 'set<int>'):
            return emit_int_set_value_instruction(op)
        if (normalize_llvm_type_name(op.result_type).starts_with('set<') && record_name_from_type(set_item_type(normalize_llvm_type_name(op.result_type))) != ''):
            return emit_record_set_value_instruction(program, function_ir, op)
        if (normalize_llvm_type_name(op.result_type).starts_with('map<')):
            return emit_map_value_instruction(program, function_ir, op)
        throw 'unsupported llvm map result type: ' + op.result_type
    if (op.detail == 'identifier'):
        string identifier_type = normalize_llvm_type_name(op.result_type)
        if (enum_decl_exists(program, identifier_type)):
            return track_identifier_enum_value('  ; enum identifier ' + op.args[0])
        BindingIR binding = lookup_named_binding(function_ir, op.args[0])
        if (binding.name != ''):
            require_backend_value_type(identifier_type, 'identifier')
            return track_identifier_local_value('  ' + lhs + ' = load ' + llvm_type(identifier_type) + ', ptr ' + slot_ref(binding.name))
        BindingIR global_decl = lookup_named_global(program, op.args[0])
        if (global_decl.name == '' && function_name_exists(program, op.args[0])):
            return track_identifier_function_value('  ; function identifier ' + op.args[0])
        require_backend_value_type(identifier_type, 'identifier')
        return track_identifier_global_value('  ' + lhs + ' = load ' + llvm_type(identifier_type) + ', ptr ' + global_ref(global_decl.name))
    if (op.detail == 'unary'):
        string operand_type = lookup_temp_llvm_type(function_ir, op.args[1])
        if (op.args[0] == '-'):
            require_scalar_type(operand_type, 'unary')
            if (normalize_llvm_type_name(operand_type) == 'num'):
                string[] lines = emit_num_materialize_if_needed(function_ir, op.args[1], op.lhs + '.unary')
                lines.push('  ' + lhs + ' = call %tb_bootstrap_num @tb_bootstrap_num_neg(%tb_bootstrap_num ' + emit_num_store_value(function_ir, op.args[1], op.lhs + '.unary') + ')')
                return join_llvm_strings(lines, '\n')
            return '  ' + lhs + ' = sub ' + llvm_type(operand_type) + ' 0, ' + temp_ref(op.args[1])
        if (op.args[0] == '!' || op.args[0] == 'not'):
            return '  ' + lhs + ' = xor i1 ' + temp_ref(op.args[1]) + ', true'
        throw 'unsupported llvm unary op: ' + op.args[0]
    if (op.detail == 'binary'):
        string op_name = op.args[0]
        string left_type = lookup_temp_llvm_type(function_ir, op.args[1])
        string right_type = lookup_temp_llvm_type(function_ir, op.args[2])
        string left_type_normalized = normalize_llvm_type_name(left_type)
        string right_type_normalized = normalize_llvm_type_name(right_type)
        if (op_name == '+'):
            if (left_type_normalized == 'string' || right_type_normalized == 'string'):
                string left_ref = temp_ref(op.args[1])
                string right_ref = temp_ref(op.args[2])
                string left_value = left_ref
                string right_value = right_ref
                bool free_left = false
                bool free_right = false
                string emitted = ''
                if (left_type_normalized == 'int'):
                    left_value = '%string.left.' + op.lhs
                    emitted = '  ' + left_value + ' = call ptr @tb_bootstrap_int_to_string(i64 ' + left_ref + ')'
                    free_left = true
                else if (left_type_normalized != 'string'):
                    throw 'unsupported llvm string concat left type: ' + left_type
                if (right_type_normalized == 'int'):
                    right_value = '%string.right.' + op.lhs
                    if (emitted != ''):
                        emitted += '\n'
                    emitted += '  ' + right_value + ' = call ptr @tb_bootstrap_int_to_string(i64 ' + right_ref + ')'
                    free_right = true
                else if (right_type_normalized != 'string'):
                    throw 'unsupported llvm string concat right type: ' + right_type
                if (emitted != ''):
                    emitted += '\n'
                emitted += '  ' + lhs + ' = call ptr @tb_bootstrap_string_concat(ptr ' + left_value + ', ptr ' + right_value + ')'
                if (free_left):
                    emitted += '\n  call void @tb_release(ptr ' + left_value + ')'
                if (free_right):
                    emitted += '\n  call void @tb_release(ptr ' + right_value + ')'
                return emitted
            if (left_type_normalized == 'num' || right_type_normalized == 'num'):
                string[] lines = emit_num_materialize_if_needed(function_ir, op.args[1], op.lhs + '.left')
                string[] right_lines = emit_num_materialize_if_needed(function_ir, op.args[2], op.lhs + '.right')
                track_num_binary_lines(lines, right_lines, 1)
                for (string line in right_lines):
                    lines.push(line)
                lines.push('  ' + lhs + ' = call %tb_bootstrap_num @tb_bootstrap_num_add(%tb_bootstrap_num ' + emit_num_store_value(function_ir, op.args[1], op.lhs + '.left') + ', %tb_bootstrap_num ' + emit_num_store_value(function_ir, op.args[2], op.lhs + '.right') + ')')
                return join_llvm_strings(lines, '\n')
            return track_scalar_binary('  ' + lhs + ' = add i64 ' + temp_ref(op.args[1]) + ', ' + temp_ref(op.args[2]))
        if (op_name == '-'):
            if (left_type_normalized == 'num' || right_type_normalized == 'num'):
                string[] lines = emit_num_materialize_if_needed(function_ir, op.args[1], op.lhs + '.left')
                string[] right_lines = emit_num_materialize_if_needed(function_ir, op.args[2], op.lhs + '.right')
                track_num_binary_lines(lines, right_lines, 1)
                for (string line in right_lines):
                    lines.push(line)
                lines.push('  ' + lhs + ' = call %tb_bootstrap_num @tb_bootstrap_num_sub(%tb_bootstrap_num ' + emit_num_store_value(function_ir, op.args[1], op.lhs + '.left') + ', %tb_bootstrap_num ' + emit_num_store_value(function_ir, op.args[2], op.lhs + '.right') + ')')
                return join_llvm_strings(lines, '\n')
            return track_scalar_binary('  ' + lhs + ' = sub i64 ' + temp_ref(op.args[1]) + ', ' + temp_ref(op.args[2]))
        if (op_name == '*'):
            if (left_type_normalized == 'num' || right_type_normalized == 'num'):
                string[] lines = emit_num_materialize_if_needed(function_ir, op.args[1], op.lhs + '.left')
                string[] right_lines = emit_num_materialize_if_needed(function_ir, op.args[2], op.lhs + '.right')
                track_num_binary_lines(lines, right_lines, 1)
                for (string line in right_lines):
                    lines.push(line)
                lines.push('  ' + lhs + ' = call %tb_bootstrap_num @tb_bootstrap_num_mul(%tb_bootstrap_num ' + emit_num_store_value(function_ir, op.args[1], op.lhs + '.left') + ', %tb_bootstrap_num ' + emit_num_store_value(function_ir, op.args[2], op.lhs + '.right') + ')')
                return join_llvm_strings(lines, '\n')
            return track_scalar_binary('  ' + lhs + ' = mul i64 ' + temp_ref(op.args[1]) + ', ' + temp_ref(op.args[2]))
        if (op_name == '/'):
            if (left_type_normalized == 'num' || right_type_normalized == 'num'):
                string[] lines = emit_num_materialize_if_needed(function_ir, op.args[1], op.lhs + '.left')
                string[] right_lines = emit_num_materialize_if_needed(function_ir, op.args[2], op.lhs + '.right')
                track_num_binary_lines(lines, right_lines, 1)
                for (string line in right_lines):
                    lines.push(line)
                lines.push('  ' + lhs + ' = call %tb_bootstrap_num @tb_bootstrap_num_div(%tb_bootstrap_num ' + emit_num_store_value(function_ir, op.args[1], op.lhs + '.left') + ', %tb_bootstrap_num ' + emit_num_store_value(function_ir, op.args[2], op.lhs + '.right') + ')')
                return join_llvm_strings(lines, '\n')
            return track_scalar_binary('  ' + lhs + ' = sdiv i64 ' + temp_ref(op.args[1]) + ', ' + temp_ref(op.args[2]))
        if (op_name == '%'):
            return track_scalar_binary('  ' + lhs + ' = srem i64 ' + temp_ref(op.args[1]) + ', ' + temp_ref(op.args[2]))
        if (op_name == '&'):
            return track_scalar_binary('  ' + lhs + ' = and i64 ' + temp_ref(op.args[1]) + ', ' + temp_ref(op.args[2]))
        if (op_name == '|'):
            return track_scalar_binary('  ' + lhs + ' = or i64 ' + temp_ref(op.args[1]) + ', ' + temp_ref(op.args[2]))
        if (op_name == '^'):
            return track_scalar_binary('  ' + lhs + ' = xor i64 ' + temp_ref(op.args[1]) + ', ' + temp_ref(op.args[2]))
        if (op_name == '<<'):
            return track_scalar_binary('  ' + lhs + ' = shl i64 ' + temp_ref(op.args[1]) + ', ' + temp_ref(op.args[2]))
        if (op_name == '>>'):
            return track_scalar_binary('  ' + lhs + ' = ashr i64 ' + temp_ref(op.args[1]) + ', ' + temp_ref(op.args[2]))
        if (op_name == '=='):
            if (temp_is_string_like_value(function_ir, op.args[1]) && temp_is_string_like_value(function_ir, op.args[2])):
                return track_string_compare_binary('  ' + lhs + '.cmp = call i32 @strcmp(ptr ' + temp_ref(op.args[1]) + ', ptr ' + temp_ref(op.args[2]) + ')\n  ' + lhs + ' = icmp eq i32 ' + temp_ref(op.lhs + '.cmp') + ', 0')
            if (left_type_normalized == 'bool' && right_type_normalized == 'bool'):
                return track_scalar_binary('  ' + lhs + ' = icmp eq i1 ' + temp_ref(op.args[1]) + ', ' + temp_ref(op.args[2]))
            if (left_type_normalized == 'num' || right_type_normalized == 'num'):
                string[] lines = emit_num_materialize_if_needed(function_ir, op.args[1], op.lhs + '.left')
                string[] right_lines = emit_num_materialize_if_needed(function_ir, op.args[2], op.lhs + '.right')
                track_num_binary_lines(lines, right_lines, 2)
                for (string line in right_lines):
                    lines.push(line)
                lines.push('  ' + lhs + '.cmp = call i64 @tb_bootstrap_num_cmp(%tb_bootstrap_num ' + emit_num_store_value(function_ir, op.args[1], op.lhs + '.left') + ', %tb_bootstrap_num ' + emit_num_store_value(function_ir, op.args[2], op.lhs + '.right') + ')')
                lines.push('  ' + lhs + ' = icmp eq i64 ' + temp_ref(op.lhs + '.cmp') + ', 0')
                return join_llvm_strings(lines, '\n')
            return track_scalar_binary('  ' + lhs + ' = icmp eq i64 ' + temp_ref(op.args[1]) + ', ' + temp_ref(op.args[2]))
        if (op_name == '!='):
            if (temp_is_string_like_value(function_ir, op.args[1]) && temp_is_string_like_value(function_ir, op.args[2])):
                return track_string_compare_binary('  ' + lhs + '.cmp = call i32 @strcmp(ptr ' + temp_ref(op.args[1]) + ', ptr ' + temp_ref(op.args[2]) + ')\n  ' + lhs + ' = icmp ne i32 ' + temp_ref(op.lhs + '.cmp') + ', 0')
            if (left_type_normalized == 'bool' && right_type_normalized == 'bool'):
                return track_scalar_binary('  ' + lhs + ' = icmp ne i1 ' + temp_ref(op.args[1]) + ', ' + temp_ref(op.args[2]))
            if (left_type_normalized == 'num' || right_type_normalized == 'num'):
                string[] lines = emit_num_materialize_if_needed(function_ir, op.args[1], op.lhs + '.left')
                string[] right_lines = emit_num_materialize_if_needed(function_ir, op.args[2], op.lhs + '.right')
                track_num_binary_lines(lines, right_lines, 2)
                for (string line in right_lines):
                    lines.push(line)
                lines.push('  ' + lhs + '.cmp = call i64 @tb_bootstrap_num_cmp(%tb_bootstrap_num ' + emit_num_store_value(function_ir, op.args[1], op.lhs + '.left') + ', %tb_bootstrap_num ' + emit_num_store_value(function_ir, op.args[2], op.lhs + '.right') + ')')
                lines.push('  ' + lhs + ' = icmp ne i64 ' + temp_ref(op.lhs + '.cmp') + ', 0')
                return join_llvm_strings(lines, '\n')
            return track_scalar_binary('  ' + lhs + ' = icmp ne i64 ' + temp_ref(op.args[1]) + ', ' + temp_ref(op.args[2]))
        if (op_name == '<'):
            if (left_type_normalized == 'num' || right_type_normalized == 'num'):
                string[] lines = emit_num_materialize_if_needed(function_ir, op.args[1], op.lhs + '.left')
                string[] right_lines = emit_num_materialize_if_needed(function_ir, op.args[2], op.lhs + '.right')
                track_num_binary_lines(lines, right_lines, 2)
                for (string line in right_lines):
                    lines.push(line)
                lines.push('  ' + lhs + '.cmp = call i64 @tb_bootstrap_num_cmp(%tb_bootstrap_num ' + emit_num_store_value(function_ir, op.args[1], op.lhs + '.left') + ', %tb_bootstrap_num ' + emit_num_store_value(function_ir, op.args[2], op.lhs + '.right') + ')')
                lines.push('  ' + lhs + ' = icmp slt i64 ' + temp_ref(op.lhs + '.cmp') + ', 0')
                return join_llvm_strings(lines, '\n')
            return track_scalar_binary('  ' + lhs + ' = icmp slt i64 ' + temp_ref(op.args[1]) + ', ' + temp_ref(op.args[2]))
        if (op_name == '>'):
            if (left_type_normalized == 'num' || right_type_normalized == 'num'):
                string[] lines = emit_num_materialize_if_needed(function_ir, op.args[1], op.lhs + '.left')
                string[] right_lines = emit_num_materialize_if_needed(function_ir, op.args[2], op.lhs + '.right')
                track_num_binary_lines(lines, right_lines, 2)
                for (string line in right_lines):
                    lines.push(line)
                lines.push('  ' + lhs + '.cmp = call i64 @tb_bootstrap_num_cmp(%tb_bootstrap_num ' + emit_num_store_value(function_ir, op.args[1], op.lhs + '.left') + ', %tb_bootstrap_num ' + emit_num_store_value(function_ir, op.args[2], op.lhs + '.right') + ')')
                lines.push('  ' + lhs + ' = icmp sgt i64 ' + temp_ref(op.lhs + '.cmp') + ', 0')
                return join_llvm_strings(lines, '\n')
            return track_scalar_binary('  ' + lhs + ' = icmp sgt i64 ' + temp_ref(op.args[1]) + ', ' + temp_ref(op.args[2]))
        if (op_name == '<='):
            if (left_type_normalized == 'num' || right_type_normalized == 'num'):
                string[] lines = emit_num_materialize_if_needed(function_ir, op.args[1], op.lhs + '.left')
                string[] right_lines = emit_num_materialize_if_needed(function_ir, op.args[2], op.lhs + '.right')
                track_num_binary_lines(lines, right_lines, 2)
                for (string line in right_lines):
                    lines.push(line)
                lines.push('  ' + lhs + '.cmp = call i64 @tb_bootstrap_num_cmp(%tb_bootstrap_num ' + emit_num_store_value(function_ir, op.args[1], op.lhs + '.left') + ', %tb_bootstrap_num ' + emit_num_store_value(function_ir, op.args[2], op.lhs + '.right') + ')')
                lines.push('  ' + lhs + ' = icmp sle i64 ' + temp_ref(op.lhs + '.cmp') + ', 0')
                return join_llvm_strings(lines, '\n')
            return track_scalar_binary('  ' + lhs + ' = icmp sle i64 ' + temp_ref(op.args[1]) + ', ' + temp_ref(op.args[2]))
        if (op_name == '>='):
            if (left_type_normalized == 'num' || right_type_normalized == 'num'):
                string[] lines = emit_num_materialize_if_needed(function_ir, op.args[1], op.lhs + '.left')
                string[] right_lines = emit_num_materialize_if_needed(function_ir, op.args[2], op.lhs + '.right')
                track_num_binary_lines(lines, right_lines, 2)
                for (string line in right_lines):
                    lines.push(line)
                lines.push('  ' + lhs + '.cmp = call i64 @tb_bootstrap_num_cmp(%tb_bootstrap_num ' + emit_num_store_value(function_ir, op.args[1], op.lhs + '.left') + ', %tb_bootstrap_num ' + emit_num_store_value(function_ir, op.args[2], op.lhs + '.right') + ')')
                lines.push('  ' + lhs + ' = icmp sge i64 ' + temp_ref(op.lhs + '.cmp') + ', 0')
                return join_llvm_strings(lines, '\n')
            return track_scalar_binary('  ' + lhs + ' = icmp sge i64 ' + temp_ref(op.args[1]) + ', ' + temp_ref(op.args[2]))
        if (op_name == '&&' || op_name == 'and'):
            return track_scalar_binary('  ' + lhs + ' = and i1 ' + temp_ref(op.args[1]) + ', ' + temp_ref(op.args[2]))
        if (op_name == '||' || op_name == 'or'):
            return track_scalar_binary('  ' + lhs + ' = or i1 ' + temp_ref(op.args[1]) + ', ' + temp_ref(op.args[2]))
        if (op_name == 'in'):
            if (left_type_normalized == 'string' && right_type_normalized == 'string[]'):
                return '  ' + lhs + ' = call i1 @tb_bootstrap_string_array_contains(ptr ' + temp_ref(op.args[2]) + ', ptr ' + temp_ref(op.args[1]) + ')'
            if (left_type_normalized == 'bool' && right_type_normalized == 'bool[]'):
                return '  ' + lhs + ' = call i1 @tb_bootstrap_bool_array_contains(ptr ' + temp_ref(op.args[2]) + ', i1 ' + temp_ref(op.args[1]) + ')'
            if (left_type_normalized == 'int' && right_type_normalized == 'set<int>'):
                return '  ' + lhs + ' = call i1 @tb_bootstrap_int_set_contains(ptr ' + temp_ref(op.args[2]) + ', i64 ' + temp_ref(op.args[1]) + ')'
            if (left_type_normalized == 'int' && right_type_normalized == 'int[]'):
                return '  ' + lhs + ' = call i1 @tb_bootstrap_int_array_contains(ptr ' + temp_ref(op.args[2]) + ', i64 ' + temp_ref(op.args[1]) + ')'
            throw 'unsupported llvm in operand types: ' + left_type + ' in ' + right_type
        if (op_name == 'not in'):
            if (left_type_normalized == 'string' && right_type_normalized == 'string[]'):
                return '  ' + lhs + '.in = call i1 @tb_bootstrap_string_array_contains(ptr ' + temp_ref(op.args[2]) + ', ptr ' + temp_ref(op.args[1]) + ')\n  ' + lhs + ' = xor i1 ' + temp_ref(op.lhs + '.in') + ', true'
            if (left_type_normalized == 'bool' && right_type_normalized == 'bool[]'):
                return '  ' + lhs + '.in = call i1 @tb_bootstrap_bool_array_contains(ptr ' + temp_ref(op.args[2]) + ', i1 ' + temp_ref(op.args[1]) + ')\n  ' + lhs + ' = xor i1 ' + temp_ref(op.lhs + '.in') + ', true'
            if (left_type_normalized == 'int' && right_type_normalized == 'set<int>'):
                return '  ' + lhs + '.in = call i1 @tb_bootstrap_int_set_contains(ptr ' + temp_ref(op.args[2]) + ', i64 ' + temp_ref(op.args[1]) + ')\n  ' + lhs + ' = xor i1 ' + temp_ref(op.lhs + '.in') + ', true'
            if (left_type_normalized == 'int' && right_type_normalized == 'int[]'):
                return '  ' + lhs + '.in = call i1 @tb_bootstrap_int_array_contains(ptr ' + temp_ref(op.args[2]) + ', i64 ' + temp_ref(op.args[1]) + ')\n  ' + lhs + ' = xor i1 ' + temp_ref(op.lhs + '.in') + ', true'
            throw 'unsupported llvm not in operand types: ' + left_type + ' not in ' + right_type
        throw 'unsupported llvm binary op: ' + op_name
    if (op.detail == 'ternary'):
        string result_type = normalize_llvm_type_name(lookup_temp_llvm_type(function_ir, op.lhs))
        if (result_type == 'int'):
            return '  ' + lhs + ' = select i1 ' + temp_ref(op.args[0]) + ', i64 ' + temp_ref(op.args[1]) + ', i64 ' + temp_ref(op.args[2])
        if (result_type == 'bool'):
            return '  ' + lhs + ' = select i1 ' + temp_ref(op.args[0]) + ', i1 ' + temp_ref(op.args[1]) + ', i1 ' + temp_ref(op.args[2])
        if (result_type == 'string' || result_type == 'string[]' || result_type.starts_with('map<') || record_name_from_type(result_type) != ''):
            return '  ' + lhs + ' = select i1 ' + temp_ref(op.args[0]) + ', ptr ' + temp_ref(op.args[1]) + ', ptr ' + temp_ref(op.args[2])
        throw 'unsupported llvm ternary result type: ' + result_type
    if (op.detail == 'call'):
        return track_call_value(emit_call_value_instruction(program, function_ir, op))
    if (op.detail == 'field'):
        string base_type = normalize_llvm_type_name(lookup_temp_llvm_type(function_ir, op.args[1]))
        if (enum_decl_exists(program, base_type)):
            string symbol = enum_string_symbol(base_type, op.args[0])
            return track_field_value('  ' + lhs + ' = getelementptr inbounds [' + tb_string_literal_data_length('\'' + op.args[0] + '\'') + ' x i8], ptr ' + string_symbol_ref(symbol) + ', i32 0, i32 0')
        string record_name = record_name_from_type(base_type)
        RecordDeclIR record_decl = lookup_record_decl(program, record_name)
        if (record_decl.header == ''):
            throw 'unsupported llvm field base type: ' + base_type
        int field_index = record_field_index(record_decl, op.args[0])
        string field_type = normalize_llvm_type_name(op.result_type)
        require_backend_value_type(field_type, 'field')
        return track_field_value('  %' + op.lhs + '.field = getelementptr inbounds ' + llvm_record_type_name(record_name) + ', ptr ' + temp_ref(op.args[1]) + ', i32 0, i32 ' + field_index + '\n  ' + lhs + ' = load ' + llvm_type(field_type) + ', ptr %' + op.lhs + '.field')
    if (op.detail == 'method-call-lambda'):
        if (op.args.length() >= 2):
            if (op.args[0] == 'create_prio_q_int_desc'):
                return emit_prio_q_lambda_instruction(function_ir, op)
            if (op.args[0] == 'create_prio_q_record_field_desc'):
                return emit_prio_q_lambda_instruction(function_ir, op)
            if (op.args[0] == 'sort_int_asc' || op.args[0] == 'sort_int_desc' || op.args[0] == 'sort_record_field_asc'):
                return emit_sort_lambda_instruction(program, function_ir, op)
            if (op.args[0] == 'map_to_parse_point' || op.args[0] == 'map_to_string_length' || op.args[0] == 'map_to_edge_distance' || op.args[0] == 'flat_map_edges_for_point'):
                return emit_bootstrap_fixture_lambda_instruction(program, function_ir, op)
        if (op.args.length() >= 5):
            if (op.args[0] == 'map_to'):
                if (normalize_llvm_type_name(lookup_temp_llvm_type(function_ir, op.args[1])) == 'int[]'):
                    return emit_int_array_map_to_lambda_instruction(function_ir, op)
        if (op.args.length() >= 7):
            if (op.args[0] == 'filter_bounds'):
                return '  ' + lhs + ' = call ptr @tb_bootstrap_int_array_array_filter_bounds(ptr ' + temp_ref(op.args[1]) + ', i64 ' + temp_ref(op.args[3]) + ', i64 ' + temp_ref(op.args[4]) + ', i64 ' + temp_ref(op.args[5]) + ', i64 ' + temp_ref(op.args[6]) + ')'
            if (op.args[0] == 'sum_grid_eq'):
                return '  ' + lhs + ' = call i64 @tb_bootstrap_int_array_array_sum_grid_eq(ptr ' + temp_ref(op.args[1]) + ', ptr ' + temp_ref(op.args[3]) + ', i64 ' + temp_ref(op.args[4]) + ', i64 ' + temp_ref(op.args[5]) + ', ptr ' + temp_ref(op.args[6]) + ')'
        throw 'unsupported llvm method-call-lambda: ' + join_llvm_strings(op.args, ' ')
    if (op.detail == 'method-call'):
        string method_line = emit_method_call_value_instruction(program, function_ir, op)
        string method_base_type = normalize_llvm_type_name(lookup_temp_llvm_type(function_ir, op.args[1]))
        if (method_base_type == 'string' || method_base_type == 'string[]' || method_base_type == 'string[][]'):
            return track_string_method_value(method_line)
        return track_method_value(method_line)
    if (op.detail == 'index'):
        return emit_index_value_instruction(function_ir, op)
    if (op.detail == 'slice'):
        return emit_slice_value_instruction(function_ir, op)
    throw 'unsupported llvm value op: ' + op.detail + ' ' + join_llvm_strings(op.args, ' ')

string emit_set_instruction(ProgramIR program, ParsedFunction function_ir, LinearInstruction op, string temp_suffix):
    BindingIR binding = ir_parse_binding_decl(op.detail)
    require_backend_value_type(binding.type_name, 'set')
    if (normalize_llvm_type_name(binding.type_name) == 'num'):
        string[] lines = emit_num_materialize_if_needed(function_ir, op.args[0], binding.name + '.' + temp_suffix)
        lines.push('  store %tb_bootstrap_num ' + emit_num_store_value(function_ir, op.args[0], binding.name + '.' + temp_suffix) + ', ptr ' + slot_ref(binding.name))
        return join_llvm_strings(lines, '\n')
    if (normalize_llvm_type_name(binding.type_name) == 'string'):
        string[] lines = emit_string_materialize_if_needed(function_ir, op.args[0], binding.name + '.' + temp_suffix)
        string stored_value = temp_ref(op.args[0]).substring(0)
        string owned_flag = 'false'.substring(0)
        if (temp_is_string(function_ir, op.args[0])):
            if (temp_can_transfer_to_local(function_ir, op.args[0])):
                owned_flag = 'true'.substring(0)
            else:
                stored_value = emit_string_owned_value(function_ir, op.args[0], binding.name + '.' + temp_suffix)
                owned_flag = 'true'.substring(0)
        lines.push('  store ptr ' + stored_value + ', ptr ' + slot_ref(binding.name))
        lines.push('  store i1 ' + owned_flag + ', ptr ' + owned_slot_ref(binding.name))
        return join_llvm_strings(lines, '\n')
    if (normalize_llvm_type_name(binding.type_name) == 'string[]'):
        string[] lines = emit_string_array_materialize_if_needed(function_ir, op.args[0], binding.name + '.' + temp_suffix)
        string stored_value = temp_ref(op.args[0]).substring(0)
        string owned_flag = 'false'.substring(0)
        if (temp_is_string_array(function_ir, op.args[0])):
            if (temp_can_transfer_to_local(function_ir, op.args[0])):
                owned_flag = 'true'.substring(0)
            else:
                stored_value = emit_string_array_owned_value(function_ir, op.args[0], binding.name + '.' + temp_suffix)
                owned_flag = 'true'.substring(0)
        lines.push('  store ptr ' + stored_value + ', ptr ' + slot_ref(binding.name))
        lines.push('  store i1 ' + owned_flag + ', ptr ' + owned_slot_ref(binding.name))
        return join_llvm_strings(lines, '\n')
    if (normalize_llvm_type_name(binding.type_name) == 'int[][]'):
        string[] lines = emit_int_array_array_materialize_if_needed(function_ir, op.args[0], binding.name + '.' + temp_suffix)
        string stored_value = temp_ref(op.args[0]).substring(0)
        string owned_flag = 'false'.substring(0)
        if (temp_is_int_array_array(function_ir, op.args[0])):
            if (temp_can_transfer_to_local(function_ir, op.args[0])):
                owned_flag = 'true'.substring(0)
            else:
                stored_value = emit_int_array_array_owned_value(function_ir, op.args[0], binding.name + '.' + temp_suffix)
                owned_flag = 'true'.substring(0)
        lines.push('  store ptr ' + stored_value + ', ptr ' + slot_ref(binding.name))
        lines.push('  store i1 ' + owned_flag + ', ptr ' + owned_slot_ref(binding.name))
        return join_llvm_strings(lines, '\n')
    if (normalize_llvm_type_name(binding.type_name).starts_with('map<')):
        string[] lines = emit_map_materialize_if_needed(function_ir, op.args[0], binding.name + '.' + temp_suffix)
        string stored_value = temp_ref(op.args[0]).substring(0)
        string owned_flag = 'false'.substring(0)
        if (temp_is_map(function_ir, op.args[0])):
            if (temp_can_transfer_to_local(function_ir, op.args[0])):
                owned_flag = 'true'.substring(0)
            else:
                stored_value = emit_map_owned_value(function_ir, op.args[0], binding.name + '.' + temp_suffix)
                owned_flag = 'true'.substring(0)
        lines.push('  store ptr ' + stored_value + ', ptr ' + slot_ref(binding.name))
        lines.push('  store i1 ' + owned_flag + ', ptr ' + owned_slot_ref(binding.name))
        return join_llvm_strings(lines, '\n')
    if (record_name_from_type(normalize_llvm_type_name(binding.type_name)) != ''):
        string[] lines = emit_record_materialize_if_needed(program, function_ir, op.args[0], binding.name + '.' + temp_suffix)
        string stored_value = temp_ref(op.args[0]).substring(0)
        string owned_flag = 'false'.substring(0)
        if (temp_is_record(function_ir, op.args[0])):
            if (temp_can_transfer_to_local(function_ir, op.args[0])):
                owned_flag = 'true'.substring(0)
            else:
                stored_value = emit_record_owned_value(function_ir, op.args[0], binding.name + '.' + temp_suffix)
                owned_flag = 'true'.substring(0)
        lines.push('  store ptr ' + stored_value + ', ptr ' + slot_ref(binding.name))
        lines.push('  store i1 ' + owned_flag + ', ptr ' + owned_slot_ref(binding.name))
        return join_llvm_strings(lines, '\n')
    if (is_backend_managed_type(binding.type_name)):
        string[] lines = []
        string owned_flag = 'false'.substring(0)
        string source_binding = transferable_local_binding_name(function_ir, op.args[0])
        if (source_binding != '' && source_binding != binding.name):
            string source_owned = ('%move.owned.' + binding.name + '.' + temp_suffix).substring(0)
            lines.push('  ' + source_owned + ' = load i1, ptr ' + owned_slot_ref(source_binding))
            owned_flag = source_owned.substring(0)
        else if (temp_can_transfer_to_local(function_ir, op.args[0])):
            owned_flag = 'true'.substring(0)
        lines.push('  store ' + llvm_type(binding.type_name) + ' ' + temp_ref(op.args[0]) + ', ptr ' + slot_ref(binding.name))
        lines.push('  store i1 ' + owned_flag + ', ptr ' + owned_slot_ref(binding.name))
        if (source_binding != '' && source_binding != binding.name):
            lines.push('  store i1 false, ptr ' + owned_slot_ref(source_binding))
            lines.push('  store ptr null, ptr ' + slot_ref(source_binding))
        return join_llvm_strings(lines, '\n')
    string line = ('  store ' + llvm_type(binding.type_name) + ' ' + temp_ref(op.args[0]) + ', ptr ' + slot_ref(binding.name)).substring(0)
    return line

string emit_assign_local_instruction(ProgramIR program, ParsedFunction function_ir, LinearInstruction op, string temp_suffix):
    BindingIR binding = lookup_named_binding(function_ir, op.detail)
    if (binding.name == ''):
        BindingIR global_binding = lookup_named_global(program, op.detail)
        require_backend_value_type(global_binding.type_name, 'assign_global')
        if (normalize_llvm_type_name(global_binding.type_name) == 'num'):
            string[] lines = emit_num_materialize_if_needed(function_ir, op.args[0], global_binding.name + '.' + temp_suffix)
            lines.push('  store %tb_bootstrap_num ' + emit_num_store_value(function_ir, op.args[0], global_binding.name + '.' + temp_suffix) + ', ptr ' + global_ref(global_binding.name))
            return join_llvm_strings(lines, '\n')
        return '  store ' + llvm_type(global_binding.type_name) + ' ' + temp_ref(op.args[0]) + ', ptr ' + global_ref(global_binding.name)
    require_backend_value_type(binding.type_name, 'assign_local')
    if (normalize_llvm_type_name(binding.type_name) == 'num'):
        string[] lines = emit_num_materialize_if_needed(function_ir, op.args[0], binding.name + '.' + temp_suffix)
        lines.push('  store %tb_bootstrap_num ' + emit_num_store_value(function_ir, op.args[0], binding.name + '.' + temp_suffix) + ', ptr ' + slot_ref(binding.name))
        return join_llvm_strings(lines, '\n')
    if (normalize_llvm_type_name(binding.type_name) == 'string'):
        string[] lines = emit_string_materialize_if_needed(function_ir, op.args[0], binding.name + '.' + temp_suffix)
        string stored_value = temp_ref(op.args[0]).substring(0)
        string owned_flag = 'false'.substring(0)
        if (temp_is_string(function_ir, op.args[0])):
            if (temp_can_transfer_to_local(function_ir, op.args[0])):
                owned_flag = 'true'.substring(0)
            else:
                stored_value = emit_string_owned_value(function_ir, op.args[0], binding.name + '.' + temp_suffix)
                owned_flag = 'true'.substring(0)
        lines.push('  store ptr ' + stored_value + ', ptr ' + slot_ref(binding.name))
        lines.push('  store i1 ' + owned_flag + ', ptr ' + owned_slot_ref(binding.name))
        return join_llvm_strings(lines, '\n')
    if (normalize_llvm_type_name(binding.type_name) == 'string[]'):
        string[] lines = emit_string_array_materialize_if_needed(function_ir, op.args[0], binding.name + '.' + temp_suffix)
        string stored_value = temp_ref(op.args[0]).substring(0)
        string owned_flag = 'false'.substring(0)
        if (temp_is_string_array(function_ir, op.args[0])):
            if (temp_can_transfer_to_local(function_ir, op.args[0])):
                owned_flag = 'true'.substring(0)
            else:
                stored_value = emit_string_array_owned_value(function_ir, op.args[0], binding.name + '.' + temp_suffix)
                owned_flag = 'true'.substring(0)
        lines.push('  store ptr ' + stored_value + ', ptr ' + slot_ref(binding.name))
        lines.push('  store i1 ' + owned_flag + ', ptr ' + owned_slot_ref(binding.name))
        return join_llvm_strings(lines, '\n')
    if (normalize_llvm_type_name(binding.type_name) == 'int[][]'):
        string[] lines = emit_int_array_array_materialize_if_needed(function_ir, op.args[0], binding.name + '.' + temp_suffix)
        string stored_value = temp_ref(op.args[0]).substring(0)
        string owned_flag = 'false'.substring(0)
        if (temp_is_int_array_array(function_ir, op.args[0])):
            if (temp_can_transfer_to_local(function_ir, op.args[0])):
                owned_flag = 'true'.substring(0)
            else:
                stored_value = emit_int_array_array_owned_value(function_ir, op.args[0], binding.name + '.' + temp_suffix)
                owned_flag = 'true'.substring(0)
        lines.push('  store ptr ' + stored_value + ', ptr ' + slot_ref(binding.name))
        lines.push('  store i1 ' + owned_flag + ', ptr ' + owned_slot_ref(binding.name))
        return join_llvm_strings(lines, '\n')
    if (normalize_llvm_type_name(binding.type_name).starts_with('map<')):
        string[] lines = emit_map_materialize_if_needed(function_ir, op.args[0], binding.name + '.' + temp_suffix)
        string stored_value = temp_ref(op.args[0]).substring(0)
        string owned_flag = 'false'.substring(0)
        if (temp_is_map(function_ir, op.args[0])):
            if (temp_can_transfer_to_local(function_ir, op.args[0])):
                owned_flag = 'true'.substring(0)
            else:
                stored_value = emit_map_owned_value(function_ir, op.args[0], binding.name + '.' + temp_suffix)
                owned_flag = 'true'.substring(0)
        lines.push('  store ptr ' + stored_value + ', ptr ' + slot_ref(binding.name))
        lines.push('  store i1 ' + owned_flag + ', ptr ' + owned_slot_ref(binding.name))
        return join_llvm_strings(lines, '\n')
    if (record_name_from_type(normalize_llvm_type_name(binding.type_name)) != ''):
        string[] lines = emit_record_materialize_if_needed(program, function_ir, op.args[0], binding.name + '.' + temp_suffix)
        string stored_value = temp_ref(op.args[0]).substring(0)
        string owned_flag = 'false'.substring(0)
        if (temp_is_record(function_ir, op.args[0])):
            if (temp_can_transfer_to_local(function_ir, op.args[0])):
                owned_flag = 'true'.substring(0)
            else:
                stored_value = emit_record_owned_value(function_ir, op.args[0], binding.name + '.' + temp_suffix)
                owned_flag = 'true'.substring(0)
        lines.push('  store ptr ' + stored_value + ', ptr ' + slot_ref(binding.name))
        lines.push('  store i1 ' + owned_flag + ', ptr ' + owned_slot_ref(binding.name))
        return join_llvm_strings(lines, '\n')
    if (is_backend_managed_type(binding.type_name)):
        string[] lines = []
        string owned_flag = 'false'.substring(0)
        string source_binding = transferable_local_binding_name(function_ir, op.args[0])
        if (source_binding != '' && source_binding != binding.name):
            string source_owned = ('%move.owned.' + binding.name + '.' + temp_suffix).substring(0)
            lines.push('  ' + source_owned + ' = load i1, ptr ' + owned_slot_ref(source_binding))
            owned_flag = source_owned.substring(0)
        else if (temp_can_transfer_to_local(function_ir, op.args[0])):
            owned_flag = 'true'.substring(0)
        lines.push('  store ' + llvm_type(binding.type_name) + ' ' + temp_ref(op.args[0]) + ', ptr ' + slot_ref(binding.name))
        lines.push('  store i1 ' + owned_flag + ', ptr ' + owned_slot_ref(binding.name))
        if (source_binding != '' && source_binding != binding.name):
            lines.push('  store i1 false, ptr ' + owned_slot_ref(source_binding))
            lines.push('  store ptr null, ptr ' + slot_ref(source_binding))
        return join_llvm_strings(lines, '\n')
    string line = ('  store ' + llvm_type(binding.type_name) + ' ' + temp_ref(op.args[0]) + ', ptr ' + slot_ref(binding.name)).substring(0)
    return line

string emit_assign_field_instruction(ProgramIR program, ParsedFunction function_ir, LinearInstruction op, string temp_suffix):
    BindingIR field = record_field_binding_from_temp(program, function_ir, op.args[0], op.detail)
    require_backend_value_type(field.type_name, 'assign_field')
    string ptr_name = '%store.field.ptr.' + temp_suffix
    if (normalize_llvm_type_name(field.type_name) == 'string'):
        string[] lines = emit_string_materialize_if_needed(function_ir, op.args[1], op.detail + '.' + temp_suffix)
        string stored_value = temp_ref(op.args[1]).substring(0)
        string owned_flag = '0'.substring(0)
        if (temp_is_string(function_ir, op.args[1]) && !temp_needs_backend_free(function_ir, op.args[1])):
            stored_value = emit_string_owned_value(function_ir, op.args[1], op.detail + '.' + temp_suffix)
            owned_flag = '1'.substring(0)
        else if (temp_is_string(function_ir, op.args[1])):
            owned_flag = '1'.substring(0)
        lines.push(emit_record_field_ptr(program, function_ir, op.args[0], op.detail, ptr_name))
        lines.push('  store ptr ' + stored_value + ', ptr ' + ptr_name)
        lines.push(emit_record_owned_field_ptr(program, function_ir, op.args[0], op.detail, '%store.field.owned.ptr.' + temp_suffix))
        lines.push('  store i8 ' + owned_flag + ', ptr %store.field.owned.ptr.' + temp_suffix)
        return join_llvm_strings(lines, '\n')
    if (normalize_llvm_type_name(field.type_name) == 'string[]'):
        string[] lines = emit_string_array_materialize_if_needed(function_ir, op.args[1], op.detail + '.' + temp_suffix)
        string stored_value = temp_ref(op.args[1]).substring(0)
        string owned_flag = '0'.substring(0)
        if (temp_is_string_array(function_ir, op.args[1]) && !temp_needs_backend_free(function_ir, op.args[1])):
            stored_value = emit_string_array_owned_value(function_ir, op.args[1], op.detail + '.' + temp_suffix)
            owned_flag = '1'.substring(0)
        else if (temp_is_string_array(function_ir, op.args[1])):
            owned_flag = '1'.substring(0)
        lines.push(emit_record_field_ptr(program, function_ir, op.args[0], op.detail, ptr_name))
        lines.push('  store ptr ' + stored_value + ', ptr ' + ptr_name)
        lines.push(emit_record_owned_field_ptr(program, function_ir, op.args[0], op.detail, '%store.field.owned.ptr.' + temp_suffix))
        lines.push('  store i8 ' + owned_flag + ', ptr %store.field.owned.ptr.' + temp_suffix)
        return join_llvm_strings(lines, '\n')
    if (normalize_llvm_type_name(field.type_name).starts_with('map<')):
        string[] lines = emit_map_materialize_if_needed(function_ir, op.args[1], op.detail + '.' + temp_suffix)
        string stored_value = temp_ref(op.args[1]).substring(0)
        string owned_flag = '0'.substring(0)
        if (temp_is_map(function_ir, op.args[1]) && !temp_needs_backend_free(function_ir, op.args[1])):
            stored_value = emit_map_owned_value(function_ir, op.args[1], op.detail + '.' + temp_suffix)
            owned_flag = '1'.substring(0)
        else if (temp_is_map(function_ir, op.args[1])):
            owned_flag = '1'.substring(0)
        lines.push(emit_record_field_ptr(program, function_ir, op.args[0], op.detail, ptr_name))
        lines.push('  store ptr ' + stored_value + ', ptr ' + ptr_name)
        lines.push(emit_record_owned_field_ptr(program, function_ir, op.args[0], op.detail, '%store.field.owned.ptr.' + temp_suffix))
        lines.push('  store i8 ' + owned_flag + ', ptr %store.field.owned.ptr.' + temp_suffix)
        return join_llvm_strings(lines, '\n')
    if (record_name_from_type(normalize_llvm_type_name(field.type_name)) != ''):
        string[] lines = emit_record_materialize_if_needed(program, function_ir, op.args[1], op.detail + '.' + temp_suffix)
        string stored_value = temp_ref(op.args[1]).substring(0)
        string owned_flag = '0'.substring(0)
        if (temp_is_record(function_ir, op.args[1]) && !temp_needs_backend_free(function_ir, op.args[1])):
            stored_value = emit_record_owned_value(function_ir, op.args[1], op.detail + '.' + temp_suffix)
            owned_flag = '1'.substring(0)
        else if (temp_is_record(function_ir, op.args[1])):
            owned_flag = '1'.substring(0)
        lines.push(emit_record_field_ptr(program, function_ir, op.args[0], op.detail, ptr_name))
        lines.push('  store ptr ' + stored_value + ', ptr ' + ptr_name)
        lines.push(emit_record_owned_field_ptr(program, function_ir, op.args[0], op.detail, '%store.field.owned.ptr.' + temp_suffix))
        lines.push('  store i8 ' + owned_flag + ', ptr %store.field.owned.ptr.' + temp_suffix)
        return join_llvm_strings(lines, '\n')
    return emit_record_field_ptr(program, function_ir, op.args[0], op.detail, ptr_name) + '\n  store ' + llvm_type(field.type_name) + ' ' + temp_ref(op.args[1]) + ', ptr ' + ptr_name

string emit_release_index_instruction(ProgramIR program, ParsedFunction function_ir, LinearInstruction op, string temp_suffix):
    string base_type = normalize_llvm_type_name(lookup_temp_llvm_type(function_ir, op.args[0]))
    if (base_type == 'int[]'):
        return '  ; release_index ' + temp_ref(op.args[0]) + ' ' + temp_ref(op.args[1])
    if (base_type == 'string[]'):
        string index_name = llvm_i32_index_temp('release.' + temp_suffix)
        return '  ' + index_name + ' = trunc i64 ' + temp_ref(op.args[1]) + ' to i32\n  call void @tb_bootstrap_string_array_release_slot(ptr ' + temp_ref(op.args[0]) + ', i32 ' + index_name + ')'
    if (base_type == 'string[][]'):
        string index_name = llvm_i32_index_temp('release.' + temp_suffix)
        return '  ' + index_name + ' = trunc i64 ' + temp_ref(op.args[1]) + ' to i32\n  call void @tb_bootstrap_string_array_array_release_slot(ptr ' + temp_ref(op.args[0]) + ', i32 ' + index_name + ')'
    if (base_type == 'int[][]'):
        string index_name = llvm_i32_index_temp('release.' + temp_suffix)
        return '  ' + index_name + ' = trunc i64 ' + temp_ref(op.args[1]) + ' to i32\n  call void @tb_bootstrap_int_array_array_release_slot(ptr ' + temp_ref(op.args[0]) + ', i32 ' + index_name + ')'
    if (base_type.ends_with('[]') && record_name_from_type(array_item_type(base_type)) != ''):
        string index_name = llvm_i32_index_temp('release.' + temp_suffix)
        string record_name = record_name_from_type(array_item_type(base_type))
        return '  ' + index_name + ' = trunc i64 ' + temp_ref(op.args[1]) + ' to i32\n  call void @tb_bootstrap_record_array_release_slot_' + record_name + '(ptr ' + temp_ref(op.args[0]) + ', i32 ' + index_name + ')'
    if (base_type.starts_with('map<')):
        string value_type = normalize_llvm_type_name(map_value_type(base_type))
        if (!is_backend_managed_type(value_type)):
            return '  ; release_index ' + temp_ref(op.args[0]) + ' ' + temp_ref(op.args[1])
        if (normalize_llvm_type_name(map_key_type(base_type)) == 'int'):
            return '  call void ' + llvm_map_release_by_key_name(base_type) + '(ptr ' + temp_ref(op.args[0]) + ', i64 ' + temp_ref(op.args[1]) + ')'
        return '  call void ' + llvm_map_release_by_key_name(base_type) + '(ptr ' + temp_ref(op.args[0]) + ', ptr ' + temp_ref(op.args[1]) + ')'
    return '  ; release_index ' + temp_ref(op.args[0]) + ' ' + temp_ref(op.args[1])

string emit_assign_index_instruction(ProgramIR program, ParsedFunction function_ir, LinearInstruction op, string temp_suffix):
    string base_type = normalize_llvm_type_name(lookup_temp_llvm_type(function_ir, op.args[0]))
    if (base_type == 'bool[]'):
        string index_name = llvm_i32_index_temp('assign.' + temp_suffix)
        return '  ' + index_name + ' = trunc i64 ' + temp_ref(op.args[1]) + ' to i32\n  call void @tb_bootstrap_bool_array_set(ptr ' + temp_ref(op.args[0]) + ', i32 ' + index_name + ', i1 ' + temp_ref(op.args[2]) + ')'
    if (base_type == 'int[]'):
        string index_name = llvm_i32_index_temp('assign.' + temp_suffix)
        return '  ' + index_name + ' = trunc i64 ' + temp_ref(op.args[1]) + ' to i32\n  call void @tb_bootstrap_int_array_set(ptr ' + temp_ref(op.args[0]) + ', i32 ' + index_name + ', i64 ' + temp_ref(op.args[2]) + ')'
    if (base_type == 'string[]'):
        string[] lines = emit_string_materialize_if_needed(function_ir, op.args[2], 'index.' + temp_suffix)
        string stored_value = temp_ref(op.args[2]).substring(0)
        string owned_flag = 'false'.substring(0)
        string index_name = llvm_i32_index_temp('assign.' + temp_suffix)
        lines.push('  ' + index_name + ' = trunc i64 ' + temp_ref(op.args[1]) + ' to i32')
        if (temp_is_string(function_ir, op.args[2])):
            if (temp_needs_backend_free(function_ir, op.args[2])):
                owned_flag = 'true'.substring(0)
            else:
                stored_value = emit_string_owned_value(function_ir, op.args[2], 'index.' + temp_suffix)
                owned_flag = 'true'.substring(0)
        lines.push('  call void @tb_bootstrap_string_array_set_owned(ptr ' + temp_ref(op.args[0]) + ', i32 ' + index_name + ', ptr ' + stored_value + ', i1 ' + owned_flag + ')')
        return join_llvm_strings(lines, '\n')
    if (base_type == 'string[][]'):
        string[] lines = emit_string_array_materialize_if_needed(function_ir, op.args[2], 'index.' + temp_suffix)
        string stored_value = temp_ref(op.args[2]).substring(0)
        string owned_flag = 'false'.substring(0)
        string index_name = llvm_i32_index_temp('assign.' + temp_suffix)
        lines.push('  ' + index_name + ' = trunc i64 ' + temp_ref(op.args[1]) + ' to i32')
        if (temp_is_string_array(function_ir, op.args[2])):
            if (temp_needs_backend_free(function_ir, op.args[2])):
                owned_flag = 'true'.substring(0)
            else:
                stored_value = emit_string_array_owned_value(function_ir, op.args[2], 'index.' + temp_suffix)
                owned_flag = 'true'.substring(0)
        lines.push('  call void @tb_bootstrap_string_array_array_set_owned(ptr ' + temp_ref(op.args[0]) + ', i32 ' + index_name + ', ptr ' + stored_value + ', i1 ' + owned_flag + ')')
        return join_llvm_strings(lines, '\n')
    if (base_type == 'int[][]'):
        string[] lines = emit_int_array_materialize_if_needed(function_ir, op.args[2], 'index.' + temp_suffix)
        string stored_value = temp_ref(op.args[2]).substring(0)
        string owned_flag = 'false'.substring(0)
        string index_name = llvm_i32_index_temp('assign.' + temp_suffix)
        lines.push('  ' + index_name + ' = trunc i64 ' + temp_ref(op.args[1]) + ' to i32')
        if (temp_is_int_array(function_ir, op.args[2])):
            if (temp_needs_backend_free(function_ir, op.args[2])):
                owned_flag = 'true'.substring(0)
            else:
                stored_value = emit_int_array_owned_value(function_ir, op.args[2], 'index.' + temp_suffix)
                owned_flag = 'true'.substring(0)
        lines.push('  call void @tb_bootstrap_int_array_array_set_owned(ptr ' + temp_ref(op.args[0]) + ', i32 ' + index_name + ', ptr ' + stored_value + ', i1 ' + owned_flag + ')')
        return join_llvm_strings(lines, '\n')
    if (base_type.ends_with('[]') && record_name_from_type(array_item_type(base_type)) != ''):
        string record_name = record_name_from_type(array_item_type(base_type))
        string[] lines = emit_record_materialize_if_needed(program, function_ir, op.args[2], 'index.' + temp_suffix)
        string stored_value = temp_ref(op.args[2]).substring(0)
        string owned_flag = 'false'.substring(0)
        string index_name = llvm_i32_index_temp('assign.' + temp_suffix)
        lines.push('  ' + index_name + ' = trunc i64 ' + temp_ref(op.args[1]) + ' to i32')
        if (temp_is_record(function_ir, op.args[2])):
            if (temp_needs_backend_free(function_ir, op.args[2])):
                owned_flag = 'true'.substring(0)
            else:
                stored_value = emit_record_owned_value(function_ir, op.args[2], 'index.' + temp_suffix)
                owned_flag = 'true'.substring(0)
        lines.push('  call void @tb_bootstrap_record_array_set_owned_' + record_name + '(ptr ' + temp_ref(op.args[0]) + ', i32 ' + index_name + ', ptr ' + stored_value + ', i1 ' + owned_flag + ')')
        return join_llvm_strings(lines, '\n')
    if (base_type.starts_with('map<')):
        string value_type = normalize_llvm_type_name(map_value_type(base_type))
        string[] lines = []
        string stored_value = temp_ref(op.args[2]).substring(0)
        string stored_owned = 'false'.substring(0)
        if (value_type == 'string'):
            lines = emit_string_materialize_if_needed(function_ir, op.args[2], 'index.' + temp_suffix)
            if (temp_is_string(function_ir, op.args[2]) && !temp_needs_backend_free(function_ir, op.args[2])):
                stored_value = emit_string_owned_value(function_ir, op.args[2], 'index.' + temp_suffix)
            stored_owned = 'true'.substring(0)
        else if (value_type == 'string[]'):
            lines = emit_string_array_materialize_if_needed(function_ir, op.args[2], 'index.' + temp_suffix)
            if (temp_is_string_array(function_ir, op.args[2]) && !temp_needs_backend_free(function_ir, op.args[2])):
                stored_value = emit_string_array_owned_value(function_ir, op.args[2], 'index.' + temp_suffix)
            stored_owned = 'true'.substring(0)
        else if (value_type.starts_with('map<')):
            lines = emit_map_materialize_if_needed(function_ir, op.args[2], 'index.' + temp_suffix)
            if (temp_is_map(function_ir, op.args[2]) && !temp_needs_backend_free(function_ir, op.args[2])):
                stored_value = emit_map_owned_value(function_ir, op.args[2], 'index.' + temp_suffix)
            stored_owned = 'true'.substring(0)
        else if (record_name_from_type(value_type) != ''):
            lines = emit_record_materialize_if_needed(program, function_ir, op.args[2], 'index.' + temp_suffix)
            if (temp_is_record(function_ir, op.args[2]) && !temp_needs_backend_free(function_ir, op.args[2])):
                stored_value = emit_record_owned_value(function_ir, op.args[2], 'index.' + temp_suffix)
            stored_owned = 'true'
        if (normalize_llvm_type_name(map_key_type(base_type)) == 'int'):
            lines.push('  call void ' + llvm_map_set_by_key_name(base_type) + '(ptr ' + temp_ref(op.args[0]) + ', i64 ' + temp_ref(op.args[1]) + ', ' + llvm_type(value_type) + ' ' + stored_value + ', i1 ' + stored_owned + ')')
        else:
            lines.push('  call void ' + llvm_map_set_by_key_name(base_type) + '(ptr ' + temp_ref(op.args[0]) + ', ptr ' + temp_ref(op.args[1]) + ', ' + llvm_type(value_type) + ' ' + stored_value + ', i1 ' + stored_owned + ')')
        return join_llvm_strings(lines, '\n')
    return '  ; assign_index ' + temp_ref(op.args[0]) + ' ' + temp_ref(op.args[1]) + ' ' + temp_ref(op.args[2])

string emit_instruction(ProgramIR program, ParsedFunction function_ir, string block_label, LinearInstruction op, string temp_suffix):
    if (op.kind == 'value'):
        if (LLVM_BACKEND_PROFILE_ACTIVE != 0):
            int start_ms = time_ms()
            string line = emit_value_instruction(program, function_ir, op)
            int elapsed_ms = time_ms() - start_ms
            LLVM_EMIT_VALUE_MS += elapsed_ms
            LLVM_EMIT_VALUE_COUNT += 1
            if (op.detail == 'binary'):
                LLVM_EMIT_VALUE_BINARY_MS += elapsed_ms
                LLVM_EMIT_VALUE_BINARY_COUNT += 1
            else if (op.detail == 'call'):
                LLVM_EMIT_VALUE_CALL_MS += elapsed_ms
                LLVM_EMIT_VALUE_CALL_COUNT += 1
            else if (op.detail == 'method-call' || op.detail == 'method-call-lambda'):
                LLVM_EMIT_VALUE_METHOD_CALL_MS += elapsed_ms
                LLVM_EMIT_VALUE_METHOD_CALL_COUNT += 1
            else if (op.detail == 'field'):
                LLVM_EMIT_VALUE_FIELD_MS += elapsed_ms
                LLVM_EMIT_VALUE_FIELD_COUNT += 1
            else if (op.detail == 'index'):
                LLVM_EMIT_VALUE_INDEX_MS += elapsed_ms
                LLVM_EMIT_VALUE_INDEX_COUNT += 1
            else if (op.detail == 'slice'):
                LLVM_EMIT_VALUE_SLICE_MS += elapsed_ms
                LLVM_EMIT_VALUE_SLICE_COUNT += 1
            else if (op.detail == 'array' || op.detail == 'set' || op.detail == 'map'):
                LLVM_EMIT_VALUE_CONTAINER_MS += elapsed_ms
                LLVM_EMIT_VALUE_CONTAINER_COUNT += 1
            return line
        return emit_value_instruction(program, function_ir, op)
    if (op.kind == 'move_temp'):
        return '  ; move_temp ' + op.detail + ' ' + temp_ref(op.args[0])
    if (op.kind == 'release_local'):
        BindingIR binding = ir_parse_binding_decl(op.detail)
        return emit_backend_release_binding(binding, temp_suffix)
    if (op.kind == 'release_temp'):
        if (is_backend_managed_type(op.detail) && temp_needs_backend_free(function_ir, op.args[0])):
            return emit_backend_release_ptr(op.detail, temp_ref(op.args[0]))
        return '  ; release_temp ' + op.detail + ' ' + temp_ref(op.args[0])
    if (op.kind == 'try'):
        string env_ref = try_env_ref(temp_suffix)
        string env_ptr_ref = try_env_ptr_ref(temp_suffix)
        string prev_slot_ref = try_prev_slot_ref(temp_suffix)
        string prev_value_ref = '%tb.exc.prev.' + temp_suffix
        string state_ref = '%tb.exc.state.' + temp_suffix
        string caught_ref = '%tb.exc.caught.' + temp_suffix
        string continue_label = try_continue_label(temp_suffix)
        return join_llvm_strings([
            '  ' + env_ref + ' = alloca [192 x i8]',
            '  ' + prev_slot_ref + ' = alloca ptr',
            '  ' + prev_value_ref + ' = load ptr, ptr ' + exception_handler_symbol(),
            '  store ptr ' + prev_value_ref + ', ptr ' + prev_slot_ref,
            '  ' + env_ptr_ref + ' = getelementptr [192 x i8], ptr ' + env_ref + ', i32 0, i32 0',
            '  store ptr ' + env_ptr_ref + ', ptr ' + exception_handler_symbol(),
            '  ' + state_ref + ' = call i32 @setjmp(ptr ' + env_ptr_ref + ')',
            '  ' + caught_ref + ' = icmp ne i32 ' + state_ref + ', 0',
            '  br i1 ' + caught_ref + ', label %' + op.detail + ', label %' + continue_label,
            continue_label + ':'
        ], '\n')
    if (op.kind == 'catch'):
        string try_suffix = catch_try_suffix(function_ir, block_label)
        string[] lines = emit_try_restore_lines(try_suffix, temp_suffix)
        string message_ref = '%tb.exc.message.' + temp_suffix
        lines.push('  ' + message_ref + ' = load ptr, ptr ' + exception_message_symbol())
        lines.push('  store ptr ' + message_ref + ', ptr ' + slot_ref(ir_parse_binding_decl(op.detail).name))
        lines.push('  store ptr null, ptr ' + exception_message_symbol())
        if (is_backend_managed_type(ir_parse_binding_decl(op.detail).type_name)):
            lines.push('  store i1 false, ptr ' + owned_slot_ref(ir_parse_binding_decl(op.detail).name))
        return join_llvm_strings(lines, '\n')
    if (op.kind == 'release_field'):
        BindingIR field = record_field_binding_from_temp(program, function_ir, op.args[0], op.detail)
        if (!is_backend_managed_type(field.type_name)):
            return '  ; release_field ' + op.detail + ' ' + temp_ref(op.args[0])
        string ptr_name = '%release.field.ptr.' + temp_suffix
        string value_name = '%release.field.value.' + temp_suffix
        string owned_ptr_name = '%release.field.owned.ptr.' + temp_suffix
        string owned_byte_name = '%release.field.owned.byte.' + temp_suffix
        string owned_name = '%release.field.owned.' + temp_suffix
        string[] lines = [emit_record_field_ptr(program, function_ir, op.args[0], op.detail, ptr_name), '  ' + value_name + ' = load ' + llvm_type(field.type_name) + ', ptr ' + ptr_name, emit_record_owned_field_ptr(program, function_ir, op.args[0], op.detail, owned_ptr_name), '  ' + owned_byte_name + ' = load i8, ptr ' + owned_ptr_name, '  ' + owned_name + ' = icmp ne i8 ' + owned_byte_name + ', 0', '  br i1 ' + owned_name + ', label %release_field.do.' + temp_suffix + ', label %release_field.done.' + temp_suffix, 'release_field.do.' + temp_suffix + ':', '  ' + emit_backend_release_ptr(field.type_name, value_name).trim_left(), '  store ' + llvm_type(field.type_name) + ' zeroinitializer, ptr ' + ptr_name, '  store i8 0, ptr ' + owned_ptr_name, '  br label %release_field.done.' + temp_suffix, 'release_field.done.' + temp_suffix + ':']
        return join_llvm_strings(lines, '\n')
    if (op.kind == 'set'):
        if (LLVM_BACKEND_PROFILE_ACTIVE != 0):
            int start_ms = time_ms()
            string line = emit_set_instruction(program, function_ir, op, temp_suffix)
            LLVM_EMIT_SET_MS += time_ms() - start_ms
            LLVM_EMIT_SET_COUNT += 1
            return line
        return emit_set_instruction(program, function_ir, op, temp_suffix)
    if (op.kind == 'assign_local'):
        if (LLVM_BACKEND_PROFILE_ACTIVE != 0):
            int start_ms = time_ms()
            string line = emit_assign_local_instruction(program, function_ir, op, temp_suffix)
            LLVM_EMIT_ASSIGN_LOCAL_MS += time_ms() - start_ms
            LLVM_EMIT_ASSIGN_LOCAL_COUNT += 1
            return line
        return emit_assign_local_instruction(program, function_ir, op, temp_suffix)
    if (op.kind == 'assign_field'):
        if (LLVM_BACKEND_PROFILE_ACTIVE != 0):
            int start_ms = time_ms()
            string line = emit_assign_field_instruction(program, function_ir, op, temp_suffix)
            LLVM_EMIT_ASSIGN_FIELD_MS += time_ms() - start_ms
            LLVM_EMIT_ASSIGN_FIELD_COUNT += 1
            return line
        return emit_assign_field_instruction(program, function_ir, op, temp_suffix)
    if (op.kind == 'release_index'):
        return emit_release_index_instruction(program, function_ir, op, temp_suffix)
    if (op.kind == 'assign_index'):
        if (LLVM_BACKEND_PROFILE_ACTIVE != 0):
            int start_ms = time_ms()
            string line = emit_assign_index_instruction(program, function_ir, op, temp_suffix)
            LLVM_EMIT_ASSIGN_INDEX_MS += time_ms() - start_ms
            LLVM_EMIT_ASSIGN_INDEX_COUNT += 1
            return line
        return emit_assign_index_instruction(program, function_ir, op, temp_suffix)
    if (op.kind == 'drop'):
        if (normalize_llvm_type_name(lookup_temp_llvm_type(function_ir, op.args[0])) == 'void'):
            return '  ; drop void ' + temp_ref(op.args[0])
        return '  ; drop ' + temp_ref(op.args[0])
    throw 'unsupported llvm instruction kind: ' + op.kind

string[] emit_terminator(ParsedFunction function_ir, BlockIR block, TerminatorIR terminator, string temp_suffix):
    if (terminator.kind == 'jump'):
        string[] lines = []
        int catch_block_index = enclosing_try_catch_block_index(function_ir, block.label)
        int target_block_index = block_index_by_label(function_ir, terminator.args[0])
        if (catch_block_index >= 0 && target_block_index >= catch_block_index):
            lines = emit_try_restore_lines(enclosing_try_suffix(function_ir, block.label), temp_suffix)
        lines.push('  br label %' + terminator.args[0])
        return lines
    if (terminator.kind == 'branch_if'):
        string[] lines = []
        lines.push('  br i1 ' + temp_ref(terminator.args[0]) + ', label %' + terminator.args[1] + ', label %' + terminator.args[2])
        return lines
    if (terminator.kind == 'return'):
        string result_type = function_ir.return_type
        require_backend_value_type(result_type, 'return')
        string try_suffix = block_try_suffix(block)
        if (try_suffix == ''):
            try_suffix = enclosing_try_suffix(function_ir, block.label)
        if (normalize_llvm_type_name(result_type) == 'void'):
            string[] lines = emit_try_restore_lines(try_suffix, temp_suffix)
            lines.push('  ret void')
            return lines
        if (is_bootstrap_c_main(function_ir) && normalize_llvm_type_name(result_type) == 'int'):
            string exit_name = '%exit.' + temp_suffix
            string[] lines = emit_try_restore_lines(try_suffix, temp_suffix)
            lines.push('  ' + exit_name + ' = trunc i64 ' + temp_ref(terminator.args[0]) + ' to i32')
            lines.push('  ret i32 ' + exit_name)
            return lines
        string[] lines = emit_try_restore_lines(try_suffix, temp_suffix)
        lines.push('  ret ' + llvm_type(result_type) + ' ' + temp_ref(terminator.args[0]))
        return lines
    if (terminator.kind == 'return_owned'):
        string result_type = function_ir.return_type
        require_backend_value_type(result_type, 'return_owned')
        string try_suffix = block_try_suffix(block)
        if (try_suffix == ''):
            try_suffix = enclosing_try_suffix(function_ir, block.label)
        if (normalize_llvm_type_name(result_type) == 'void'):
            string[] lines = emit_try_restore_lines(try_suffix, temp_suffix)
            lines.push('  ret void')
            return lines
        if (normalize_llvm_type_name(result_type) == 'string'):
            string[] lines = emit_string_materialize_if_needed(function_ir, terminator.args[0], 'return.' + temp_suffix)
            string returned_value = temp_ref(terminator.args[0])
            if (temp_is_string(function_ir, terminator.args[0]) && !temp_needs_backend_free(function_ir, terminator.args[0])):
                returned_value = emit_string_owned_value(function_ir, terminator.args[0], 'return.' + temp_suffix)
            for (string restore_line in emit_try_restore_lines(try_suffix, temp_suffix)):
                lines.push(restore_line)
            lines.push('  ret ptr ' + returned_value)
            return lines
        if (normalize_llvm_type_name(result_type) == 'string[]'):
            string[] lines = emit_string_array_materialize_if_needed(function_ir, terminator.args[0], 'return.' + temp_suffix)
            string returned_value = temp_ref(terminator.args[0])
            if (temp_is_string_array(function_ir, terminator.args[0]) && !temp_needs_backend_free(function_ir, terminator.args[0])):
                returned_value = emit_string_array_owned_value(function_ir, terminator.args[0], 'return.' + temp_suffix)
            for (string restore_line in emit_try_restore_lines(try_suffix, temp_suffix)):
                lines.push(restore_line)
            lines.push('  ret ptr ' + returned_value)
            return lines
        if (normalize_llvm_type_name(result_type).starts_with('map<')):
            string[] lines = emit_map_materialize_if_needed(function_ir, terminator.args[0], 'return.' + temp_suffix)
            string returned_value = temp_ref(terminator.args[0])
            if (temp_is_map(function_ir, terminator.args[0]) && !temp_needs_backend_free(function_ir, terminator.args[0])):
                returned_value = emit_map_owned_value(function_ir, terminator.args[0], 'return.' + temp_suffix)
            for (string restore_line in emit_try_restore_lines(try_suffix, temp_suffix)):
                lines.push(restore_line)
            lines.push('  ret ptr ' + returned_value)
            return lines
        if (record_name_from_type(normalize_llvm_type_name(result_type)) != ''):
            string[] lines = emit_record_materialize_if_needed(ProgramIR([], [], [], [], []), function_ir, terminator.args[0], 'return.' + temp_suffix)
            string returned_value = temp_ref(terminator.args[0])
            if (temp_is_record(function_ir, terminator.args[0]) && !temp_needs_backend_free(function_ir, terminator.args[0])):
                returned_value = emit_record_owned_value(function_ir, terminator.args[0], 'return.' + temp_suffix)
            for (string restore_line in emit_try_restore_lines(try_suffix, temp_suffix)):
                lines.push(restore_line)
            lines.push('  ret ptr ' + returned_value)
            return lines
        if (is_bootstrap_c_main(function_ir) && normalize_llvm_type_name(result_type) == 'int'):
            string exit_name = '%exit.' + temp_suffix
            string[] lines = emit_try_restore_lines(try_suffix, temp_suffix)
            lines.push('  ' + exit_name + ' = trunc i64 ' + temp_ref(terminator.args[0]) + ' to i32')
            lines.push('  ret i32 ' + exit_name)
            return lines
        string[] lines = emit_try_restore_lines(try_suffix, temp_suffix)
        lines.push('  ret ' + llvm_type(result_type) + ' ' + temp_ref(terminator.args[0]))
        return lines
    if (terminator.kind == 'throw' || terminator.kind == 'throw_owned'):
        return [
            '  %tb.throw.handler.' + temp_suffix + ' = load ptr, ptr ' + exception_handler_symbol(),
            '  %tb.throw.has_handler.' + temp_suffix + ' = icmp ne ptr %tb.throw.handler.' + temp_suffix + ', null',
            '  br i1 %tb.throw.has_handler.' + temp_suffix + ', label %tb.throw.unwind.' + temp_suffix + ', label %tb.throw.fatal.' + temp_suffix,
            'tb.throw.unwind.' + temp_suffix + ':',
            '  store ptr ' + temp_ref(terminator.args[0]) + ', ptr ' + exception_message_symbol(),
            '  call void @longjmp(ptr %tb.throw.handler.' + temp_suffix + ', i32 1)',
            '  unreachable',
            'tb.throw.fatal.' + temp_suffix + ':',
            '  call i32 @puts(ptr ' + temp_ref(terminator.args[0]) + ')',
            '  call void @exit(i32 1)',
            '  unreachable'
        ]
    throw 'unsupported llvm terminator kind: ' + terminator.kind

string[] emit_allocas(ParsedFunction function_ir, bool bootstrap_main_args):
    string[] lines = []
    bool emitted_bootstrap_args = false
    for (BindingIR param_decl in function_ir.params):
        require_backend_value_type(param_decl.type_name, 'param')
        lines.push('  ' + slot_ref(param_decl.name) + ' = alloca ' + llvm_type(param_decl.type_name))
        if (bootstrap_main_args && !emitted_bootstrap_args):
            lines.push('  %tb.args = call ptr @tb_bootstrap_args_from_argv(i32 %argc, ptr %argv)')
            lines.push('  store ptr %tb.args, ptr ' + slot_ref(param_decl.name))
            emitted_bootstrap_args = true
        else:
            lines.push('  store ' + llvm_type(param_decl.type_name) + ' ' + param_ref(param_decl.name) + ', ptr ' + slot_ref(param_decl.name))
        if (is_backend_managed_type(param_decl.type_name)):
            lines.push('  ' + owned_slot_ref(param_decl.name) + ' = alloca i1')
            lines.push('  store i1 false, ptr ' + owned_slot_ref(param_decl.name))
    for (BindingIR local_decl in function_ir.locals):
        require_backend_value_type(local_decl.type_name, 'local')
        lines.push('  ' + slot_ref(local_decl.name) + ' = alloca ' + llvm_type(local_decl.type_name))
        if (is_backend_managed_type(local_decl.type_name)):
            lines.push('  ' + owned_slot_ref(local_decl.name) + ' = alloca i1')
            lines.push('  store i1 false, ptr ' + owned_slot_ref(local_decl.name))
        if (llvm_type(local_decl.type_name) == 'ptr'):
            lines.push('  store ptr null, ptr ' + slot_ref(local_decl.name))
    return lines

void append_plain_function_lines(string[] lines, ProgramIR program, ParsedFunction function_ir, string emitted_name, bool needs_runtime_global_init):
    string result_type = function_ir.return_type.substring(0)
    require_backend_value_type(result_type, 'function return')
    string function_name = emitted_name.substring(0)
    bool bootstrap_main_args = false
    if (function_name == 'main' && !function_ir.params.is_empty()):
        if (function_ir.params.length() == 1 && normalize_llvm_type_name(function_ir.params[0].type_name) == 'string[]'):
            bootstrap_main_args = true
        else:
            throw 'llvm bootstrap backend only supports zero-parameter main or main(string[] args)'

    string[] params = []
    if (bootstrap_main_args):
        params.push('i32 %argc')
        params.push('ptr %argv')
    else:
        for (BindingIR param_decl in function_ir.params):
            require_backend_value_type(param_decl.type_name, 'param')
            params.push(llvm_type(param_decl.type_name) + ' ' + param_ref(param_decl.name))

    string function_llvm_type = llvm_type(result_type).substring(0)
    if (is_bootstrap_c_main(function_ir) && normalize_llvm_type_name(result_type) == 'int'):
        function_llvm_type = 'i32'.substring(0)
    lines.push('define ' + function_llvm_type + ' @' + function_name + '(' + join_llvm_strings(params, ', ') + ') {')
    bool first = true
    int block_index = 0
    while (block_index < function_ir.blocks.length()):
        BlockIR block = function_ir.blocks[block_index]
        lines.push(block.label + ':')
        if (first):
            string[] allocas = emit_allocas(function_ir, bootstrap_main_args)
            for (string line in allocas):
                lines.push(line)
            if (needs_runtime_global_init && is_bootstrap_c_main(function_ir)):
                lines.push('  call void ' + globals_init_function_symbol() + '()')
            first = false
        int instruction_index = 0
        for (LinearInstruction op in block.instructions):
            lines.push(emit_instruction(program, function_ir, block.label, op, block.label + '.' + instruction_index))
            instruction_index += 1
        if (block.terminator.kind == ''):
            if (block_index == function_ir.blocks.length() - 1 && normalize_llvm_type_name(result_type) == 'void'):
                lines.push('  ret void')
            else if (block_index == function_ir.blocks.length() - 1 && is_bootstrap_c_main(function_ir) && normalize_llvm_type_name(result_type) == 'int'):
                lines.push('  ret i32 0')
            else if (block_index + 1 < function_ir.blocks.length()):
                lines.push('  br label %' + function_ir.blocks[block_index + 1].label)
            else:
                throw 'unsupported llvm terminator kind: '
        else:
            for (string line in emit_terminator(function_ir, block, block.terminator, block.label)):
                lines.push(line)
        block_index += 1
    lines.push('}')
string cached_len_symbol(string function_name):
    return '@__tb_cached_len_' + function_name

string cached_keys_symbol(string function_name):
    return '@__tb_cached_keys_' + function_name

string cached_used_symbol(string function_name):
    return '@__tb_cached_used_' + function_name

string cached_values_symbol(string function_name):
    return '@__tb_cached_values_' + function_name

string cached_impl_symbol_local(string function_name):
    return '@__tb_cached_impl_' + function_name

string globals_init_flag_symbol():
    return '@__tb_globals_initialized'

string globals_init_function_symbol():
    return '@__tb_init_globals'

bool global_has_static_initializer(ProgramIR program, GlobalDeclIR global_decl):
    BindingIR binding = ir_parse_binding_decl(strip_prefix(global_decl.header, 'global '))
    string type_name = normalize_llvm_type_name(binding.type_name)
    if (type_name == 'string[]'):
        return false
    if (type_name == 'map<string, string[]>'):
        return false
    if (record_name_from_type(type_name) != ''):
        LinearInstruction record_op = lookup_global_instruction(global_decl, global_decl.value_name)
        return record_op.kind == 'value' && record_op.detail == 'call' && record_op.args[0] == record_name_from_type(type_name)
    return global_decl.instructions.length() == 1 && global_decl.instructions[0].kind == 'value' && (global_decl.instructions[0].detail == 'int' || global_decl.instructions[0].detail == 'bool' || global_decl.instructions[0].detail == 'num' || global_decl.instructions[0].detail == 'string')

bool program_uses_runtime_global_init(ProgramIR program):
    for (GlobalDeclIR global_decl in program.globals):
        if (!global_has_static_initializer(program, global_decl)):
            return true
    return false

int cached_capacity():
    return 65536

bool supports_cached_record_param_backend(ProgramIR program, string type_name):
    string record_name = record_name_from_type(normalize_llvm_type_name(type_name))
    if (record_name == ''):
        return false
    RecordDeclIR record_decl = lookup_record_decl(program, record_name)
    if (record_decl.header == ''):
        return false
    BindingIR[] fields = record_field_bindings(record_decl)
    if (fields.is_empty() || fields.length() > 2):
        return false
    for (BindingIR field in fields):
        if (normalize_llvm_type_name(field.type_name) != 'int'):
            return false
    return true

bool supports_cached_function_backend(ProgramIR program, ParsedFunction function_ir):
    string result_type = normalize_llvm_type_name(function_ir.return_type)
    if (result_type != 'int'):
        return false
    if (function_ir.params.length() != 1):
        return false
    string param_type = normalize_llvm_type_name(function_ir.params[0].type_name)
    if (param_type == 'int'):
        return true
    return supports_cached_record_param_backend(program, param_type)

string[] emit_cached_function_globals(ProgramIR program, ParsedFunction function_ir):
    string function_name = function_ir.name
    return [
        cached_used_symbol(function_name) + ' = internal global [' + cached_capacity() + ' x i8] zeroinitializer',
        cached_keys_symbol(function_name) + ' = internal global [' + cached_capacity() + ' x i64] zeroinitializer',
        cached_values_symbol(function_name) + ' = internal global [' + cached_capacity() + ' x i64] zeroinitializer'
    ]

string[] emit_cached_record_key_lines(ProgramIR program, ParsedFunction function_ir, string base_ptr, string key_name):
    string param_type = normalize_llvm_type_name(function_ir.params[0].type_name)
    string record_name = record_name_from_type(param_type)
    RecordDeclIR record_decl = lookup_record_decl(program, record_name)
    string record_type = llvm_record_type_name(record_name)
    BindingIR[] fields = record_field_bindings(record_decl)
    string[] lines = []
    lines.push('  %' + key_name + '.field0.ptr = getelementptr inbounds ' + record_type + ', ptr ' + base_ptr + ', i32 0, i32 0')
    lines.push('  %' + key_name + '.field0 = load i64, ptr %' + key_name + '.field0.ptr')
    if (fields.length() == 1):
        lines.push('  %' + key_name + ' = add i64 %' + key_name + '.field0, 0')
        return lines
    lines.push('  %' + key_name + '.field1.ptr = getelementptr inbounds ' + record_type + ', ptr ' + base_ptr + ', i32 0, i32 1')
    lines.push('  %' + key_name + '.field1 = load i64, ptr %' + key_name + '.field1.ptr')
    lines.push('  %' + key_name + '.field0.i32 = trunc i64 %' + key_name + '.field0 to i32')
    lines.push('  %' + key_name + '.field1.i32 = trunc i64 %' + key_name + '.field1 to i32')
    lines.push('  %' + key_name + '.field0.u64 = zext i32 %' + key_name + '.field0.i32 to i64')
    lines.push('  %' + key_name + '.field1.u64 = zext i32 %' + key_name + '.field1.i32 to i64')
    lines.push('  %' + key_name + '.field0.shift = shl i64 %' + key_name + '.field0.u64, 32')
    lines.push('  %' + key_name + ' = or i64 %' + key_name + '.field0.shift, %' + key_name + '.field1.u64')
    return lines

void append_cached_function_lines(string[] lines, ProgramIR program, ParsedFunction function_ir, bool needs_runtime_global_init):
    string function_name = function_ir.name
    string result_type = normalize_llvm_type_name(function_ir.return_type)
    if (result_type != 'int'):
        throw 'cached llvm bootstrap backend only supports int return'
    if (!supports_cached_function_backend(program, function_ir)):
        throw 'cached llvm bootstrap backend only supports one int or simple record parameter'

    append_plain_function_lines(lines, program, function_ir, strip_prefix(cached_impl_symbol_local(function_name), '@'), needs_runtime_global_init)
    lines.push('')
    string arg_name = function_ir.params[0].name
    string param_type = normalize_llvm_type_name(function_ir.params[0].type_name)
    string param_llvm_type = llvm_type(param_type)
    lines.push('define i64 @' + function_name + '(' + param_llvm_type + ' ' + param_ref(arg_name) + ') {')
    lines.push('entry:')
    if (param_type != 'int'):
        for (string line in emit_cached_record_key_lines(program, function_ir, param_ref(arg_name), 'cache.arg.key')):
            lines.push(line)
    else:
        lines.push('  %cache.arg.key = add i64 ' + param_ref(arg_name) + ', 0')
    lines.push('  %cache.start = urem i64 %cache.arg.key, ' + cached_capacity())
    lines.push('  br label %cache.loop')
    lines.push('cache.loop:')
    lines.push('  %cache.index = phi i64 [%cache.start, %entry], [%cache.next, %cache.step]')
    lines.push('  %cache.used.ptr = getelementptr inbounds [' + cached_capacity() + ' x i8], ptr ' + cached_used_symbol(function_name) + ', i32 0, i64 %cache.index')
    lines.push('  %cache.used.byte = load i8, ptr %cache.used.ptr')
    lines.push('  %cache.used = icmp ne i8 %cache.used.byte, 0')
    lines.push('  br i1 %cache.used, label %cache.body, label %cache.miss')
    lines.push('cache.body:')
    lines.push('  %cache.key.ptr = getelementptr inbounds [' + cached_capacity() + ' x i64], ptr ' + cached_keys_symbol(function_name) + ', i32 0, i64 %cache.index')
    lines.push('  %cache.key = load i64, ptr %cache.key.ptr')
    lines.push('  %cache.hit = icmp eq i64 %cache.key, %cache.arg.key')
    lines.push('  br i1 %cache.hit, label %cache.found, label %cache.step')
    lines.push('cache.step:')
    lines.push('  %cache.wrap = icmp eq i64 %cache.index, ' + (cached_capacity() - 1) + '')
    lines.push('  %cache.next.raw = add i64 %cache.index, 1')
    lines.push('  %cache.next = select i1 %cache.wrap, i64 0, i64 %cache.next.raw')
    lines.push('  br label %cache.loop')
    lines.push('cache.found:')
    lines.push('  %cache.value.ptr = getelementptr inbounds [' + cached_capacity() + ' x i64], ptr ' + cached_values_symbol(function_name) + ', i32 0, i64 %cache.index')
    lines.push('  %cache.value = load i64, ptr %cache.value.ptr')
    lines.push('  ret i64 %cache.value')
    lines.push('cache.miss:')
    lines.push('  %cache.result = call i64 ' + cached_impl_symbol_local(function_name) + '(' + param_llvm_type + ' ' + param_ref(arg_name) + ')')
    lines.push('  br label %cache.store')
    lines.push('cache.store:')
    lines.push('  store i8 1, ptr %cache.used.ptr')
    lines.push('  %cache.store.key.ptr = getelementptr inbounds [' + cached_capacity() + ' x i64], ptr ' + cached_keys_symbol(function_name) + ', i32 0, i64 %cache.index')
    lines.push('  store i64 %cache.arg.key, ptr %cache.store.key.ptr')
    lines.push('  %cache.store.value.ptr = getelementptr inbounds [' + cached_capacity() + ' x i64], ptr ' + cached_values_symbol(function_name) + ', i32 0, i64 %cache.index')
    lines.push('  store i64 %cache.result, ptr %cache.store.value.ptr')
    lines.push('  br label %cache.return')
    lines.push('cache.return:')
    lines.push('  ret i64 %cache.result')
    lines.push('}')

void append_function_lines(string[] lines, ProgramIR program, ParsedFunction function_ir, bool needs_runtime_global_init):
    if (is_cached_function_header(function_ir.header) && supports_cached_function_backend(program, function_ir)):
        append_cached_function_lines(lines, program, function_ir, needs_runtime_global_init)
        return
    append_plain_function_lines(lines, program, function_ir, function_ir.name, needs_runtime_global_init)

string[] emit_function(ProgramIR program, ParsedFunction function_ir, bool needs_runtime_global_init):
    string[] lines = []
    append_function_lines(lines, program, function_ir, needs_runtime_global_init)
    return lines

string emit_global_initializer(GlobalDeclIR global_decl):
    if (global_decl.instructions.length() != 1):
        throw 'llvm bootstrap backend only supports simple scalar global initializers'
    LinearInstruction op = global_decl.instructions[0]
    BindingIR binding = ir_parse_binding_decl(strip_prefix(global_decl.header, 'global '))
    require_backend_value_type(binding.type_name, 'global')
    if (op.kind != 'value'):
        throw 'unsupported llvm global initializer instruction: ' + op.kind
    if (op.detail == 'int'):
        return op.args[0].substring(0)
    if (op.detail == 'bool'):
        return llvm_bool_literal(op.args[0])
    if (op.detail == 'num'):
        return '%tb_bootstrap_num { i64 ' + num_literal_value_text(op.args[0]) + ', i64 ' + num_literal_scale(op.args[0]).to_string() + ' }'
    if (op.detail == 'string'):
        StringConstIR constant = encode_tb_string_literal(global_string_symbol(binding.name, op.lhs), op.args[0])
        return 'getelementptr inbounds ([' + constant.length + ' x i8], ptr ' + string_symbol_ref(constant.symbol) + ', i32 0, i32 0)'
    throw 'unsupported llvm global initializer value: ' + op.detail

string emit_runtime_global_placeholder(BindingIR binding):
    string type_name = normalize_llvm_type_name(binding.type_name)
    if (type_name == 'int'):
        return global_ref(binding.name) + ' = global i64 0'
    if (type_name == 'bool'):
        return global_ref(binding.name) + ' = global i1 false'
    if (type_name == 'num'):
        return global_ref(binding.name) + ' = global %tb_bootstrap_num zeroinitializer'
    return global_ref(binding.name) + ' = global ptr null'

string[] collect_global_temp_names(LinearInstruction[] instructions):
    string[] names = []
    int index = 0
    while (index < instructions.length()):
        if (instructions[index].lhs != ''):
            names.push(instructions[index].lhs)
        index += 1
    return names

string rename_global_temp_if_needed(string value, string[] temp_names, string prefix):
    for (string temp_name in temp_names):
        if (value == temp_name):
            return prefix + '.' + value
    return value

LinearInstruction rename_global_instruction_temps(LinearInstruction op, string[] temp_names, string prefix):
    string lhs = op.lhs
    if (lhs != ''):
        lhs = prefix + '.' + lhs
    string[] args = []
    for (string arg in op.args):
        args.push(rename_global_temp_if_needed(arg, temp_names, prefix))
    return LinearInstruction(op.kind, lhs, op.result_type, op.ownership_mode, op.detail, args)

LinearInstruction find_global_array_instruction(GlobalDeclIR global_decl):
    int index = 0
    while (index < global_decl.instructions.length()):
        if (global_decl.instructions[index].kind == 'value' && global_decl.instructions[index].detail == 'array'):
            return global_decl.instructions[index]
        index += 1
    return LinearInstruction('', '', '', '', '', [])

LinearInstruction lookup_global_instruction(GlobalDeclIR global_decl, string temp_name):
    int index = 0
    while (index < global_decl.instructions.length()):
        if (global_decl.instructions[index].lhs == temp_name):
            return global_decl.instructions[index]
        index += 1
    return LinearInstruction('', '', '', '', '', [])

string[] emit_global_string_array_storage(GlobalDeclIR global_decl, string global_name, string symbol_prefix, string temp_name):
    LinearInstruction array_op = lookup_global_instruction(global_decl, temp_name)
    if (!(array_op.kind == 'value' && array_op.detail == 'array')):
        throw 'unsupported llvm string[] global initializer'
    string data_symbol = symbol_prefix + '.data'
    string owned_symbol = symbol_prefix + '.owned'
    string value_symbol = symbol_prefix + '.value'
    string[] item_ptrs = []
    int index = 0
    while (index < array_op.args.length()):
        LinearInstruction item_op = lookup_global_instruction(global_decl, array_op.args[index])
        if (!(item_op.kind == 'value' && item_op.detail == 'string')):
            throw 'unsupported llvm string[] global element'
        StringConstIR constant = encode_tb_string_literal(global_string_symbol(global_name, item_op.lhs), item_op.args[0])
        item_ptrs.push('ptr getelementptr inbounds ([' + constant.length + ' x i8], ptr ' + string_symbol_ref(constant.symbol) + ', i32 0, i32 0)')
        index += 1
    return [
        data_symbol + ' = private global [' + array_op.args.length() + ' x ptr] [' + join_llvm_strings(item_ptrs, ', ') + ']',
        owned_symbol + ' = private global [' + array_op.args.length() + ' x i8] zeroinitializer',
        value_symbol + ' = global %tb_bootstrap_string_array { i32 ' + array_op.args.length() + ', i32 ' + array_op.args.length() + ', ptr getelementptr inbounds ([' + array_op.args.length() + ' x ptr], ptr ' + data_symbol + ', i32 0, i32 0), ptr getelementptr inbounds ([' + array_op.args.length() + ' x i8], ptr ' + owned_symbol + ', i32 0, i32 0) }'
    ]

string global_value_symbol_from_prefix(string symbol_prefix):
    return symbol_prefix + '.value'

string[] emit_global_record_storage(ProgramIR program, GlobalDeclIR global_decl, string global_name, string symbol_prefix, string temp_name, string record_name):
    LinearInstruction record_op = lookup_global_instruction(global_decl, temp_name)
    if (!(record_op.kind == 'value' && record_op.detail == 'call' && record_op.args[0] == record_name)):
        throw 'unsupported llvm record global initializer'
    RecordDeclIR record_decl = lookup_record_decl(program, record_name)
    if (record_decl.header == ''):
        throw 'unknown llvm record global type: ' + record_name
    string value_symbol = global_value_symbol_from_prefix(symbol_prefix)
    string[] lines = []
    string[] field_values = []
    for (BindingIR field in record_field_bindings(record_decl)):
        int arg_index = record_field_index(record_decl, field.name) + 1
        string arg_name = record_op.args[arg_index]
        LinearInstruction arg_op = lookup_global_instruction(global_decl, arg_name)
        if (field.type_name == 'string'):
            if (!(arg_op.kind == 'value' && arg_op.detail == 'string')):
                throw 'unsupported llvm record global string field'
            StringConstIR constant = encode_tb_string_literal(global_string_symbol(global_name, arg_op.lhs), arg_op.args[0])
            field_values.push('ptr getelementptr inbounds ([' + constant.length + ' x i8], ptr ' + string_symbol_ref(constant.symbol) + ', i32 0, i32 0)')
        else if (field.type_name == 'string[]'):
            string nested_prefix = symbol_prefix + '.' + field.name + '.' + arg_name
            for (string line in emit_global_string_array_storage(global_decl, global_name, nested_prefix, arg_name)):
                lines.push(line)
            field_values.push('ptr ' + global_value_symbol_from_prefix(nested_prefix))
        else if (normalize_llvm_type_name(field.type_name) == 'map<string, string[]>'):
            string nested_prefix = symbol_prefix + '.' + field.name + '.' + arg_name
            LinearInstruction map_op = lookup_global_instruction(global_decl, arg_name)
            if (!(map_op.kind == 'value' && map_op.detail == 'map')):
                throw 'unsupported llvm record global map field'
            string keys_symbol = nested_prefix + '.keys'
            string values_symbol = nested_prefix + '.values'
            string owned_symbol = nested_prefix + '.owned'
            string nested_value_symbol = global_value_symbol_from_prefix(nested_prefix)
            string[] key_ptrs = []
            string[] value_ptrs = []
            int item_index = 0
            while (item_index < map_op.args.length()):
                LinearInstruction key_op = lookup_global_instruction(global_decl, map_op.args[item_index])
                LinearInstruction value_op = lookup_global_instruction(global_decl, map_op.args[item_index + 1])
                StringConstIR key_constant = encode_tb_string_literal(global_string_symbol(global_name, key_op.lhs), key_op.args[0])
                key_ptrs.push('ptr getelementptr inbounds ([' + key_constant.length + ' x i8], ptr ' + string_symbol_ref(key_constant.symbol) + ', i32 0, i32 0)')
                string entry_prefix = nested_prefix + '.entry.' + value_op.lhs
                for (string line in emit_global_string_array_storage(global_decl, global_name, entry_prefix, value_op.lhs)):
                    lines.push(line)
                value_ptrs.push('ptr ' + global_value_symbol_from_prefix(entry_prefix))
                item_index += 2
            lines.push(keys_symbol + ' = private global [' + key_ptrs.length() + ' x ptr] [' + join_llvm_strings(key_ptrs, ', ') + ']')
            lines.push(values_symbol + ' = private global [' + value_ptrs.length() + ' x ptr] [' + join_llvm_strings(value_ptrs, ', ') + ']')
            lines.push(owned_symbol + ' = private global [' + value_ptrs.length() + ' x i8] zeroinitializer')
            lines.push(nested_value_symbol + ' = global %tb_bootstrap_map_string_string_array { i32 ' + value_ptrs.length() + ', ptr getelementptr inbounds ([' + key_ptrs.length() + ' x ptr], ptr ' + keys_symbol + ', i32 0, i32 0), ptr getelementptr inbounds ([' + value_ptrs.length() + ' x ptr], ptr ' + values_symbol + ', i32 0, i32 0), ptr getelementptr inbounds ([' + value_ptrs.length() + ' x i8], ptr ' + owned_symbol + ', i32 0, i32 0) }')
            field_values.push('ptr ' + nested_value_symbol)
        else if (record_name_from_type(field.type_name) != ''):
            string nested_prefix = symbol_prefix + '.' + field.name + '.' + arg_name
            for (string line in emit_global_record_storage(program, global_decl, global_name, nested_prefix, arg_name, record_name_from_type(field.type_name))):
                lines.push(line)
            field_values.push('ptr ' + global_value_symbol_from_prefix(nested_prefix))
        else if (arg_op.detail == 'int'):
            field_values.push('i64 ' + arg_op.args[0])
        else if (arg_op.detail == 'bool'):
            field_values.push('i1 ' + llvm_bool_literal(arg_op.args[0]))
        else if (arg_op.detail == 'num'):
            field_values.push('%tb_bootstrap_num { i64 ' + num_literal_value_text(arg_op.args[0]) + ', i64 ' + num_literal_scale(arg_op.args[0]).to_string() + ' }')
        else:
            throw 'unsupported llvm record global field'
    int managed_index = 0
    while (managed_index < managed_record_field_count(record_decl)):
        field_values.push('i8 0')
        managed_index += 1
    lines.push(value_symbol + ' = global ' + llvm_record_type_name(record_name) + ' { ' + join_llvm_strings(field_values, ', ') + ' }')
    return lines

string[] emit_global_lines(ProgramIR program, GlobalDeclIR global_decl):
    BindingIR binding = ir_parse_binding_decl(strip_prefix(global_decl.header, 'global '))
    require_backend_value_type(binding.type_name, 'global')
    if (!global_has_static_initializer(program, global_decl)):
        return [emit_runtime_global_placeholder(binding)]
    if (normalize_llvm_type_name(binding.type_name) == 'string[]'):
        LinearInstruction array_op = find_global_array_instruction(global_decl)
        if (array_op.kind == ''):
            throw 'unsupported llvm string[] global initializer'
        string value_symbol = '@.arr.global.' + binding.name + '.value'
        string[] lines = emit_global_string_array_storage(global_decl, binding.name, '@.arr.global.' + binding.name, array_op.lhs)
        lines.push(global_ref(binding.name) + ' = global ptr ' + value_symbol)
        return lines
    if (normalize_llvm_type_name(binding.type_name) == 'map<string, string[]>'):
        LinearInstruction map_op = lookup_global_instruction(global_decl, global_decl.value_name)
        if (!(map_op.kind == 'value' && map_op.detail == 'map')):
            throw 'unsupported llvm map global initializer'
        string keys_symbol = '@.map.global.' + binding.name + '.keys'
        string values_symbol = '@.map.global.' + binding.name + '.values'
        string owned_symbol = '@.map.global.' + binding.name + '.owned'
        string value_symbol = '@.map.global.' + binding.name + '.value'
        string[] key_ptrs = []
        string[] value_ptrs = []
        string[] lines = []
        int index = 0
        while (index < map_op.args.length()):
            LinearInstruction key_op = lookup_global_instruction(global_decl, map_op.args[index])
            LinearInstruction value_op = lookup_global_instruction(global_decl, map_op.args[index + 1])
            if (!(key_op.kind == 'value' && key_op.detail == 'string')):
                throw 'unsupported llvm map global key'
            if (!(value_op.kind == 'value' && value_op.detail == 'array')):
                throw 'unsupported llvm map global value'
            string entry_name = value_op.lhs
            StringConstIR key_constant = encode_tb_string_literal(global_string_symbol(binding.name, key_op.lhs), key_op.args[0])
            key_ptrs.push('ptr getelementptr inbounds ([' + key_constant.length + ' x i8], ptr ' + string_symbol_ref(key_constant.symbol) + ', i32 0, i32 0)')
            string nested_prefix = '@.map.global.' + binding.name + '.entry.' + entry_name
            for (string line in emit_global_string_array_storage(global_decl, binding.name, nested_prefix, value_op.lhs)):
                lines.push(line)
            value_ptrs.push('ptr ' + nested_prefix + '.value')
            index += 2
        lines.push(keys_symbol + ' = private global [' + key_ptrs.length() + ' x ptr] [' + join_llvm_strings(key_ptrs, ', ') + ']')
        lines.push(values_symbol + ' = private global [' + value_ptrs.length() + ' x ptr] [' + join_llvm_strings(value_ptrs, ', ') + ']')
        lines.push(owned_symbol + ' = private global [' + value_ptrs.length() + ' x i8] zeroinitializer')
        lines.push(value_symbol + ' = global %tb_bootstrap_map_string_string_array { i32 ' + value_ptrs.length() + ', ptr getelementptr inbounds ([' + key_ptrs.length() + ' x ptr], ptr ' + keys_symbol + ', i32 0, i32 0), ptr getelementptr inbounds ([' + value_ptrs.length() + ' x ptr], ptr ' + values_symbol + ', i32 0, i32 0), ptr getelementptr inbounds ([' + value_ptrs.length() + ' x i8], ptr ' + owned_symbol + ', i32 0, i32 0) }')
        lines.push(global_ref(binding.name) + ' = global ptr ' + value_symbol)
        return lines
    if (record_name_from_type(normalize_llvm_type_name(binding.type_name)) != ''):
        string record_name = record_name_from_type(normalize_llvm_type_name(binding.type_name))
        string record_prefix = '@.record.global.' + binding.name
        string[] lines = emit_global_record_storage(program, global_decl, binding.name, record_prefix, global_decl.value_name, record_name)
        lines.push(global_ref(binding.name) + ' = global ptr ' + global_value_symbol_from_prefix(record_prefix))
        return lines
    return [global_ref(binding.name) + ' = global ' + llvm_type(binding.type_name) + ' ' + emit_global_initializer(global_decl)]

string[] emit_runtime_global_init_lines(ProgramIR program, GlobalDeclIR global_decl):
    BindingIR binding = ir_parse_binding_decl(strip_prefix(global_decl.header, 'global '))
    string prefix = binding.name
    string[] temp_names = collect_global_temp_names(global_decl.instructions)
    LinearInstruction[] renamed = []
    int renamed_index = 0
    while (renamed_index < global_decl.instructions.length()):
        renamed.push(rename_global_instruction_temps(global_decl.instructions[renamed_index], temp_names, prefix))
        renamed_index += 1
    ParsedFunction function_ir = ParsedFunction('func void __tb_init_globals', '__tb_init_globals', 'void', [], [], [BlockIR('entry', renamed, TerminatorIR('', []))])
    string[] lines = []
    int instruction_index = 0
    while (instruction_index < renamed.length()):
        lines.push(emit_instruction(program, function_ir, 'globals', renamed[instruction_index], 'globals.' + binding.name + '.' + instruction_index))
        instruction_index += 1
    LinearInstruction store_op = LinearInstruction('assign_local', '', '', '', binding.name, [rename_global_temp_if_needed(global_decl.value_name, temp_names, prefix)])
    lines.push(emit_instruction(program, function_ir, 'globals', store_op, 'globals.' + binding.name + '.store'))
    return lines

string[] emit_global_init_helper(ProgramIR program):
    string[] lines = [
        globals_init_flag_symbol() + ' = internal global i1 false',
        'define private void ' + globals_init_function_symbol() + '() {',
        'entry:',
        '  %already = load i1, ptr ' + globals_init_flag_symbol(),
        '  br i1 %already, label %done, label %init',
        'init:',
        '  store i1 true, ptr ' + globals_init_flag_symbol()
    ]
    for (GlobalDeclIR global_decl in program.globals):
        if (!global_has_static_initializer(program, global_decl)):
            for (string line in emit_runtime_global_init_lines(program, global_decl)):
                lines.push(line)
    lines.push('  br label %done')
    lines.push('done:')
    lines.push('  ret void')
    lines.push('}')
    return lines

string emit_record_type(RecordDeclIR record_decl):
    string record_name = strip_prefix(record_decl.header, 'record ')
    string[] field_types = []
    for (BindingIR field in record_field_bindings(record_decl)):
        field_types.push(llvm_type(field.type_name))
    int managed_count = managed_record_field_count(record_decl)
    int index = 0
    while (index < managed_count):
        field_types.push('i8')
        index += 1
    return llvm_record_type_name(record_name) + ' = type { ' + join_llvm_strings(field_types, ', ') + ' }'

string[] emit_record_helpers(RecordDeclIR record_decl):
    string record_name = strip_prefix(record_decl.header, 'record ')
    string record_type = llvm_record_type_name(record_name)
    BindingIR[] fields = record_field_bindings(record_decl)
    string[] clone_field_lines = []
    int index = 0
    while (index < fields.length()):
        BindingIR field = fields[index]
        clone_field_lines.push('  %field.src.' + field.name + ' = getelementptr inbounds ' + record_type + ', ptr %record, i32 0, i32 ' + index)
        clone_field_lines.push('  %field.value.' + field.name + ' = load ' + llvm_type(field.type_name) + ', ptr %field.src.' + field.name)
        string stored_value = '%field.value.' + field.name
        string stored_owned = 'false'
        if (is_backend_managed_type(field.type_name)):
            int owned_index = llvm_record_owned_field_index(record_decl, field.name)
            clone_field_lines.push('  %field.owned.src.' + field.name + ' = getelementptr inbounds ' + record_type + ', ptr %record, i32 0, i32 ' + owned_index)
            clone_field_lines.push('  %field.owned.byte.' + field.name + ' = load i8, ptr %field.owned.src.' + field.name)
            clone_field_lines.push('  %field.owned.' + field.name + ' = icmp ne i8 %field.owned.byte.' + field.name + ', 0')
        if (normalize_llvm_type_name(field.type_name) == 'string'):
            clone_field_lines.push('  br i1 %field.owned.' + field.name + ', label %field.clone.owned.' + field.name + ', label %field.clone.borrowed.' + field.name)
            clone_field_lines.push('field.clone.owned.' + field.name + ':')
            clone_field_lines.push('  %field.copy.' + field.name + ' = call ptr @tb_retain(ptr %field.value.' + field.name + ')')
            clone_field_lines.push('  br label %field.clone.done.' + field.name)
            clone_field_lines.push('field.clone.borrowed.' + field.name + ':')
            clone_field_lines.push('  br label %field.clone.done.' + field.name)
            clone_field_lines.push('field.clone.done.' + field.name + ':')
            clone_field_lines.push('  %field.clone.value.' + field.name + ' = phi ptr [%field.copy.' + field.name + ', %field.clone.owned.' + field.name + '], [%field.value.' + field.name + ', %field.clone.borrowed.' + field.name + ']')
            stored_value = '%field.clone.value.' + field.name
            stored_owned = '%field.owned.' + field.name
        else if (normalize_llvm_type_name(field.type_name) == 'string[]'):
            clone_field_lines.push('  br i1 %field.owned.' + field.name + ', label %field.clone.owned.' + field.name + ', label %field.clone.borrowed.' + field.name)
            clone_field_lines.push('field.clone.owned.' + field.name + ':')
            clone_field_lines.push('  %field.copy.' + field.name + ' = call ptr @tb_bootstrap_string_array_clone(ptr %field.value.' + field.name + ')')
            clone_field_lines.push('  br label %field.clone.done.' + field.name)
            clone_field_lines.push('field.clone.borrowed.' + field.name + ':')
            clone_field_lines.push('  br label %field.clone.done.' + field.name)
            clone_field_lines.push('field.clone.done.' + field.name + ':')
            clone_field_lines.push('  %field.clone.value.' + field.name + ' = phi ptr [%field.copy.' + field.name + ', %field.clone.owned.' + field.name + '], [%field.value.' + field.name + ', %field.clone.borrowed.' + field.name + ']')
            stored_value = '%field.clone.value.' + field.name
            stored_owned = '%field.owned.' + field.name
        else if (normalize_llvm_type_name(field.type_name).starts_with('map<')):
            clone_field_lines.push('  br i1 %field.owned.' + field.name + ', label %field.clone.owned.' + field.name + ', label %field.clone.borrowed.' + field.name)
            clone_field_lines.push('field.clone.owned.' + field.name + ':')
            clone_field_lines.push('  %field.copy.' + field.name + ' = call ptr ' + llvm_map_clone_name(field.type_name) + '(ptr %field.value.' + field.name + ')')
            clone_field_lines.push('  br label %field.clone.done.' + field.name)
            clone_field_lines.push('field.clone.borrowed.' + field.name + ':')
            clone_field_lines.push('  br label %field.clone.done.' + field.name)
            clone_field_lines.push('field.clone.done.' + field.name + ':')
            clone_field_lines.push('  %field.clone.value.' + field.name + ' = phi ptr [%field.copy.' + field.name + ', %field.clone.owned.' + field.name + '], [%field.value.' + field.name + ', %field.clone.borrowed.' + field.name + ']')
            stored_value = '%field.clone.value.' + field.name
            stored_owned = '%field.owned.' + field.name
        else if (record_name_from_type(field.type_name) != ''):
            clone_field_lines.push('  br i1 %field.owned.' + field.name + ', label %field.clone.owned.' + field.name + ', label %field.clone.borrowed.' + field.name)
            clone_field_lines.push('field.clone.owned.' + field.name + ':')
            clone_field_lines.push('  %field.copy.' + field.name + ' = call ptr @tb_bootstrap_record_clone_' + record_name_from_type(field.type_name) + '(ptr %field.value.' + field.name + ')')
            clone_field_lines.push('  br label %field.clone.done.' + field.name)
            clone_field_lines.push('field.clone.borrowed.' + field.name + ':')
            clone_field_lines.push('  br label %field.clone.done.' + field.name)
            clone_field_lines.push('field.clone.done.' + field.name + ':')
            clone_field_lines.push('  %field.clone.value.' + field.name + ' = phi ptr [%field.copy.' + field.name + ', %field.clone.owned.' + field.name + '], [%field.value.' + field.name + ', %field.clone.borrowed.' + field.name + ']')
            stored_value = '%field.clone.value.' + field.name
            stored_owned = '%field.owned.' + field.name
        else if (normalize_llvm_type_name(field.type_name).ends_with('[]') && record_name_from_type(array_item_type(normalize_llvm_type_name(field.type_name))) != ''):
            clone_field_lines.push('  br i1 %field.owned.' + field.name + ', label %field.clone.owned.' + field.name + ', label %field.clone.borrowed.' + field.name)
            clone_field_lines.push('field.clone.owned.' + field.name + ':')
            clone_field_lines.push('  %field.copy.' + field.name + ' = call ptr @tb_bootstrap_record_array_clone_' + record_name_from_type(array_item_type(normalize_llvm_type_name(field.type_name))) + '(ptr %field.value.' + field.name + ')')
            clone_field_lines.push('  br label %field.clone.done.' + field.name)
            clone_field_lines.push('field.clone.borrowed.' + field.name + ':')
            clone_field_lines.push('  br label %field.clone.done.' + field.name)
            clone_field_lines.push('field.clone.done.' + field.name + ':')
            clone_field_lines.push('  %field.clone.value.' + field.name + ' = phi ptr [%field.copy.' + field.name + ', %field.clone.owned.' + field.name + '], [%field.value.' + field.name + ', %field.clone.borrowed.' + field.name + ']')
            stored_value = '%field.clone.value.' + field.name
            stored_owned = '%field.owned.' + field.name
        clone_field_lines.push('  %field.dst.' + field.name + ' = getelementptr inbounds ' + record_type + ', ptr %clone, i32 0, i32 ' + index)
        clone_field_lines.push('  store ' + llvm_type(field.type_name) + ' ' + stored_value + ', ptr %field.dst.' + field.name)
        if (is_backend_managed_type(field.type_name)):
            int owned_index = llvm_record_owned_field_index(record_decl, field.name)
            clone_field_lines.push('  %field.owned.dst.' + field.name + ' = getelementptr inbounds ' + record_type + ', ptr %clone, i32 0, i32 ' + owned_index)
            clone_field_lines.push('  %field.owned.store.' + field.name + ' = zext i1 ' + stored_owned + ' to i8')
            clone_field_lines.push('  store i8 %field.owned.store.' + field.name + ', ptr %field.owned.dst.' + field.name)
        index += 1
    string[] free_field_lines = []
    index = 0
    while (index < fields.length()):
        BindingIR field = fields[index]
        if (is_backend_managed_type(field.type_name)):
            free_field_lines.push('  %field.ptr.' + field.name + ' = getelementptr inbounds ' + record_type + ', ptr %record, i32 0, i32 ' + index)
            free_field_lines.push('  %field.value.' + field.name + ' = load ' + llvm_type(field.type_name) + ', ptr %field.ptr.' + field.name)
            int owned_index = llvm_record_owned_field_index(record_decl, field.name)
            free_field_lines.push('  %field.owned.ptr.' + field.name + ' = getelementptr inbounds ' + record_type + ', ptr %record, i32 0, i32 ' + owned_index)
            free_field_lines.push('  %field.owned.byte.' + field.name + ' = load i8, ptr %field.owned.ptr.' + field.name)
            free_field_lines.push('  %field.owned.' + field.name + ' = icmp ne i8 %field.owned.byte.' + field.name + ', 0')
            free_field_lines.push('  br i1 %field.owned.' + field.name + ', label %field.release.' + field.name + ', label %field.skip.' + field.name)
            free_field_lines.push('field.release.' + field.name + ':')
            if (normalize_llvm_type_name(field.type_name).ends_with('[]') && record_name_from_type(array_item_type(normalize_llvm_type_name(field.type_name))) != ''):
                free_field_lines.push('  call void @tb_bootstrap_record_array_free_' + record_name_from_type(array_item_type(normalize_llvm_type_name(field.type_name))) + '(ptr %field.value.' + field.name + ')')
            else:
                free_field_lines.push('  ' + emit_backend_release_ptr(field.type_name, '%field.value.' + field.name).trim_left())
            free_field_lines.push('  br label %field.skip.' + field.name)
            free_field_lines.push('field.skip.' + field.name + ':')
        index += 1
    string[] lines = read_file('compiler/tb/llvm_helpers/record_helpers_base.ll').split_lines()
    lines = replace_llvm_template_lines(lines, '__RECORD__', record_name)
    lines = replace_llvm_template_lines(lines, '__RECORD_TYPE__', record_type)
    lines = replace_llvm_template_block_lines(lines, '__CLONE_FIELD_LINES__', clone_field_lines)
    lines = replace_llvm_template_block_lines(lines, '__FREE_FIELD_LINES__', free_field_lines)
    return lines

string[] emit_num_helpers():
    return read_file('compiler/tb/llvm_helpers/num.ll').split_lines()


string[] emit_string_helpers(bool include_num_to_string):
    string[] lines = read_file('compiler/tb/llvm_helpers/string_base.ll').split_lines()
    if (include_num_to_string):
        for (string line in read_file('compiler/tb/llvm_helpers/string_num_to_string.ll').split_lines()):
            lines.push(line)
    return lines


string[] emit_main_args_helpers():
    return read_file('compiler/tb/llvm_helpers/main_args.ll').split_lines()

string[] emit_string_array_helpers():
    return read_file('compiler/tb/llvm_helpers/string_array.ll').split_lines()

string[] emit_string_array_array_helpers():
    return read_file('compiler/tb/llvm_helpers/string_array_array.ll').split_lines()

string[] emit_int_array_helpers():
    string[] lines = read_file('compiler/tb/llvm_helpers/int_array_base.ll').split_lines()
    for (string line in read_file('compiler/tb/llvm_helpers/int_array_map_ops.ll').split_lines()):
        lines.push(line)
    return lines


string[] emit_int_set_helpers():
    return read_file('compiler/tb/llvm_helpers/int_set.ll').split_lines()

string[] emit_named_int_sort_helper(string comparator_name):
    string comparator_symbol = llvm_named_int_sort_comparator_symbol(comparator_name)
    return [
        'define private i32 ' + comparator_symbol + '(ptr %left.slot, ptr %right.slot) {',
        'entry:',
        '  %left = load i64, ptr %left.slot',
        '  %right = load i64, ptr %right.slot',
        '  %cmp64 = call i64 @' + comparator_name + '(i64 %left, i64 %right)',
        '  %is.neg = icmp slt i64 %cmp64, 0',
        '  %is.pos = icmp sgt i64 %cmp64, 0',
        '  %signed = select i1 %is.neg, i32 -1, i32 0',
        '  %result = select i1 %is.pos, i32 1, i32 %signed',
        '  ret i32 %result',
        '}'
    ]

string[] emit_named_record_sort_helper(string record_name, string comparator_name):
    string comparator_symbol = llvm_named_record_sort_comparator_symbol(record_name, comparator_name)
    return [
        'define private i32 ' + comparator_symbol + '(ptr %left.pair.ptr, ptr %right.pair.ptr) {',
        'entry:',
        '  %left.item.ptr = getelementptr inbounds { ptr, i8 }, ptr %left.pair.ptr, i32 0, i32 0',
        '  %left.item = load ptr, ptr %left.item.ptr',
        '  %right.item.ptr = getelementptr inbounds { ptr, i8 }, ptr %right.pair.ptr, i32 0, i32 0',
        '  %right.item = load ptr, ptr %right.item.ptr',
        '  %cmp64 = call i64 @' + comparator_name + '(ptr %left.item, ptr %right.item)',
        '  %is.neg = icmp slt i64 %cmp64, 0',
        '  %is.pos = icmp sgt i64 %cmp64, 0',
        '  %signed = select i1 %is.neg, i32 -1, i32 0',
        '  %result = select i1 %is.pos, i32 1, i32 %signed',
        '  ret i32 %result',
        '}'
    ]

string[] emit_record_set_helpers(ProgramIR program, string record_name):
    RecordDeclIR record_decl = lookup_record_decl(program, record_name)
    BindingIR[] fields = record_field_bindings(record_decl)
    string[] contains_field_lines = []
    int field_index = 0
    while (field_index < fields.length()):
        BindingIR field = fields[field_index]
        contains_field_lines.push('  %field.left.' + field.name + ' = getelementptr inbounds %tb_bootstrap_record_' + record_name + ', ptr %item, i32 0, i32 ' + field_index)
        contains_field_lines.push('  %field.right.' + field.name + ' = getelementptr inbounds %tb_bootstrap_record_' + record_name + ', ptr %value, i32 0, i32 ' + field_index)
        string field_type = normalize_llvm_type_name(field.type_name)
        if (field_type == 'int'):
            contains_field_lines.push('  %field.left.value.' + field.name + ' = load i64, ptr %field.left.' + field.name)
            contains_field_lines.push('  %field.right.value.' + field.name + ' = load i64, ptr %field.right.' + field.name)
            contains_field_lines.push('  %field.eq.' + field.name + ' = icmp eq i64 %field.left.value.' + field.name + ', %field.right.value.' + field.name)
        else if (field_type == 'bool'):
            contains_field_lines.push('  %field.left.value.' + field.name + ' = load i1, ptr %field.left.' + field.name)
            contains_field_lines.push('  %field.right.value.' + field.name + ' = load i1, ptr %field.right.' + field.name)
            contains_field_lines.push('  %field.eq.' + field.name + ' = icmp eq i1 %field.left.value.' + field.name + ', %field.right.value.' + field.name)
        else if (field_type == 'string'):
            contains_field_lines.push('  %field.left.value.' + field.name + ' = load ptr, ptr %field.left.' + field.name)
            contains_field_lines.push('  %field.right.value.' + field.name + ' = load ptr, ptr %field.right.' + field.name)
            contains_field_lines.push('  %field.cmp.' + field.name + ' = call i32 @strcmp(ptr %field.left.value.' + field.name + ', ptr %field.right.value.' + field.name + ')')
            contains_field_lines.push('  %field.eq.' + field.name + ' = icmp eq i32 %field.cmp.' + field.name + ', 0')
        else:
            throw 'unsupported record set field type: ' + field.type_name
        field_index += 1
    string[] contains_decision_lines = []
    if (fields.is_empty()):
        contains_decision_lines.push('  br label %found')
    else:
        contains_decision_lines.push('  %all.eq.0 = and i1 %field.eq.' + fields[0].name + ', true')
        int and_index = 1
        while (and_index < fields.length()):
            contains_decision_lines.push('  %all.eq.' + and_index + ' = and i1 %all.eq.' + (and_index - 1) + ', %field.eq.' + fields[and_index].name)
            and_index += 1
        contains_decision_lines.push('  br i1 %all.eq.' + (fields.length() - 1) + ', label %found, label %loop.step')
    string[] lines = read_file('compiler/tb/llvm_helpers/record_set_base.ll').split_lines()
    lines = replace_llvm_template_lines(lines, '__RECORD__', record_name)
    lines = replace_llvm_template_block_lines(lines, '__CONTAINS_FIELD_LINES__', contains_field_lines)
    lines = replace_llvm_template_block_lines(lines, '__CONTAINS_DECISION_LINES__', contains_decision_lines)
    return lines

string[] emit_bool_array_helpers():
    return read_file('compiler/tb/llvm_helpers/bool_array.ll').split_lines()


string[] emit_int_array_array_helpers():
    return read_file('compiler/tb/llvm_helpers/int_array_array.ll').split_lines()


string[] replace_llvm_template_lines(string[] template_lines, string from_text, string to_text):
    string[] lines = []
    for (string line in template_lines):
        lines.push(line.replace(from_text, to_text))
    return lines


string[] replace_llvm_template_block_lines(string[] template_lines, string marker, string[] replacement_lines):
    string[] lines = []
    for (string line in template_lines):
        if (line == marker):
            for (string replacement_line in replacement_lines):
                lines.push(replacement_line)
        else:
            lines.push(line)
    return lines


string[] emit_record_array_helpers(string record_name):
    string[] lines = replace_llvm_template_lines(read_file('compiler/tb/llvm_helpers/record_array_base.ll').split_lines(), '__RECORD__', record_name)
    string record_array_type = llvm_record_array_type_name(record_name)
    lines.push('%tb_bootstrap_prio_q_' + record_name + ' = type { ptr, ptr }')
    lines.push('define private ptr @tb_bootstrap_record_array_sort_by_' + record_name + '(ptr %array, ptr %cmp) {')
    lines.push('entry:')
    lines.push('  %len = call i32 @tb_bootstrap_record_array_length_' + record_name + '(ptr %array)')
    lines.push('  %data.ptr = getelementptr inbounds ' + record_array_type + ', ptr %array, i32 0, i32 2')
    lines.push('  %data = load ptr, ptr %data.ptr')
    lines.push('  %owned.ptr = getelementptr inbounds ' + record_array_type + ', ptr %array, i32 0, i32 3')
    lines.push('  %owned = load ptr, ptr %owned.ptr')
    lines.push('  %len64 = sext i32 %len to i64')
    lines.push('  %pair.size.ptr = getelementptr { ptr, i8 }, ptr null, i32 1')
    lines.push('  %pair.size = ptrtoint ptr %pair.size.ptr to i64')
    lines.push('  %pairs.bytes = mul i64 %len64, %pair.size')
    lines.push('  %pairs = call ptr @malloc(i64 %pairs.bytes)')
    lines.push('  br label %copy.cond')
    lines.push('copy.cond:')
    lines.push('  %copy.i = phi i32 [0, %entry], [%copy.next.i, %copy.step]')
    lines.push('  %copy.keep = icmp slt i32 %copy.i, %len')
    lines.push('  br i1 %copy.keep, label %copy.body, label %copy.done')
    lines.push('copy.body:')
    lines.push('  %pair.slot = getelementptr inbounds { ptr, i8 }, ptr %pairs, i32 %copy.i')
    lines.push('  %pair.item.ptr = getelementptr inbounds { ptr, i8 }, ptr %pair.slot, i32 0, i32 0')
    lines.push('  %data.slot = getelementptr inbounds ptr, ptr %data, i32 %copy.i')
    lines.push('  %item = load ptr, ptr %data.slot')
    lines.push('  store ptr %item, ptr %pair.item.ptr')
    lines.push('  %pair.owned.ptr = getelementptr inbounds { ptr, i8 }, ptr %pair.slot, i32 0, i32 1')
    lines.push('  %owned.slot = getelementptr inbounds i8, ptr %owned, i32 %copy.i')
    lines.push('  %owned.value = load i8, ptr %owned.slot')
    lines.push('  store i8 %owned.value, ptr %pair.owned.ptr')
    lines.push('  br label %copy.step')
    lines.push('copy.step:')
    lines.push('  %copy.next.i = add i32 %copy.i, 1')
    lines.push('  br label %copy.cond')
    lines.push('copy.done:')
    lines.push('  call void @qsort(ptr %pairs, i64 %len64, i64 %pair.size, ptr %cmp)')
    lines.push('  br label %write.cond')
    lines.push('write.cond:')
    lines.push('  %write.i = phi i32 [0, %copy.done], [%write.next.i, %write.step]')
    lines.push('  %write.keep = icmp slt i32 %write.i, %len')
    lines.push('  br i1 %write.keep, label %write.body, label %done.sort')
    lines.push('write.body:')
    lines.push('  %write.pair.slot = getelementptr inbounds { ptr, i8 }, ptr %pairs, i32 %write.i')
    lines.push('  %write.item.ptr = getelementptr inbounds { ptr, i8 }, ptr %write.pair.slot, i32 0, i32 0')
    lines.push('  %write.item = load ptr, ptr %write.item.ptr')
    lines.push('  %write.data.slot = getelementptr inbounds ptr, ptr %data, i32 %write.i')
    lines.push('  store ptr %write.item, ptr %write.data.slot')
    lines.push('  %write.owned.ptr = getelementptr inbounds { ptr, i8 }, ptr %write.pair.slot, i32 0, i32 1')
    lines.push('  %write.owned = load i8, ptr %write.owned.ptr')
    lines.push('  %write.owned.slot = getelementptr inbounds i8, ptr %owned, i32 %write.i')
    lines.push('  store i8 %write.owned, ptr %write.owned.slot')
    lines.push('  br label %write.step')
    lines.push('write.step:')
    lines.push('  %write.next.i = add i32 %write.i, 1')
    lines.push('  br label %write.cond')
    lines.push('done.sort:')
    lines.push('  call void @free(ptr %pairs)')
    lines.push('  ret ptr %array')
    lines.push('}')
    lines.push('define private ptr @tb_bootstrap_create_prio_q_generic_' + record_name + '_by(ptr %array, ptr %cmp) {')
    lines.push('entry:')
    lines.push('  %clone = call ptr @tb_bootstrap_record_array_clone_' + record_name + '(ptr %array)')
    lines.push('  %sorted = call ptr @tb_bootstrap_record_array_sort_by_' + record_name + '(ptr %clone, ptr %cmp)')
    lines.push('  %pq = call ptr @malloc(i64 16)')
    lines.push('  %array.ptr = getelementptr inbounds %tb_bootstrap_prio_q_' + record_name + ', ptr %pq, i32 0, i32 0')
    lines.push('  %cmp.ptr = getelementptr inbounds %tb_bootstrap_prio_q_' + record_name + ', ptr %pq, i32 0, i32 1')
    lines.push('  store ptr %sorted, ptr %array.ptr')
    lines.push('  store ptr %cmp, ptr %cmp.ptr')
    lines.push('  ret ptr %pq')
    lines.push('}')
    lines.push('define private i1 @tb_bootstrap_prio_q_generic_' + record_name + '_is_empty(ptr %pq) {')
    lines.push('entry:')
    lines.push('  %array.ptr = getelementptr inbounds %tb_bootstrap_prio_q_' + record_name + ', ptr %pq, i32 0, i32 0')
    lines.push('  %array = load ptr, ptr %array.ptr')
    lines.push('  %len = call i32 @tb_bootstrap_record_array_length_' + record_name + '(ptr %array)')
    lines.push('  %empty = icmp eq i32 %len, 0')
    lines.push('  ret i1 %empty')
    lines.push('}')
    lines.push('define private i32 @tb_bootstrap_prio_q_generic_' + record_name + '_push(ptr %pq, ptr %value, i1 %is_owned) {')
    lines.push('entry:')
    lines.push('  %array.ptr = getelementptr inbounds %tb_bootstrap_prio_q_' + record_name + ', ptr %pq, i32 0, i32 0')
    lines.push('  %array = load ptr, ptr %array.ptr')
    lines.push('  %cmp.ptr = getelementptr inbounds %tb_bootstrap_prio_q_' + record_name + ', ptr %pq, i32 0, i32 1')
    lines.push('  %cmp = load ptr, ptr %cmp.ptr')
    lines.push('  %len = call i32 @tb_bootstrap_record_array_push_' + record_name + '(ptr %array, ptr %value, i1 %is_owned)')
    lines.push('  %sorted = call ptr @tb_bootstrap_record_array_sort_by_' + record_name + '(ptr %array, ptr %cmp)')
    lines.push('  ret i32 %len')
    lines.push('}')
    lines.push('define private ptr @tb_bootstrap_prio_q_generic_' + record_name + '_pop(ptr %pq) {')
    lines.push('entry:')
    lines.push('  %array.ptr = getelementptr inbounds %tb_bootstrap_prio_q_' + record_name + ', ptr %pq, i32 0, i32 0')
    lines.push('  %array = load ptr, ptr %array.ptr')
    lines.push('  %len.ptr = getelementptr inbounds ' + record_array_type + ', ptr %array, i32 0, i32 0')
    lines.push('  %len = load i32, ptr %len.ptr')
    lines.push('  %is.empty = icmp eq i32 %len, 0')
    lines.push('  br i1 %is.empty, label %empty, label %pop')
    lines.push('empty:')
    lines.push('  ret ptr null')
    lines.push('pop:')
    lines.push('  %data.ptr = getelementptr inbounds ' + record_array_type + ', ptr %array, i32 0, i32 2')
    lines.push('  %data = load ptr, ptr %data.ptr')
    lines.push('  %owned.ptr = getelementptr inbounds ' + record_array_type + ', ptr %array, i32 0, i32 3')
    lines.push('  %owned = load ptr, ptr %owned.ptr')
    lines.push('  %first.slot = getelementptr inbounds ptr, ptr %data, i32 0')
    lines.push('  %value = load ptr, ptr %first.slot')
    lines.push('  %last.index = sub i32 %len, 1')
    lines.push('  %has.tail = icmp sgt i32 %last.index, 0')
    lines.push('  br i1 %has.tail, label %loop.cond, label %shrink')
    lines.push('loop.cond:')
    lines.push('  %current = phi i32 [0, %pop], [%next.current, %loop.body]')
    lines.push('  %keep.loop = icmp slt i32 %current, %last.index')
    lines.push('  br i1 %keep.loop, label %loop.body, label %shrink')
    lines.push('loop.body:')
    lines.push('  %src = add i32 %current, 1')
    lines.push('  %src.slot = getelementptr inbounds ptr, ptr %data, i32 %src')
    lines.push('  %src.value = load ptr, ptr %src.slot')
    lines.push('  %dst.slot = getelementptr inbounds ptr, ptr %data, i32 %current')
    lines.push('  store ptr %src.value, ptr %dst.slot')
    lines.push('  %src.owned.slot = getelementptr inbounds i8, ptr %owned, i32 %src')
    lines.push('  %src.owned = load i8, ptr %src.owned.slot')
    lines.push('  %dst.owned.slot = getelementptr inbounds i8, ptr %owned, i32 %current')
    lines.push('  store i8 %src.owned, ptr %dst.owned.slot')
    lines.push('  %next.current = add i32 %current, 1')
    lines.push('  br label %loop.cond')
    lines.push('shrink:')
    lines.push('  store i32 %last.index, ptr %len.ptr')
    lines.push('  %last.slot = getelementptr inbounds ptr, ptr %data, i32 %last.index')
    lines.push('  store ptr null, ptr %last.slot')
    lines.push('  %last.owned.slot = getelementptr inbounds i8, ptr %owned, i32 %last.index')
    lines.push('  store i8 0, ptr %last.owned.slot')
    lines.push('  ret ptr %value')
    lines.push('}')
    if (record_name == 'Node'):
        for (string line in read_file('compiler/tb/llvm_helpers/record_array_node.ll').split_lines()):
            lines.push(line)
    if (record_name == 'Edge'):
        for (string line in read_file('compiler/tb/llvm_helpers/record_array_edge.ll').split_lines()):
            lines.push(line)
    return lines

string emit_map_type(string type_name):
    string key_type = normalize_llvm_type_name(map_key_type(type_name))
    if (key_type != 'string' && key_type != 'int'):
        throw 'unsupported llvm map key type: ' + key_type
    return llvm_map_type_name(type_name) + ' = type { i32, ptr, ptr, ptr }'

string[] emit_map_helpers(string type_name):
    string key_type = normalize_llvm_type_name(map_key_type(type_name))
    string value_type = normalize_llvm_type_name(map_value_type(type_name))
    if (key_type != 'string' && key_type != 'int'):
        throw 'unsupported llvm map key type: ' + key_type
    require_backend_value_type(value_type, 'map value')
    string map_struct = llvm_map_type_name(type_name)
    string value_llvm_type = llvm_type(value_type)
    string key_llvm_type = 'ptr'
    if (key_type == 'int'):
        key_llvm_type = 'i64'
    string[] lines = read_file('compiler/tb/llvm_helpers/map_base.ll').split_lines()
    lines = replace_llvm_template_lines(lines, '__MAP_NEW_NAME__', llvm_map_new_name(type_name))
    lines = replace_llvm_template_lines(lines, '__MAP_SET_NAME__', llvm_map_set_name(type_name))
    lines = replace_llvm_template_lines(lines, '__MAP_LENGTH_NAME__', llvm_map_length_name(type_name))
    lines = replace_llvm_template_lines(lines, '__MAP_GET_NAME__', llvm_map_get_name(type_name))
    lines = replace_llvm_template_lines(lines, '__MAP_SET_BY_KEY_NAME__', llvm_map_set_by_key_name(type_name))
    lines = replace_llvm_template_lines(lines, '__MAP_RELEASE_BY_KEY_NAME__', llvm_map_release_by_key_name(type_name))
    lines = replace_llvm_template_lines(lines, '__MAP_KEYS_NAME__', llvm_map_keys_name(type_name))
    lines = replace_llvm_template_lines(lines, '__MAP_VALUES_NAME__', llvm_map_values_name(type_name))
    lines = replace_llvm_template_lines(lines, '__MAP_CLONE_NAME__', llvm_map_clone_name(type_name))
    lines = replace_llvm_template_lines(lines, '__MAP_FREE_NAME__', llvm_map_free_name(type_name))
    lines = replace_llvm_template_lines(lines, '__MAP_STRUCT__', map_struct)
    lines = replace_llvm_template_lines(lines, '__VALUE_LLVM_TYPE__', value_llvm_type)
    lines = replace_llvm_template_lines(lines, '__KEY_LLVM_TYPE__', key_llvm_type)
    lines = replace_llvm_template_lines(lines, '__ZERO_VALUE__', llvm_zero_value(value_type))

    string[] key_compare_lines = ['  %key.match = icmp eq i64 %key.value, %key']
    string[] insert_key_lines = ['  store i64 %key, ptr %new.key.slot']
    string[] keys_result_lines = [
        '  %key.text = call ptr @tb_bootstrap_int_to_string(i64 %key.value)',
        '  call void @tb_bootstrap_string_array_set_owned(ptr %result, i32 %index, ptr %key.text, i1 true)'
    ]
    string[] clone_key_copy_lines = ['  %key.copy = add i64 %key.value, 0']
    string[] free_key_lines = []
    if (key_type == 'string'):
        key_compare_lines = [
            '  %cmp = call i32 @strcmp(ptr %key.value, ptr %key)',
            '  %key.match = icmp eq i32 %cmp, 0'
        ]
        insert_key_lines = [
            '  %insert.key = call ptr @tb_bootstrap_string_copy(ptr %key)',
            '  store ptr %insert.key, ptr %new.key.slot'
        ]
        keys_result_lines = [
            '  %key.copy = call ptr @tb_retain(ptr %key.value)',
            '  call void @tb_bootstrap_string_array_set_owned(ptr %result, i32 %index, ptr %key.copy, i1 true)'
        ]
        clone_key_copy_lines = ['  %key.copy = call ptr @tb_retain(ptr %key.value)']
        free_key_lines = [
            '  %key.value = load ptr, ptr %key.slot',
            '  call void @tb_release(ptr %key.value)'
        ]
    lines = replace_llvm_template_block_lines(lines, '__KEY_COMPARE_GET__', key_compare_lines)
    lines = replace_llvm_template_block_lines(lines, '__KEY_COMPARE_SET_BY_KEY__', key_compare_lines)
    lines = replace_llvm_template_block_lines(lines, '__KEY_COMPARE_RELEASE_BY_KEY__', key_compare_lines)
    lines = replace_llvm_template_block_lines(lines, '__INSERT_KEY_BLOCK__', insert_key_lines)
    lines = replace_llvm_template_block_lines(lines, '__KEYS_RESULT_BLOCK__', keys_result_lines)
    lines = replace_llvm_template_block_lines(lines, '__CLONE_KEY_COPY_BLOCK__', clone_key_copy_lines)
    lines = replace_llvm_template_block_lines(lines, '__FREE_KEY_BLOCK__', free_key_lines)

    string[] values_block_lines = [
        'define private ptr ' + llvm_map_values_name(type_name) + '(ptr %map) {',
        'entry:',
        '  ret ptr null',
        '}'
    ]
    if (value_type == 'int'):
        values_block_lines = [
            'define private ptr ' + llvm_map_values_name(type_name) + '(ptr %map) {',
            'entry:',
            '  %len = call i32 ' + llvm_map_length_name(type_name) + '(ptr %map)',
            '  %result = call ptr @tb_bootstrap_string_array_new(i32 %len)',
            '  %values.ptr = getelementptr inbounds ' + map_struct + ', ptr %map, i32 0, i32 2',
            '  %values = load ptr, ptr %values.ptr',
            '  br label %loop.cond',
            'loop.cond:',
            '  %index = phi i32 [0, %entry], [%next.index, %loop.step]',
            '  %keep.loop = icmp slt i32 %index, %len',
            '  br i1 %keep.loop, label %loop.body, label %done',
            'loop.body:',
            '  %value.slot = getelementptr inbounds ' + value_llvm_type + ', ptr %values, i32 %index',
            '  %value.raw = load ' + value_llvm_type + ', ptr %value.slot',
            '  %value.text = call ptr @tb_bootstrap_int_to_string(i64 %value.raw)',
            '  call void @tb_bootstrap_string_array_set_owned(ptr %result, i32 %index, ptr %value.text, i1 true)',
            '  br label %loop.step',
            'loop.step:',
            '  %next.index = add i32 %index, 1',
            '  br label %loop.cond',
            'done:',
            '  ret ptr %result',
            '}'
        ]
    else if (value_type == 'string'):
        values_block_lines = [
            'define private ptr ' + llvm_map_values_name(type_name) + '(ptr %map) {',
            'entry:',
            '  %len = call i32 ' + llvm_map_length_name(type_name) + '(ptr %map)',
            '  %result = call ptr @tb_bootstrap_string_array_new(i32 %len)',
            '  %values.ptr = getelementptr inbounds ' + map_struct + ', ptr %map, i32 0, i32 2',
            '  %values = load ptr, ptr %values.ptr',
            '  %owned.ptr = getelementptr inbounds ' + map_struct + ', ptr %map, i32 0, i32 3',
            '  %owned = load ptr, ptr %owned.ptr',
            '  br label %loop.cond',
            'loop.cond:',
            '  %index = phi i32 [0, %entry], [%next.index, %loop.step]',
            '  %keep.loop = icmp slt i32 %index, %len',
            '  br i1 %keep.loop, label %loop.body, label %done',
            'loop.body:',
            '  %value.slot = getelementptr inbounds ' + value_llvm_type + ', ptr %values, i32 %index',
            '  %value.raw = load ' + value_llvm_type + ', ptr %value.slot',
            '  %owned.slot = getelementptr inbounds i8, ptr %owned, i32 %index',
            '  %owned.byte = load i8, ptr %owned.slot',
            '  %value.owned = icmp ne i8 %owned.byte, 0',
            '  br i1 %value.owned, label %loop.owned, label %loop.borrowed',
            'loop.owned:',
            '  %value.copy = call ptr @tb_retain(ptr %value.raw)',
            '  call void @tb_bootstrap_string_array_set_owned(ptr %result, i32 %index, ptr %value.copy, i1 true)',
            '  br label %loop.step',
            'loop.borrowed:',
            '  call void @tb_bootstrap_string_array_set_owned(ptr %result, i32 %index, ptr %value.raw, i1 false)',
            '  br label %loop.step',
            'loop.step:',
            '  %next.index = add i32 %index, 1',
            '  br label %loop.cond',
            'done:',
            '  ret ptr %result',
            '}'
        ]
    lines = replace_llvm_template_block_lines(lines, '__VALUES_BLOCK__', values_block_lines)

    string[] clone_value_copy_lines = []
    string clone_stored_value = '%value.raw'
    string clone_stored_owned = 'false'
    if (value_type == 'string'):
        clone_value_copy_lines = [
            '  %owned.slot = getelementptr inbounds i8, ptr %owned, i32 %index',
            '  %owned.byte = load i8, ptr %owned.slot',
            '  %value.owned = icmp ne i8 %owned.byte, 0',
            '  br i1 %value.owned, label %clone.value.owned, label %clone.value.borrowed',
            'clone.value.owned:',
            '  %value.copy = call ptr @tb_retain(ptr %value.raw)',
            '  br label %clone.value.done',
            'clone.value.borrowed:',
            '  br label %clone.value.done',
            'clone.value.done:',
            '  %value.clone = phi ptr [%value.copy, %clone.value.owned], [%value.raw, %clone.value.borrowed]'
        ]
        clone_stored_value = '%value.clone'
        clone_stored_owned = '%value.owned'
    else if (value_type == 'string[]'):
        clone_value_copy_lines = ['  %value.copy = call ptr @tb_bootstrap_string_array_clone(ptr %value.raw)']
        clone_stored_value = '%value.copy'
        clone_stored_owned = 'true'
    else if (value_type.starts_with('map<')):
        clone_value_copy_lines = ['  %value.copy = call ptr ' + llvm_map_clone_name(value_type) + '(ptr %value.raw)']
        clone_stored_value = '%value.copy'
        clone_stored_owned = 'true'
    else if (record_name_from_type(value_type) != ''):
        clone_value_copy_lines = ['  %value.copy = call ptr @tb_bootstrap_record_clone_' + record_name_from_type(value_type) + '(ptr %value.raw)']
        clone_stored_value = '%value.copy'
        clone_stored_owned = 'true'
    lines = replace_llvm_template_block_lines(lines, '__CLONE_VALUE_COPY_BLOCK__', clone_value_copy_lines)
    lines = replace_llvm_template_lines(lines, '__CLONE_STORED_VALUE__', clone_stored_value)
    lines = replace_llvm_template_lines(lines, '__CLONE_STORED_OWNED__', clone_stored_owned)

    string[] value_release_lines = []
    if (is_backend_managed_type(value_type)):
        value_release_lines = ['  ' + emit_backend_release_ptr(value_type, '%value.raw').trim_left()]
    lines = replace_llvm_template_block_lines(lines, '__VALUE_RELEASE_BLOCK__', value_release_lines)

    string[] free_value_lines = ['  br label %loop.step']
    if (is_backend_managed_type(value_type)):
        free_value_lines = [
            '  %owned.slot = getelementptr inbounds i8, ptr %owned, i32 %index',
            '  %owned.byte = load i8, ptr %owned.slot',
            '  %value.owned = icmp ne i8 %owned.byte, 0',
            '  br i1 %value.owned, label %loop.free.value, label %loop.step',
            'loop.free.value:',
            '  %value.slot = getelementptr inbounds ' + value_llvm_type + ', ptr %values, i32 %index',
            '  %value.raw = load ' + value_llvm_type + ', ptr %value.slot',
            '  ' + emit_backend_release_ptr(value_type, '%value.raw').trim_left(),
            '  br label %loop.step'
        ]
    lines = replace_llvm_template_block_lines(lines, '__FREE_VALUE_BLOCK__', free_value_lines)
    return lines

string[] llvm_codegen_ir(ProgramIR program):
    if (!program.imports.is_empty()):
        throw 'llvm bootstrap backend only supports modules without imports'
    LLVM_NAMED_INT_SORT_COMPARATOR_NAMES = []
    LLVM_NAMED_RECORD_SORT_COMPARATOR_KEYS = []
    string[] lines = []
    int map_types_start_ms = time_ms()
    string[] map_types = collect_used_map_types(program)
    LLVM_PHASE_MAP_TYPES_MS += time_ms() - map_types_start_ms
    bool needs_maps = !map_types.is_empty()
    int feature_scan_start_ms = time_ms()
    analyze_program_features(program, map_types)
    LLVM_PHASE_FEATURE_SCAN_MS += time_ms() - feature_scan_start_ms
    bool needs_map_to_parse_point = LLVM_SCAN_NEEDS_MAP_TO_PARSE_POINT != 0
    bool needs_map_to_string_length = LLVM_SCAN_NEEDS_MAP_TO_STRING_LENGTH != 0
    bool needs_map_to_edge_distance = LLVM_SCAN_NEEDS_MAP_TO_EDGE_DISTANCE != 0
    bool needs_flat_map_edges_for_point = LLVM_SCAN_NEEDS_FLAT_MAP_EDGES_FOR_POINT != 0
    int record_decls_start_ms = time_ms()
    RecordDeclIR[] record_decls = effective_record_decls_for_scan(program, needs_map_to_parse_point, needs_map_to_edge_distance, needs_flat_map_edges_for_point)
    LLVM_PHASE_RECORD_DECLS_MS += time_ms() - record_decls_start_ms
    int program_cache_start_ms = time_ms()
    load_program_lookup_cache(program, record_decls)
    LLVM_PHASE_PROGRAM_CACHE_MS += time_ms() - program_cache_start_ms
    bool needs_records = !record_decls.is_empty()
    int string_constants_start_ms = time_ms()
    StringConstIR[] string_constants = collect_string_constants(program)
    LLVM_PHASE_STRING_CONSTANTS_MS += time_ms() - string_constants_start_ms
    bool needs_strcmp = LLVM_SCAN_NEEDS_STRCMP != 0
    bool needs_string_search = LLVM_SCAN_NEEDS_STRING_SEARCH != 0
    bool needs_strlen = LLVM_SCAN_NEEDS_STRLEN != 0
    bool needs_string_array = LLVM_SCAN_NEEDS_STRING_ARRAY != 0
    bool needs_string_array_array = LLVM_SCAN_NEEDS_STRING_ARRAY_ARRAY != 0
    bool needs_int_set = LLVM_SCAN_NEEDS_INT_SET != 0
    string[] record_set_types = program_record_set_types(program)
    bool needs_bool_array = LLVM_SCAN_NEEDS_BOOL_ARRAY != 0
    bool needs_prio_q_int = LLVM_SCAN_NEEDS_PRIO_Q_INT != 0
    bool needs_int_array = LLVM_SCAN_NEEDS_INT_ARRAY != 0
    bool needs_int_array_array = LLVM_SCAN_NEEDS_INT_ARRAY_ARRAY != 0
    bool needs_record_array = LLVM_SCAN_NEEDS_RECORD_ARRAY != 0
    bool needs_runtime_string_copy = LLVM_SCAN_NEEDS_RUNTIME_STRING_COPY != 0
    bool needs_backend_free = LLVM_SCAN_NEEDS_BACKEND_FREE != 0
    bool needs_main_args = LLVM_SCAN_NEEDS_MAIN_ARGS != 0
    bool needs_num = LLVM_SCAN_NEEDS_NUM != 0
    bool needs_print_int = LLVM_SCAN_NEEDS_PRINT_INT != 0
    bool needs_print_string_array = LLVM_SCAN_NEEDS_PRINT_STRING_ARRAY != 0
    bool needs_print_int_array = LLVM_SCAN_NEEDS_PRINT_INT_ARRAY != 0
    bool needs_print_bool = LLVM_SCAN_NEEDS_PRINT_BOOL != 0
    bool needs_print_num = LLVM_SCAN_NEEDS_PRINT_NUM != 0
    bool needs_print_string = LLVM_SCAN_NEEDS_PRINT_STRING != 0
    bool needs_throw = LLVM_SCAN_NEEDS_THROW != 0
    bool needs_try_catch = LLVM_SCAN_NEEDS_TRY_CATCH != 0
    bool needs_read_lines = LLVM_SCAN_NEEDS_READ_LINES != 0
    bool needs_read_file = LLVM_SCAN_NEEDS_READ_FILE != 0
    bool needs_getenv = LLVM_SCAN_NEEDS_GETENV != 0
    bool needs_time_ms = LLVM_SCAN_NEEDS_TIME_MS != 0
    bool needs_file_output = LLVM_SCAN_NEEDS_FILE_OUTPUT != 0
    bool needs_to_int = LLVM_SCAN_NEEDS_TO_INT != 0
    bool needs_int_to_string = LLVM_SCAN_NEEDS_INT_TO_STRING != 0
    bool needs_popcount = LLVM_SCAN_NEEDS_POPCOUNT != 0
    bool needs_hash = LLVM_SCAN_NEEDS_HASH != 0
    bool needs_num_hash = LLVM_SCAN_NEEDS_NUM_HASH != 0
    string[] foreign_modules = active_foreign_modules(program)
    bool needs_string_helpers = needs_runtime_string_copy || needs_to_int || needs_int_to_string || needs_hash || LLVM_SCAN_NEEDS_STRING_HELPERS_OPS != 0 || needs_read_lines || needs_read_file || needs_getenv
    bool needs_string_array_helpers = needs_string_array || needs_string_helpers
    bool needs_runtime_global_init = LLVM_SCAN_NEEDS_RUNTIME_GLOBAL_INIT != 0
    if (needs_num || needs_num_hash):
        lines.push('%tb_bootstrap_num = type { i64, i64 }')
    if (needs_num):
        lines.push('@.num.empty = private unnamed_addr constant [1 x i8] c"\\00"')
        lines.push('@.num.minus = private unnamed_addr constant [2 x i8] c"-\\00"')
        lines.push('@.fmt.num.frac = private unnamed_addr constant [15 x i8] c"%s%lld.%0*lld\\0A\\00"')
    if (needs_print_bool):
        lines.push('@.bool.true = private unnamed_addr constant [5 x i8] c"true\\00"')
        lines.push('@.bool.false = private unnamed_addr constant [6 x i8] c"false\\00"')
    if (needs_print_int || needs_print_int_array || needs_num):
        lines.push('@.fmt.int = private unnamed_addr constant [6 x i8] c"%lld\\0A\\00"')
    if (needs_int_array):
        lines.push('@.fmt.array.open = private unnamed_addr constant [2 x i8] c"[\\00"')
        lines.push('@.fmt.array.sep = private unnamed_addr constant [3 x i8] c", \\00"')
        lines.push('@.fmt.array.value = private unnamed_addr constant [5 x i8] c"%lld\\00"')
        lines.push('@.fmt.array.close = private unnamed_addr constant [3 x i8] c"]\\0A\\00"')
    if (needs_string_array_helpers):
        lines.push('@.fmt.str_array.open = private unnamed_addr constant [2 x i8] c"[\\00"')
        lines.push('@.fmt.str_array.sep = private unnamed_addr constant [3 x i8] c", \\00"')
        lines.push('@.fmt.str_array.value = private unnamed_addr constant [5 x i8] c"\'%s\'\\00"')
        lines.push('@.fmt.str_array.close = private unnamed_addr constant [3 x i8] c"]\\0A\\00"')
    if (needs_string_helpers):
        lines.push('@.fmt.int.text = private unnamed_addr constant [5 x i8] c"%lld\\00"')
    if (!string_constants.is_empty()):
        for (StringConstIR constant in string_constants):
            lines.push(emit_string_constant(constant))
    if (needs_throw || needs_try_catch || needs_read_lines || needs_read_file):
        lines.push(exception_handler_symbol() + ' = internal global ptr null')
        lines.push(exception_message_symbol() + ' = internal global ptr null')
    for (string map_type in map_types):
        lines.push(emit_map_type(map_type))
    for (RecordDeclIR record_decl in record_decls):
        lines.push(emit_record_type(record_decl))
    if (needs_string_array_helpers || needs_string_array_array || needs_bool_array || needs_int_array || needs_int_array_array || needs_record_array || needs_runtime_string_copy || needs_records || needs_maps || needs_read_lines || needs_read_file):
        lines.push('declare ptr @malloc(i64)')
        lines.push('declare void @qsort(ptr, i64, i64, ptr)')
    if (needs_try_catch):
        lines.push('declare i32 @setjmp(ptr) returns_twice')
    if (needs_throw || needs_try_catch || needs_read_lines || needs_read_file):
        lines.push('declare void @longjmp(ptr, i32) noreturn')
    if (needs_string_array_helpers || needs_string_array_array || needs_bool_array || needs_int_array || needs_int_array_array || needs_record_array || needs_backend_free || needs_records || needs_maps || needs_read_lines || needs_read_file):
        lines.push('declare void @free(ptr)')
    if (needs_print_int || needs_print_string_array || needs_print_int_array || needs_print_num || needs_num || needs_int_array || needs_int_set || needs_string_array_helpers || needs_read_lines || needs_read_file):
        lines.push('declare i32 @printf(ptr, ...)')
    if (needs_int_set):
        lines.push('declare i32 @putchar(i32)')
    if (needs_print_string || needs_print_bool || needs_throw):
        lines.push('declare i32 @puts(ptr)')
    if (needs_throw || needs_read_lines || needs_read_file):
        lines.push('declare void @exit(i32)')
    if (needs_strcmp || needs_string_search || needs_string_array_helpers):
        lines.push('declare i32 @strcmp(ptr, ptr)')
    if (needs_strlen || needs_runtime_string_copy || needs_read_lines || needs_read_file || needs_string_helpers):
        lines.push('declare i64 @strlen(ptr)')
    if (needs_getenv):
        lines.push('declare ptr @getenv(ptr)')
    if (needs_string_helpers):
        lines.push('declare ptr @strstr(ptr, ptr)')
    if (needs_string_helpers):
        lines.push('declare i64 @strtoll(ptr, ptr, i32)')
    if (needs_string_helpers):
        lines.push('declare i32 @snprintf(ptr, i64, ptr, ...)')
    if (needs_popcount):
        lines.push('declare i64 @llvm.ctpop.i64(i64)')
    if (needs_num):
        lines.push('declare double @llvm.sqrt.f64(double)')
        lines.push('declare double @llvm.round.f64(double)')
    if (needs_runtime_string_copy || needs_string_array_array || needs_bool_array || needs_int_array_array || needs_int_array || needs_string_helpers):
        lines.push('declare void @llvm.memcpy.p0.p0.i64(ptr, ptr, i64, i1)')
    if (needs_string_array_helpers || needs_string_array_array || needs_bool_array || needs_int_array || needs_int_array_array || needs_record_array || needs_maps || needs_read_lines):
        lines.push('declare void @llvm.memset.p0.i64(ptr, i8, i64, i1)')
    if (needs_read_lines || needs_read_file || needs_file_output):
        lines.push('declare ptr @fopen(ptr, ptr)')
    if (needs_time_ms):
        lines.push('declare i32 @gettimeofday(ptr, ptr)')
    if (needs_file_output):
        lines.push('declare i32 @fputs(ptr, ptr)')
        lines.push('declare i32 @fputc(i32, ptr)')
    if (needs_read_lines || needs_read_file || needs_file_output):
        lines.push('declare i32 @fclose(ptr)')
    if (needs_read_lines):
        lines.push('declare void @rewind(ptr)')
    if (needs_read_lines || needs_read_file):
        lines.push('declare i64 @getline(ptr, ptr, ptr)')
    for (string declaration in foreign_module_llvm_declarations(foreign_modules)):
        lines.push(declaration)
    int helpers_start_ms = 0
    if (LLVM_BACKEND_PROFILE_ACTIVE != 0):
        helpers_start_ms = time_ms()
    if (needs_num):
        for (string helper in emit_num_helpers()):
            lines.push(helper)
    if (needs_string_helpers):
        for (string helper in emit_string_helpers(needs_num_hash)):
            lines.push(helper)
    if (needs_string_array_helpers):
        for (string helper in emit_string_array_helpers()):
            lines.push(helper)
    if (needs_string_array_array):
        for (string helper in emit_string_array_array_helpers()):
            lines.push(helper)
    if (needs_bool_array):
        for (string helper in emit_bool_array_helpers()):
            lines.push(helper)
    if (needs_int_array):
        for (string helper in emit_int_array_helpers()):
            lines.push(helper)
    if (needs_int_set):
        for (string helper in emit_int_set_helpers()):
            lines.push(helper)
    for (string record_name in record_set_types):
        for (string helper in emit_record_set_helpers(program, record_name)):
            lines.push(helper)
    if (needs_int_array_array):
        for (string helper in emit_int_array_array_helpers()):
            lines.push(helper)
    if (needs_record_array):
        for (RecordDeclIR record_decl in record_decls):
            for (string helper in emit_record_array_helpers(strip_prefix(record_decl.header, 'record '))):
                lines.push(helper)
    else if (!record_set_types.is_empty()):
        for (string record_name in record_set_types):
            for (string helper in emit_record_array_helpers(record_name)):
                lines.push(helper)
    if (needs_map_to_string_length):
        for (string helper in emit_string_length_map_helper()):
            lines.push(helper)
    if (needs_map_to_parse_point):
        for (string helper in emit_map_to_parse_point_helper()):
            lines.push(helper)
    if (needs_map_to_edge_distance):
        for (string helper in emit_map_to_edge_distance_helper()):
            lines.push(helper)
    if (needs_flat_map_edges_for_point):
        for (string helper in emit_flat_map_edges_for_point_helper()):
            lines.push(helper)
    if (needs_read_lines):
        for (string helper in emit_read_lines_helper()):
            lines.push(helper)
    if (needs_read_file):
        for (string helper in emit_read_file_helper()):
            lines.push(helper)
    if (needs_getenv):
        for (string helper in emit_getenv_helper()):
            lines.push(helper)
    if (needs_time_ms):
        for (string helper in emit_time_ms_helper()):
            lines.push(helper)
    if (needs_file_output):
        for (string helper in emit_file_output_helpers()):
            lines.push(helper)
    if (needs_main_args):
        for (string helper in emit_main_args_helpers()):
            lines.push(helper)
    for (string map_type in map_types):
        for (string helper in emit_map_helpers(map_type)):
            lines.push(helper)
    for (RecordDeclIR record_decl in record_decls):
        for (string helper in emit_record_helpers(record_decl)):
            lines.push(helper)
    if (LLVM_BACKEND_PROFILE_ACTIVE != 0):
        LLVM_PHASE_HELPERS_MS += time_ms() - helpers_start_ms
    if ((!string_constants.is_empty() || needs_maps || !record_decls.is_empty() || needs_strcmp || needs_strlen || needs_runtime_string_copy || needs_string_array || needs_string_array_array || needs_record_array) && (!program.globals.is_empty() || !program.functions.is_empty())):
        lines.push('')
    for (GlobalDeclIR global_decl in program.globals):
        int global_start_ms = 0
        if (LLVM_BACKEND_PROFILE_ACTIVE != 0):
            global_start_ms = time_ms()
        for (string line in emit_global_lines(program, global_decl)):
            lines.push(line)
        if (LLVM_BACKEND_PROFILE_ACTIVE != 0):
            LLVM_PHASE_GLOBAL_MS += time_ms() - global_start_ms
            LLVM_PHASE_GLOBAL_COUNT += 1
    for (ParsedFunction function_ir in program.functions):
        if (is_cached_function_header(function_ir.header) && supports_cached_function_backend(program, function_ir)):
            int cached_global_start_ms = 0
            if (LLVM_BACKEND_PROFILE_ACTIVE != 0):
                cached_global_start_ms = time_ms()
            for (string line in emit_cached_function_globals(program, function_ir)):
                lines.push(line)
            if (LLVM_BACKEND_PROFILE_ACTIVE != 0):
                LLVM_PHASE_CACHED_GLOBAL_MS += time_ms() - cached_global_start_ms
                LLVM_PHASE_CACHED_GLOBAL_COUNT += 1
    if (needs_runtime_global_init):
        int global_init_helper_start_ms = 0
        if (LLVM_BACKEND_PROFILE_ACTIVE != 0):
            global_init_helper_start_ms = time_ms()
        for (string line in emit_global_init_helper(program)):
            lines.push(line)
        if (LLVM_BACKEND_PROFILE_ACTIVE != 0):
            LLVM_PHASE_GLOBAL_INIT_HELPER_MS += time_ms() - global_init_helper_start_ms
    if (!program.globals.is_empty() && !program.functions.is_empty()):
        lines.push('')
    for (ParsedFunction function_ir in program.functions):
        int function_start_ms = 0
        if (LLVM_BACKEND_PROFILE_ACTIVE != 0):
            function_start_ms = time_ms()
        append_function_lines(lines, program, function_ir, needs_runtime_global_init)
        lines.push('')
        if (LLVM_BACKEND_PROFILE_ACTIVE != 0):
            LLVM_PHASE_FUNCTION_MS += time_ms() - function_start_ms
            LLVM_PHASE_FUNCTION_COUNT += 1
    for (string comparator_name in LLVM_NAMED_INT_SORT_COMPARATOR_NAMES):
        for (string helper in emit_named_int_sort_helper(comparator_name)):
            lines.push(helper)
        lines.push('')
    for (string key in LLVM_NAMED_RECORD_SORT_COMPARATOR_KEYS):
        int split = key.index_of('|')
        string record_name = key.substring(0, split)
        string comparator_name = key.substring(split + 1)
        for (string helper in emit_named_record_sort_helper(record_name, comparator_name)):
            lines.push(helper)
        lines.push('')
    string[] detached = []
    for (string line in lines):
        detached.push(line.substring(0))
    return detached

void print_llvm_lines(string[] lines):
    string[] copied = []
    for (string line in lines):
        copied.push(line)
    for (string line in copied):
        print(line)

void llvm_print_ir(ProgramIR program):
    if (!program.imports.is_empty()):
        throw 'llvm bootstrap backend only supports modules without imports'
    LLVM_NAMED_INT_SORT_COMPARATOR_NAMES = []
    LLVM_NAMED_RECORD_SORT_COMPARATOR_KEYS = []
    string[] map_types = collect_used_map_types(program)
    bool needs_maps = !map_types.is_empty()
