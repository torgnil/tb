void prepare_call_llvm_metadata(ProgramIR program):
    LLVM_CALL_META_NAMES = []
    LLVM_CALL_META_RETURN_TYPES = []
    LLVM_CALL_META_RETURN_LLVM_TYPES = []
    LLVM_CALL_META_PARAM_COUNTS = []
    LLVM_CALL_META_PARAM_OFFSETS = []
    LLVM_CALL_META_PARAM_LLVM_TYPES = []
    LLVM_CALL_META_INDEX_CACHE_NAMES = []
    LLVM_CALL_META_INDEX_CACHE_VALUES = []
    int offset = 0
    for (ParsedFunction function_ir in program.functions):
        LLVM_CALL_META_NAMES.push(function_ir.name.substring(0))
        LLVM_CALL_META_RETURN_TYPES.push(function_ir.return_type.substring(0))
        LLVM_CALL_META_RETURN_LLVM_TYPES.push(llvm_type(function_ir.return_type))
        LLVM_CALL_META_PARAM_COUNTS.push(function_ir.params.length())
        LLVM_CALL_META_PARAM_OFFSETS.push(offset)
        for (BindingIR param_decl in function_ir.params):
            LLVM_CALL_META_PARAM_LLVM_TYPES.push(llvm_type(param_decl.type_name))
            offset += 1
    for (string module_name in active_foreign_modules(program)):
        for (string declaration in foreign_module_llvm_declarations([module_name])):
            string symbol_name = foreign_symbol_name_from_llvm_declaration(declaration)
            string return_type = foreign_function_return_type(symbol_name)
            string[] param_types = foreign_function_param_types(symbol_name)
            LLVM_CALL_META_NAMES.push(symbol_name)
            LLVM_CALL_META_RETURN_TYPES.push(return_type)
            LLVM_CALL_META_RETURN_LLVM_TYPES.push(llvm_type(return_type))
            LLVM_CALL_META_PARAM_COUNTS.push(param_types.length())
            LLVM_CALL_META_PARAM_OFFSETS.push(offset)
            for (string param_type in param_types):
                LLVM_CALL_META_PARAM_LLVM_TYPES.push(llvm_type(param_type))
                offset += 1

int lookup_call_meta_index(string name):
    int cache_index = LLVM_CALL_META_INDEX_CACHE_NAMES.length() - 1
    while (cache_index >= 0):
        if (LLVM_CALL_META_INDEX_CACHE_NAMES[cache_index] == name):
            return LLVM_CALL_META_INDEX_CACHE_VALUES[cache_index]
        cache_index -= 1
    int index = 0
    while (index < LLVM_CALL_META_NAMES.length()):
        if (LLVM_CALL_META_NAMES[index] == name):
            LLVM_CALL_META_INDEX_CACHE_NAMES.push(name.substring(0))
            LLVM_CALL_META_INDEX_CACHE_VALUES.push(index)
            return index
        index += 1
    LLVM_CALL_META_INDEX_CACHE_NAMES.push(name.substring(0))
    LLVM_CALL_META_INDEX_CACHE_VALUES.push(-1)
    return -1

string lookup_call_meta_return_type(int index):
    if (index < 0 || index >= LLVM_CALL_META_RETURN_TYPES.length()):
        return ''
    return LLVM_CALL_META_RETURN_TYPES[index]

string lookup_call_meta_return_llvm_type(int index):
    if (index < 0 || index >= LLVM_CALL_META_RETURN_LLVM_TYPES.length()):
        return ''
    return LLVM_CALL_META_RETURN_LLVM_TYPES[index]

int lookup_call_meta_param_count(int index):
    if (index < 0 || index >= LLVM_CALL_META_PARAM_COUNTS.length()):
        return 0
    return LLVM_CALL_META_PARAM_COUNTS[index]

string lookup_call_meta_param_llvm_type(int function_index, int param_index):
    if (function_index < 0 || function_index >= LLVM_CALL_META_PARAM_COUNTS.length()):
        return ''
    if (param_index < 0 || param_index >= LLVM_CALL_META_PARAM_COUNTS[function_index]):
        return ''
    int flat_index = LLVM_CALL_META_PARAM_OFFSETS[function_index] + param_index
    return LLVM_CALL_META_PARAM_LLVM_TYPES[flat_index]

string foreign_symbol_name_from_llvm_declaration(string declaration):
    int at_index = declaration.index_of('@')
    if (at_index < 0):
        return ''
    int end_index = at_index + 1
    while (end_index < declaration.length() && declaration[end_index] != '('):
        end_index += 1
    return declaration.substring(at_index + 1, end_index)

bool program_uses_foreign_symbol_prefix(ProgramIR program, string prefix):
    for (GlobalDeclIR global_decl in program.globals):
        BindingIR binding = ir_parse_binding_decl(strip_prefix(global_decl.header, 'global '))
        if (binding.name.starts_with(prefix)):
            return true
    for (ParsedFunction function_ir in program.functions):
        for (BlockIR block in function_ir.blocks):
            for (LinearInstruction op in block.instructions):
                if (op.kind == 'value' && op.detail == 'call'):
                    if (!op.args.is_empty() && op.args[0].starts_with(prefix)):
                        return true
    return false

string[] active_foreign_modules(ProgramIR program):
    string[] modules = []
    if (program_uses_foreign_symbol_prefix(program, '__tb_foreign_raylib_')):
        modules.push('raylib')
    return modules

string strip_cached_prefix_local(string header):
    if (header.starts_with('cached ')):
        return header.substring(7)
    return header


string llvm_type(string type_name):
    if (LLVM_BACKEND_PROFILE_ACTIVE != 0):
        LLVM_TYPE_CALLS += 1
    type_name = normalize_llvm_type_name(type_name)
    if (type_name == 'void'):
        return 'void'
    if (type_name == 'int'):
        return 'i64'
    if (type_name == 'bool'):
        return 'i1'
    if (type_name == 'num'):
        return '%tb_bootstrap_num'
    if (type_name == 'string'):
        return 'ptr'
    if (type_name == 'file'):
        return 'ptr'
    if (type_name == 'int[][]'):
        return 'ptr'
    if (type_name == 'string[][]'):
        return 'ptr'
    if (type_name == 'string[]'):
        return 'ptr'
    if (type_name == 'bool[]'):
        return 'ptr'
    if (type_name == 'int[]'):
        return 'ptr'
    if (type_name.starts_with('set<')):
        return 'ptr'
    if (type_name.starts_with('prio_q<')):
        return 'ptr'
    if (type_name.ends_with('[]') && record_name_from_type(array_item_type(type_name)) != ''):
        return 'ptr'
    if (type_name.starts_with('map<')):
        return 'ptr'
    if (record_name_from_type(type_name) != ''):
        return 'ptr'
    throw 'unsupported llvm type: ' + type_name

bool is_scalar_type(string type_name):
    type_name = normalize_llvm_type_name(type_name)
    return type_name == 'int' || type_name == 'bool' || type_name == 'num' || type_name == 'string'

bool is_backend_value_type(string type_name):
    type_name = normalize_llvm_type_name(type_name)
    return type_name == 'void' || type_name == 'int' || type_name == 'bool' || type_name == 'num' || type_name == 'string' || type_name == 'file' || type_name == 'string[]' || type_name == 'string[][]' || type_name == 'bool[]' || type_name == 'int[]' || type_name == 'int[][]' || type_name.starts_with('set<') || type_name.starts_with('prio_q<') || (type_name.ends_with('[]') && record_name_from_type(array_item_type(type_name)) != '') || type_name.starts_with('map<') || record_name_from_type(type_name) != ''

string function_name_from_header_local(string header):
    string signature = strip_prefix(strip_cached_prefix_local(header), 'func ')
    int split = ir_last_space_index(signature)
    if (split < 0):
        return signature
    return signature.substring(split + 1)

string function_return_type_from_header_local(string header):
    string signature = strip_prefix(strip_cached_prefix_local(header), 'func ')
    int split = ir_last_space_index(signature)
    if (split < 0):
        return ''
    return signature.substring(0, split)

string temp_ref(string name):
    if (LLVM_BACKEND_PROFILE_ACTIVE != 0):
        LLVM_TEMP_REF_CALLS += 1
        LLVM_TEMP_REF_INPUT_BYTES += name.length()
        LLVM_TEMP_REF_OUTPUT_BYTES += name.length() + 1
        if (LLVM_PROFILE_VALUE_FAMILY == 'call'):
            LLVM_TEMP_REF_CALLS_CALL += 1
        else if (LLVM_PROFILE_VALUE_FAMILY == 'method'):
            LLVM_TEMP_REF_CALLS_METHOD += 1
        else if (LLVM_PROFILE_VALUE_FAMILY == 'index'):
            LLVM_TEMP_REF_CALLS_INDEX += 1
        else if (LLVM_PROFILE_VALUE_FAMILY == 'slice'):
            LLVM_TEMP_REF_CALLS_SLICE += 1
        else if (LLVM_PROFILE_VALUE_FAMILY == 'binary'):
            LLVM_TEMP_REF_CALLS_BINARY += 1
        else if (LLVM_PROFILE_VALUE_FAMILY == 'other'):
            LLVM_TEMP_REF_CALLS_OTHER += 1
    return '%' + name

string slot_ref(string name):
    return '%' + name + '.slot'

string owned_slot_ref(string name):
    return '%' + name + '.owned.slot'

string param_ref(string name):
    return '%' + name + '.param'

string global_ref(string name):
    return '@' + name

string string_symbol_ref(string name):
    return '@' + name

bool is_bootstrap_c_main(ParsedFunction function_ir):
    string function_name = function_ir.name
    if (function_name != 'main'):
        return false
    if (function_ir.params.is_empty()):
        return true
    if (function_ir.params.length() != 1):
        return false
    return normalize_llvm_type_name(function_ir.params[0].type_name) == 'string[]'

bool is_cached_function_header(string header):
    return header.starts_with('cached func ')

string lookup_cache_temp_name(string name):
    if (name.starts_with('%')):
        return name.substring(1)
    return name

LinearInstruction[] flatten_function_instructions(ParsedFunction function_ir):
    LinearInstruction[] instructions = []
    for (BlockIR block in function_ir.blocks):
        for (LinearInstruction op in block.instructions):
            instructions.push(op)
    return instructions

void ensure_function_lookup_cache(ParsedFunction function_ir):
    string cache_key = function_ir.header
    if (LLVM_LOOKUP_CACHE_FUNCTION_KEY == cache_key):
        return
    LLVM_LOOKUP_CACHE_FUNCTION_KEY = cache_key.substring(0)
    LLVM_LOOKUP_CACHE_FLAT_INSTRUCTIONS = []
    LLVM_LOOKUP_CACHE_TEMP_TYPE_SLOTS = []
    LLVM_LOOKUP_CACHE_INSTRUCTION_POSITIONS = []
    LLVM_LOOKUP_CACHE_BINDING_NAMES = []
    LLVM_LOOKUP_CACHE_BINDING_TYPES = []
    LLVM_LOOKUP_CACHE_LOCAL_BINDING_NAMES = []
    LLVM_LOOKUP_CACHE_LOCAL_BINDING_TYPES = []
    for (BindingIR param_decl in function_ir.params):
        LLVM_LOOKUP_CACHE_BINDING_NAMES.push(param_decl.name.substring(0))
        LLVM_LOOKUP_CACHE_BINDING_TYPES.push(param_decl.type_name.substring(0))
    for (BindingIR local_decl in function_ir.locals):
        LLVM_LOOKUP_CACHE_BINDING_NAMES.push(local_decl.name.substring(0))
        LLVM_LOOKUP_CACHE_BINDING_TYPES.push(local_decl.type_name.substring(0))
        LLVM_LOOKUP_CACHE_LOCAL_BINDING_NAMES.push(local_decl.name.substring(0))
        LLVM_LOOKUP_CACHE_LOCAL_BINDING_TYPES.push(local_decl.type_name.substring(0))
    int position = 0
    for (BlockIR block in function_ir.blocks):
        for (LinearInstruction op in block.instructions):
            LLVM_LOOKUP_CACHE_FLAT_INSTRUCTIONS.push(op)
            if (op.lhs != ''):
                LLVM_LOOKUP_CACHE_TEMP_TYPE_SLOTS = set_temp_type_slot(LLVM_LOOKUP_CACHE_TEMP_TYPE_SLOTS, op.lhs, op.result_type)
                int slot_index = temp_slot_index(op.lhs)
                if (slot_index >= 0):
                    while (LLVM_LOOKUP_CACHE_INSTRUCTION_POSITIONS.length() <= slot_index):
                        LLVM_LOOKUP_CACHE_INSTRUCTION_POSITIONS.push(-1)
                    if (LLVM_LOOKUP_CACHE_INSTRUCTION_POSITIONS[slot_index] < 0):
                        LLVM_LOOKUP_CACHE_INSTRUCTION_POSITIONS[slot_index] = position
            position += 1

BindingIR lookup_named_binding(ParsedFunction function_ir, string name):
    if (LLVM_BACKEND_PROFILE_ACTIVE != 0):
        LLVM_LOOKUP_NAMED_BINDING_CALLS += 1
    ensure_function_lookup_cache(function_ir)
    int name_length = name.length()
    int index = LLVM_LOOKUP_CACHE_BINDING_NAMES.length() - 1
    while (index >= 0):
        if (LLVM_BACKEND_PROFILE_ACTIVE != 0):
            LLVM_LOOKUP_NAMED_BINDING_SCAN_TOTAL += 1
        if (LLVM_LOOKUP_CACHE_BINDING_NAMES[index].length() == name_length && LLVM_LOOKUP_CACHE_BINDING_NAMES[index] == name):
            return BindingIR(LLVM_LOOKUP_CACHE_BINDING_TYPES[index], LLVM_LOOKUP_CACHE_BINDING_NAMES[index])
        index -= 1
    return BindingIR('', '')

BindingIR lookup_named_local_binding(ParsedFunction function_ir, string name):
    if (LLVM_BACKEND_PROFILE_ACTIVE != 0):
        LLVM_LOOKUP_NAMED_LOCAL_BINDING_CALLS += 1
    ensure_function_lookup_cache(function_ir)
    int name_length = name.length()
    int index = LLVM_LOOKUP_CACHE_LOCAL_BINDING_NAMES.length() - 1
    while (index >= 0):
        if (LLVM_BACKEND_PROFILE_ACTIVE != 0):
            LLVM_LOOKUP_NAMED_LOCAL_BINDING_SCAN_TOTAL += 1
        if (LLVM_LOOKUP_CACHE_LOCAL_BINDING_NAMES[index].length() == name_length && LLVM_LOOKUP_CACHE_LOCAL_BINDING_NAMES[index] == name):
            return BindingIR(LLVM_LOOKUP_CACHE_LOCAL_BINDING_TYPES[index], LLVM_LOOKUP_CACHE_LOCAL_BINDING_NAMES[index])
        index -= 1
    return BindingIR('', '')

string transferable_local_binding_name(ParsedFunction function_ir, string temp_name):
    LinearInstruction op = lookup_temp_instruction(function_ir, temp_name)
    if (op.kind == 'value' && op.detail == 'identifier' && !op.args.is_empty()):
        BindingIR local_decl = lookup_named_local_binding(function_ir, op.args[0])
        if (local_decl.name != '' && is_backend_managed_type(local_decl.type_name)):
            return local_decl.name.substring(0)
    return ''

string emit_string_array_release_ptr(string ptr_name):
    return '  call void @tb_bootstrap_string_array_free(ptr ' + ptr_name + ')'

string emit_string_release_ptr(string ptr_name):
    return '  call void @tb_release(ptr ' + ptr_name + ')'

void load_program_lookup_cache(ProgramIR program, RecordDeclIR[] record_decls):
    LLVM_PROGRAM_CACHE_GLOBAL_NAMES = []
    LLVM_PROGRAM_CACHE_GLOBAL_TYPES = []
    LLVM_PROGRAM_CACHE_FUNCTION_NAMES = []
    LLVM_PROGRAM_CACHE_RECORD_NAMES = []
    LLVM_PROGRAM_CACHE_RECORD_DECLS = []
    for (GlobalDeclIR global_decl in program.globals):
        BindingIR binding = ir_parse_binding_decl(strip_prefix(global_decl.header, 'global '))
        LLVM_PROGRAM_CACHE_GLOBAL_NAMES.push(binding.name.substring(0))
        LLVM_PROGRAM_CACHE_GLOBAL_TYPES.push(binding.type_name.substring(0))
    for (ParsedFunction function_ir in program.functions):
        LLVM_PROGRAM_CACHE_FUNCTION_NAMES.push(function_ir.name.substring(0))
    for (RecordDeclIR record_decl in record_decls):
        string record_name = strip_prefix(record_decl.header, 'record ')
        LLVM_PROGRAM_CACHE_RECORD_NAMES.push(record_name.substring(0))
        LLVM_PROGRAM_CACHE_RECORD_DECLS.push(record_decl)

BindingIR lookup_named_global(ProgramIR program, string name):
    int name_length = name.length()
    int index = LLVM_PROGRAM_CACHE_GLOBAL_NAMES.length() - 1
    while (index >= 0):
        if (LLVM_PROGRAM_CACHE_GLOBAL_NAMES[index].length() == name_length && LLVM_PROGRAM_CACHE_GLOBAL_NAMES[index] == name):
            return BindingIR(LLVM_PROGRAM_CACHE_GLOBAL_TYPES[index], LLVM_PROGRAM_CACHE_GLOBAL_NAMES[index])
        index -= 1
    return BindingIR('', '')

string try_prev_slot_ref(string temp_suffix):
    return '%tb.exc.prev.slot.' + temp_suffix

string try_env_ref(string temp_suffix):
    return '%tb.exc.env.' + temp_suffix

string try_env_ptr_ref(string temp_suffix):
    return '%tb.exc.env.ptr.' + temp_suffix

string try_continue_label(string temp_suffix):
    return 'tb.try.cont.' + temp_suffix

string exception_handler_symbol():
    return '@__tb_exception_handler'

string exception_message_symbol():
    return '@__tb_exception_message'

string block_try_suffix(BlockIR block):
    int instruction_index = 0
    for (LinearInstruction op in block.instructions):
        if (op.kind == 'try'):
            return block.label + '.' + instruction_index
        instruction_index += 1
    return ''

string catch_try_suffix(ParsedFunction function_ir, string catch_label):
    for (BlockIR block in function_ir.blocks):
        int instruction_index = 0
        for (LinearInstruction op in block.instructions):
            if (op.kind == 'try' && op.detail == catch_label):
                return block.label + '.' + instruction_index
            instruction_index += 1
    return ''

string[] emit_try_restore_lines(string try_suffix, string temp_suffix):
    if (try_suffix == ''):
        string[] empty = []
        return empty
    return [
        '  %tb.exc.prev.restore.' + temp_suffix + ' = load ptr, ptr ' + try_prev_slot_ref(try_suffix),
        '  store ptr %tb.exc.prev.restore.' + temp_suffix + ', ptr ' + exception_handler_symbol()
    ]

int block_index_by_label(ParsedFunction function_ir, string label):
    int block_index = 0
    while (block_index < function_ir.blocks.length()):
        if (function_ir.blocks[block_index].label == label):
            return block_index
        block_index += 1
    return -1

int enclosing_try_catch_block_index(ParsedFunction function_ir, string block_label):
    int block_index = block_index_by_label(function_ir, block_label)
    if (block_index < 0):
        return -1
    int best_try_block_index = -1
    int best_catch_block_index = -1
    int scan_block_index = 0
    while (scan_block_index <= block_index):
        BlockIR block = function_ir.blocks[scan_block_index]
        int instruction_index = 0
        for (LinearInstruction op in block.instructions):
            if (op.kind == 'try'):
                int catch_block_index = block_index_by_label(function_ir, op.detail)
                if (catch_block_index > block_index && scan_block_index >= best_try_block_index):
                    best_try_block_index = scan_block_index
                    best_catch_block_index = catch_block_index
            instruction_index += 1
        scan_block_index += 1
    return best_catch_block_index

string enclosing_try_suffix(ParsedFunction function_ir, string block_label):
    int catch_block_index = enclosing_try_catch_block_index(function_ir, block_label)
    if (catch_block_index < 0):
        return ''
    return catch_try_suffix(function_ir, function_ir.blocks[catch_block_index].label)

string lookup_temp_llvm_type_uncached(ParsedFunction function_ir, string lookup_name):
    if (LLVM_BACKEND_PROFILE_ACTIVE != 0):
        LLVM_LOOKUP_TEMP_TYPE_UNCACHED_CALLS += 1
    string result_type = 'unknown'
    for (BlockIR block in function_ir.blocks):
        for (LinearInstruction op in block.instructions):
            if (LLVM_BACKEND_PROFILE_ACTIVE != 0):
                LLVM_LOOKUP_TEMP_TYPE_UNCACHED_SCAN_TOTAL += 1
            if (result_type == 'unknown' && op.lhs == lookup_name):
                result_type = op.result_type
    if (result_type == '[]'):
        if (LLVM_BACKEND_PROFILE_ACTIVE != 0):
            LLVM_LOOKUP_TEMP_TYPE_ARRAY_FALLBACK_CALLS += 1
        bool found_def = false
        for (BlockIR block in function_ir.blocks):
            int index = 0
            while (index < block.instructions.length()):
                LinearInstruction op = block.instructions[index]
                if (LLVM_BACKEND_PROFILE_ACTIVE != 0):
                    LLVM_LOOKUP_TEMP_TYPE_UNCACHED_SCAN_TOTAL += 1
                if (!found_def):
                    if (op.lhs == lookup_name):
                        found_def = true
                    index += 1
                    continue
                if (op.kind == 'move_temp' && op.detail.ends_with('[]')):
                    return op.detail
                if (op.kind == 'set'):
                    BindingIR binding = ir_parse_binding_decl(op.detail)
                    if (binding.type_name.ends_with('[]')):
                        return binding.type_name
                if (op.kind == 'assign_local'):
                    BindingIR binding = lookup_named_binding(function_ir, op.detail)
                    if (binding.type_name.ends_with('[]')):
                        return binding.type_name
                if (op.kind == 'return' || op.kind == 'return_owned'):
                    return result_type
                index += 1
        for (BlockIR block in function_ir.blocks):
            for (LinearInstruction op in block.instructions):
                if (LLVM_BACKEND_PROFILE_ACTIVE != 0):
                    LLVM_LOOKUP_TEMP_TYPE_UNCACHED_SCAN_TOTAL += 1
                if (op.args.length() == 1):
                    if (op.args[0] == lookup_name):
                        if (op.kind == 'move_temp'):
                            if (op.detail.ends_with('[]')):
                                return op.detail
                        if (op.kind == 'set'):
                            BindingIR binding = ir_parse_binding_decl(op.detail)
                            if (binding.type_name.ends_with('[]')):
                                return binding.type_name
                        if (op.kind == 'assign_local'):
                            BindingIR binding = lookup_named_binding(function_ir, op.detail)
                            if (binding.type_name.ends_with('[]')):
                                return binding.type_name
                        if (op.kind == 'return' || op.kind == 'return_owned'):
                            return result_type
    return result_type

string lookup_temp_llvm_type(ParsedFunction function_ir, string temp_name):
    if (LLVM_BACKEND_PROFILE_ACTIVE != 0):
        LLVM_LOOKUP_TEMP_TYPE_CALLS += 1
    string lookup_name = lookup_cache_temp_name(temp_name)
    ensure_function_lookup_cache(function_ir)
    string cached_type = lookup_temp_type_slot(LLVM_LOOKUP_CACHE_TEMP_TYPE_SLOTS, lookup_name)
    if (cached_type != 'unknown' && cached_type != '[]'):
        return cached_type
    string result_type = lookup_temp_llvm_type_uncached(function_ir, lookup_name)
    if (result_type != 'unknown'):
        LLVM_LOOKUP_CACHE_TEMP_TYPE_SLOTS = set_temp_type_slot(LLVM_LOOKUP_CACHE_TEMP_TYPE_SLOTS, lookup_name, result_type)
    return result_type

LinearInstruction lookup_temp_instruction(ParsedFunction function_ir, string temp_name):
    if (LLVM_BACKEND_PROFILE_ACTIVE != 0):
        LLVM_LOOKUP_TEMP_INSTRUCTION_CALLS += 1
    string lookup_name = lookup_cache_temp_name(temp_name)
    ensure_function_lookup_cache(function_ir)
    int position = lookup_temp_instruction_slot(LLVM_LOOKUP_CACHE_INSTRUCTION_POSITIONS, lookup_name)
    if (position >= 0 && position < LLVM_LOOKUP_CACHE_FLAT_INSTRUCTIONS.length()):
        if (LLVM_BACKEND_PROFILE_ACTIVE != 0):
            LLVM_LOOKUP_TEMP_INSTRUCTION_SLOT_HITS += 1
        return LLVM_LOOKUP_CACHE_FLAT_INSTRUCTIONS[position]
    if (LLVM_BACKEND_PROFILE_ACTIVE != 0):
        LLVM_LOOKUP_TEMP_INSTRUCTION_FALLBACK_SCANS += 1
    int index = 0
    while (index < LLVM_LOOKUP_CACHE_FLAT_INSTRUCTIONS.length()):
        if (LLVM_LOOKUP_CACHE_FLAT_INSTRUCTIONS[index].lhs == lookup_name):
            return LLVM_LOOKUP_CACHE_FLAT_INSTRUCTIONS[index]
        index += 1
    if (LLVM_BACKEND_PROFILE_ACTIVE != 0):
        LLVM_LOOKUP_TEMP_INSTRUCTION_MISSES += 1
    return LinearInstruction('', '', '', '', '', [])

ParsedFunction lookup_named_function_decl(ProgramIR program, string name):
    for (ParsedFunction function_ir in program.functions):
        if (function_ir.name == name):
            return function_ir
    return ParsedFunction('', '', '', [], [], [])

bool function_name_exists(ProgramIR program, string name):
    int name_length = name.length()
    int index = LLVM_PROGRAM_CACHE_FUNCTION_NAMES.length() - 1
    while (index >= 0):
        if (LLVM_PROGRAM_CACHE_FUNCTION_NAMES[index].length() == name_length && LLVM_PROGRAM_CACHE_FUNCTION_NAMES[index] == name):
            return true
        index -= 1
    return false

string call_return_type(ProgramIR program, string name):
    ParsedFunction function_ir = lookup_named_function_decl(program, name)
    if (function_ir.header == ''):
        return 'unknown'
    return function_ir.return_type.substring(0)

BindingIR[] call_param_bindings(ProgramIR program, string name):
    ParsedFunction function_ir = lookup_named_function_decl(program, name)
    if (function_ir.header != ''):
        return function_ir.params
    BindingIR[] empty = []
    return empty

string[] call_arg_types(ParsedFunction function_ir, string[] arg_names):
    string[] types = []
    for (string arg_name in arg_names):
        types.push(lookup_temp_llvm_type(function_ir, arg_name))
    return types

void require_scalar_type(string type_name, string context):
    if (!is_scalar_type(type_name)):
        throw 'unsupported llvm ' + context + ' type: ' + type_name

void require_backend_value_type(string type_name, string context):
    if (!is_backend_value_type(type_name)):
        throw 'unsupported llvm ' + context + ' type: ' + type_name

bool is_backend_managed_type(string type_name):
    type_name = normalize_llvm_type_name(type_name)
    return type_name == 'string' || type_name == 'string[]' || type_name == 'bool[]' || type_name == 'int[]' || type_name == 'int[][]' || type_name.starts_with('set<') || (type_name.ends_with('[]') && record_name_from_type(array_item_type(type_name)) != '') || type_name.starts_with('map<') || record_name_from_type(type_name) != ''

bool temp_has_owned_semantics(ParsedFunction function_ir, string temp_name):
    LinearInstruction op = lookup_temp_instruction(function_ir, temp_name)
    return ownership_is_owned_mode(op.ownership_mode) && is_backend_managed_type(op.result_type)

bool temp_is_string(ParsedFunction function_ir, string temp_name):
    return normalize_llvm_type_name(lookup_temp_llvm_type(function_ir, temp_name)) == 'string'

bool temp_is_managed_string(ParsedFunction function_ir, string temp_name):
    if (!temp_is_string(function_ir, temp_name)):
        return false
    return lookup_temp_instruction(function_ir, temp_name).ownership_mode == 'managed'

bool temp_is_string_like_value(ParsedFunction function_ir, string temp_name):
    if (temp_is_string(function_ir, temp_name)):
        return true
    LinearInstruction op = lookup_temp_instruction(function_ir, temp_name)
    if (op.kind != 'value'):
        return false
    if (op.detail == 'string'):
        return true
    if (op.detail == 'index' && op.args.length() >= 1):
        return normalize_llvm_type_name(lookup_temp_llvm_type(function_ir, op.args[0])) == 'string'
    if (op.detail == 'method-call' && op.args.length() >= 2 && op.args[0] == 'char_at'):
        return normalize_llvm_type_name(lookup_temp_llvm_type(function_ir, op.args[1])) == 'string'
    return false

bool temp_is_string_array(ParsedFunction function_ir, string temp_name):
    return normalize_llvm_type_name(lookup_temp_llvm_type(function_ir, temp_name)) == 'string[]'

bool temp_is_string_array_array(ParsedFunction function_ir, string temp_name):
    return normalize_llvm_type_name(lookup_temp_llvm_type(function_ir, temp_name)) == 'string[][]'

bool temp_is_bool_array(ParsedFunction function_ir, string temp_name):
    return normalize_llvm_type_name(lookup_temp_llvm_type(function_ir, temp_name)) == 'bool[]'

bool temp_is_int_array(ParsedFunction function_ir, string temp_name):
    return normalize_llvm_type_name(lookup_temp_llvm_type(function_ir, temp_name)) == 'int[]'

bool temp_is_int_set(ParsedFunction function_ir, string temp_name):
    return normalize_llvm_type_name(lookup_temp_llvm_type(function_ir, temp_name)) == 'set<int>'

bool temp_is_int_array_array(ParsedFunction function_ir, string temp_name):
    return normalize_llvm_type_name(lookup_temp_llvm_type(function_ir, temp_name)) == 'int[][]'

bool temp_is_record_array(ParsedFunction function_ir, string temp_name):
    string type_name = normalize_llvm_type_name(lookup_temp_llvm_type(function_ir, temp_name))
    return type_name.ends_with('[]') && record_name_from_type(array_item_type(type_name)) != ''

bool temp_is_record(ParsedFunction function_ir, string temp_name):
    return record_name_from_type(normalize_llvm_type_name(lookup_temp_llvm_type(function_ir, temp_name))) != ''

bool temp_is_map(ParsedFunction function_ir, string temp_name):
    return normalize_llvm_type_name(lookup_temp_llvm_type(function_ir, temp_name)).starts_with('map<')

bool temp_is_moved(ParsedFunction function_ir, string temp_name):
    for (BlockIR block in function_ir.blocks):
        for (LinearInstruction op in block.instructions):
            if (op.kind == 'move_temp'):
                if (op.args.length() == 1):
                    if (op.args[0] == temp_name):
                        return true
    return false

bool temp_needs_backend_free(ParsedFunction function_ir, string temp_name):
    LinearInstruction op = lookup_temp_instruction(function_ir, temp_name)
    string result_type = normalize_llvm_type_name(op.result_type)
    if (!ownership_is_owned_mode(op.ownership_mode)):
        return false
    if (result_type == 'string'):
        if (op.kind == 'binary'):
            return true
        if (op.kind != 'value'):
            return false
        if (op.detail == 'call' || op.detail == 'method-call' || op.detail == 'slice'):
            return true
        if (op.detail == 'index' && op.args.length() >= 1):
            return normalize_llvm_type_name(lookup_temp_llvm_type(function_ir, op.args[0])) == 'string'
        return false
    if (op.kind != 'value'):
        return false
    if (result_type == 'string[]'):
        return op.detail == 'array' || op.detail == 'call'
    if (result_type == 'string[][]'):
        return op.detail == 'array' || op.detail == 'call'
    if (result_type == 'bool[]'):
        return op.detail == 'array' || op.detail == 'call'
    if (result_type == 'int[]'):
        return op.detail == 'array' || op.detail == 'call'
    if (result_type.starts_with('set<')):
        return op.detail == 'set' || op.detail == 'call' || op.detail == 'method-call'
    if (result_type == 'int[][]'):
        return op.detail == 'array' || op.detail == 'call'
    if (result_type.ends_with('[]') && record_name_from_type(array_item_type(result_type)) != ''):
        return op.detail == 'array' || op.detail == 'call'
    if (result_type == 'string'):
        return op.detail == 'call'
    if (result_type.starts_with('map<')):
        return op.detail == 'map' || op.detail == 'call'
    if (record_name_from_type(result_type) != ''):
        return op.detail == 'call'
    return false

string backend_owned_flag_for_temp(ParsedFunction function_ir, string temp_name):
    if (temp_needs_backend_free(function_ir, temp_name)):
        return 'true'
    return 'false'

bool temp_can_transfer_to_local(ParsedFunction function_ir, string temp_name):
    return temp_needs_backend_free(function_ir, temp_name) || temp_is_moved(function_ir, temp_name)

string emit_backend_release_ptr(string type_name, string ptr_name):
    type_name = normalize_llvm_type_name(type_name)
    if (type_name == 'string[]'):
        return emit_string_array_release_ptr(ptr_name)
    if (type_name == 'string[][]'):
        return '  call void @tb_bootstrap_string_array_array_free(ptr ' + ptr_name + ')'
    if (type_name == 'bool[]'):
        return '  call void @tb_bootstrap_bool_array_free(ptr ' + ptr_name + ')'
    if (type_name == 'int[]'):
        return '  call void @tb_bootstrap_int_array_free(ptr ' + ptr_name + ')'
    if (type_name == 'set<int>'):
        return '  call void @tb_bootstrap_int_set_free(ptr ' + ptr_name + ')'
    if (type_name.starts_with('set<') && record_name_from_type(set_item_type(type_name)) != ''):
        return '  call void @tb_bootstrap_record_set_free_' + record_name_from_type(set_item_type(type_name)) + '(ptr ' + ptr_name + ')'
    if (type_name == 'int[][]'):
        return '  call void @tb_bootstrap_int_array_array_free(ptr ' + ptr_name + ')'
    if (type_name.ends_with('[]') && record_name_from_type(array_item_type(type_name)) != ''):
        return '  call void @tb_bootstrap_record_array_free_' + record_name_from_type(array_item_type(type_name)) + '(ptr ' + ptr_name + ')'
    if (type_name == 'string'):
        return emit_string_release_ptr(ptr_name)
    if (type_name.starts_with('map<')):
        return '  call void ' + llvm_map_free_name(type_name) + '(ptr ' + ptr_name + ')'
    if (record_name_from_type(type_name) != ''):
        return emit_record_release_ptr(record_name_from_type(type_name), ptr_name)
    return '  ; release_ptr ' + type_name + ' ' + ptr_name

string emit_string_owned_value(ParsedFunction function_ir, string temp_name, string temp_suffix):
    if (temp_needs_backend_free(function_ir, temp_name)):
        return temp_ref(temp_name)
    string copy_name = '%string.copy.' + temp_suffix
    return copy_name

string[] emit_string_materialize_if_needed(ParsedFunction function_ir, string temp_name, string temp_suffix):
    if (temp_needs_backend_free(function_ir, temp_name)):
        return []
    if (!temp_is_string(function_ir, temp_name)):
        return []
    if (temp_is_managed_string(function_ir, temp_name)):
        return ['  ' + emit_string_owned_value(function_ir, temp_name, temp_suffix) + ' = call ptr @tb_retain(ptr ' + temp_ref(temp_name) + ')']
    return ['  ' + emit_string_owned_value(function_ir, temp_name, temp_suffix) + ' = call ptr @tb_bootstrap_string_copy(ptr ' + temp_ref(temp_name) + ')']

