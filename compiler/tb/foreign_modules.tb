string[] raylib_roots():
    return [
        '/opt/homebrew/opt/raylib',
        '/usr/local/opt/raylib',
        '/opt/homebrew/Cellar/raylib/5.5',
        '/usr/local/Cellar/raylib/5.5'
    ]

bool is_foreign_module(string name):
    return name == 'raylib'

