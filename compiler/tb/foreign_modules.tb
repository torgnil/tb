string foreign_function_llvm_declaration(string symbol_name):
    if (symbol_name == '__tb_foreign_raylib_InitWindow'):
        return 'declare void @__tb_foreign_raylib_InitWindow(i64, i64, ptr)'
    if (symbol_name == '__tb_foreign_raylib_WindowShouldClose'):
        return 'declare i1 @__tb_foreign_raylib_WindowShouldClose()'
    if (symbol_name == '__tb_foreign_raylib_GetFrameTimeMillis'):
        return 'declare i64 @__tb_foreign_raylib_GetFrameTimeMillis()'
    if (symbol_name == '__tb_foreign_raylib_GetTimeMillis'):
        return 'declare i64 @__tb_foreign_raylib_GetTimeMillis()'
    if (symbol_name == '__tb_foreign_raylib_SetTargetFPS'):
        return 'declare void @__tb_foreign_raylib_SetTargetFPS(i64)'
    if (symbol_name == '__tb_foreign_raylib_BeginDrawing'):
        return 'declare void @__tb_foreign_raylib_BeginDrawing()'
    if (symbol_name == '__tb_foreign_raylib_EndDrawing'):
        return 'declare void @__tb_foreign_raylib_EndDrawing()'
    if (symbol_name == '__tb_foreign_raylib_ClearBackground'):
        return 'declare void @__tb_foreign_raylib_ClearBackground(i64)'
    if (symbol_name == '__tb_foreign_raylib_LoadTexture'):
        return 'declare i64 @__tb_foreign_raylib_LoadTexture(ptr)'
    if (symbol_name == '__tb_foreign_raylib_DrawText'):
        return 'declare void @__tb_foreign_raylib_DrawText(ptr, i64, i64, i64, i64)'
    if (symbol_name == '__tb_foreign_raylib_DrawTexture'):
        return 'declare void @__tb_foreign_raylib_DrawTexture(i64, i64, i64, i64)'
    if (symbol_name == '__tb_foreign_raylib_UnloadTexture'):
        return 'declare void @__tb_foreign_raylib_UnloadTexture(i64)'
    if (symbol_name == '__tb_foreign_raylib_DrawRectangle'):
        return 'declare void @__tb_foreign_raylib_DrawRectangle(i64, i64, i64, i64, i64)'
    if (symbol_name == '__tb_foreign_raylib_DrawCircle'):
        return 'declare void @__tb_foreign_raylib_DrawCircle(i64, i64, i64, i64)'
    if (symbol_name == '__tb_foreign_raylib_DrawLine'):
        return 'declare void @__tb_foreign_raylib_DrawLine(i64, i64, i64, i64, i64)'
    if (symbol_name == '__tb_foreign_raylib_IsKeyDown'):
        return 'declare i1 @__tb_foreign_raylib_IsKeyDown(i64)'
    if (symbol_name == '__tb_foreign_raylib_IsKeyPressed'):
        return 'declare i1 @__tb_foreign_raylib_IsKeyPressed(i64)'
    if (symbol_name == '__tb_foreign_raylib_GetMouseX'):
        return 'declare i64 @__tb_foreign_raylib_GetMouseX()'
    if (symbol_name == '__tb_foreign_raylib_GetMouseY'):
        return 'declare i64 @__tb_foreign_raylib_GetMouseY()'
    if (symbol_name == '__tb_foreign_raylib_IsMouseButtonDown'):
        return 'declare i1 @__tb_foreign_raylib_IsMouseButtonDown(i64)'
    if (symbol_name == '__tb_foreign_raylib_InitAudioDevice'):
        return 'declare void @__tb_foreign_raylib_InitAudioDevice()'
    if (symbol_name == '__tb_foreign_raylib_CloseAudioDevice'):
        return 'declare void @__tb_foreign_raylib_CloseAudioDevice()'
    if (symbol_name == '__tb_foreign_raylib_LoadSound'):
        return 'declare i64 @__tb_foreign_raylib_LoadSound(ptr)'
    if (symbol_name == '__tb_foreign_raylib_PlaySound'):
        return 'declare void @__tb_foreign_raylib_PlaySound(i64)'
    if (symbol_name == '__tb_foreign_raylib_SetSoundVolume'):
        return 'declare void @__tb_foreign_raylib_SetSoundVolume(i64, i64)'
    if (symbol_name == '__tb_foreign_raylib_UnloadSound'):
        return 'declare void @__tb_foreign_raylib_UnloadSound(i64)'
    if (symbol_name == '__tb_foreign_raylib_GetScreenWidth'):
        return 'declare i64 @__tb_foreign_raylib_GetScreenWidth()'
    if (symbol_name == '__tb_foreign_raylib_GetScreenHeight'):
        return 'declare i64 @__tb_foreign_raylib_GetScreenHeight()'
    if (symbol_name == '__tb_foreign_raylib_CloseWindow'):
