string raylib_constant_declarations():
    string decls = 'const int __tb_foreign_raylib_BLACK = 0;\n'
    decls += 'const int __tb_foreign_raylib_WHITE = 1;\n'
    decls += 'const int __tb_foreign_raylib_RED = 2;\n'
    decls += 'const int __tb_foreign_raylib_GREEN = 3;\n'
    decls += 'const int __tb_foreign_raylib_BLUE = 4;\n'
    decls += 'const int __tb_foreign_raylib_YELLOW = 5;\n'
    decls += 'const int __tb_foreign_raylib_RAYWHITE = 6;\n'
    decls += 'const int __tb_foreign_raylib_LIGHTGRAY = 7;\n'
    decls += 'const int __tb_foreign_raylib_DARKGRAY = 8;\n'
    decls += 'const int __tb_foreign_raylib_KEY_SPACE = 32;\n'
    decls += 'const int __tb_foreign_raylib_KEY_ESCAPE = 256;\n'
    decls += 'const int __tb_foreign_raylib_KEY_RIGHT = 262;\n'
    decls += 'const int __tb_foreign_raylib_KEY_LEFT = 263;\n'
    decls += 'const int __tb_foreign_raylib_KEY_DOWN = 264;\n'
    decls += 'const int __tb_foreign_raylib_KEY_UP = 265;\n'
    decls += 'const int __tb_foreign_raylib_MOUSE_BUTTON_LEFT = 0;\n'
    decls += 'const int __tb_foreign_raylib_MOUSE_BUTTON_RIGHT = 1;\n'
    decls += 'const int __tb_foreign_raylib_MOUSE_BUTTON_MIDDLE = 2;'
    return decls

string injected_foreign_module_declarations(string[] active_modules):
    string injected = ''
    for (string module_name in active_modules):
        if (module_name == 'raylib'):
            if (injected != ''):
                injected += '\n'
            injected += raylib_constant_declarations()
    return injected

string _rewrite_module_uses(string source, string module_name):
    string output = ''
    int index = 0
    bool line_comment = false
    bool block_comment = false
    bool in_string = false
    while (index < source.length()):
        string current = source[index]
        string next = ''
        if (index + 1 < source.length()):
            next = source[index + 1]
        if (in_string):
            output += current
            if (current == '\''):
                in_string = false
            index += 1
            continue
        if (line_comment):
            output += current
            if (current == '\n'):
                line_comment = false
            index += 1
            continue
        if (block_comment):
            output += current
            if (current == '*' && next == '/'):
                output += next
                index += 2
                block_comment = false
            else:
                index += 1
            continue
        if (current == '\''):
            output += current
            in_string = true
            index += 1
            continue
        if (current == '#'):
            output += current
            line_comment = true
            index += 1
            continue
        if (current == '/' && next == '*'):
            output += current + next
            block_comment = true
            index += 2
            continue
        if (string_has_prefix_at(source, module_name, index)):
            string before = ''
            if (index > 0):
                before = source[index - 1]
            int after_index = index + module_name.length()
            string after = ''
            if (after_index < source.length()):
                after = source[after_index]
            if ((before == '' || !(before.is_alnum() || before == '_')) && after == '.'):
                int member_start = after_index + 1
                int member_end = member_start
                while (member_end < source.length() && (source[member_end].is_alnum() || source[member_end] == '_')):
                    member_end += 1
                string member_name = source.substring(member_start, member_end)
                string replacement = foreign_module_member_symbol(module_name, member_name)
                if (replacement != ''):
                    output += replacement
                    index = member_end
                    continue
        output += current
        index += 1
    return output

string rewrite_foreign_module_uses(string source, string[] active_modules):
    string rewritten = source
    for (string module_name in active_modules):
        rewritten = _rewrite_module_uses(rewritten, module_name)
    return rewritten

string[] foreign_module_llvm_declarations(string[] active_modules):
    string[] lines = []
    for (string module_name in active_modules):
        if (module_name == 'raylib'):
            for (string symbol_name in raylib_function_symbols()):
                lines.push(foreign_function_llvm_declaration(symbol_name))
    return lines

string[] foreign_module_link_flags(string[] active_modules):
    string[] flags = []
    for (string module_name in active_modules):
        if (module_name == 'raylib'):
            for (string root in raylib_roots()):
                flags.push('-L' + root + '/lib')
                flags.push('-Wl,-rpath,' + root + '/lib')
            flags.push('-lraylib')
    return flags

string[] foreign_module_cflags(string[] active_modules):
    string[] flags = []
    for (string module_name in active_modules):
        if (module_name == 'raylib'):
            for (string root in raylib_roots()):
                flags.push('-I' + root + '/include')
    return flags

string[] foreign_module_c_sources(string[] active_modules):
    string[] sources = []
    for (string module_name in active_modules):
        if (module_name == 'raylib'):
            sources.push('raylib-tb/raylib_tb.c')
    return sources
