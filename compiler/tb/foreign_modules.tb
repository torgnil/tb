string foreign_module_member_symbol(string module_name, string member_name):
    if (module_name == 'raylib'):
        return raylib_member_symbol(member_name)
    return ''

bool string_has_prefix_at(string value, string prefix, int start):
    if (start < 0 || start + prefix.length() > value.length()):
        return false
    int index = 0
    while (index < prefix.length()):
        if (value[start + index] != prefix[index]):
            return false
        index += 1
    return true

