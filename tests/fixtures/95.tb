int slow_value(int x):
    int sum = 0
    int i = 0
    while (i < 50000):
        sum += i % 3
        i += 1
    return x + sum - sum

string fast_label(string text):
    return '[' + text + ']'

int main(string[] args):
    thread_pool pool = thread_pool(2)
    future<int> slow = pool.submit(slow_value, 41)
    future<string> fast = pool.submit(fast_label, 'done')
    print(fast.await())
    print(slow.await())
    return 0
