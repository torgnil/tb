string greet(string name) {
    return 'hello ' + name;
}

int add_two(int value) {
    int next = value + 1;
    return next + 1;
}

int main(string[] args) {
    string message = greet('tb');
    int start = 40;

    if (message == 'hello tb') {
        print(message);
    }

    print(add_two(start));
    print(message.substring(6));
    print(message.length());
    print(message[6]);
    return 0;
}
