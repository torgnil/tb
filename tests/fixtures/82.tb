record Item(string name, int score);

int compare_items(Item left, Item right):
    if (left.score > right.score):
        return -1
    if (left.score < right.score):
        return 1
    return 0

int main(string[] args):
    Item[] items = [Item('a', 2), Item('b', 3), Item('c', 1)]
    prio_q<Item> pq = items.create_prio_q(compare_items)
    pq.push(Item('d', 4))
    items.push(Item('e', 5))
    while (!pq.is_empty()):
        print(pq.pop().name)
    return 0
