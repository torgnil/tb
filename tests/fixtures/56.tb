enum Mode {
    ALPHA,
    BETA
}

int main(string[] args) {
    int i = 0;
    int total = 0;
    while (i < 4) {
        total += i;
        i++;
    }
    print(total);
    print(6 ^ 3);
    print(6 | 3);
    print(6 & 3);
    print(abs(-42));
    print(round(sqrt(2), 3));

    string[] names = ['a', 'bb'];
    print(names.map_to(string name -> length(name)));

    int code = 2;
    switch (code) {
        case 1: {
            print('one');
        }
        case 2: {
            print('two');
        }
        default: {
            print('other');
        }
    }

    string text = 'b';
    switch (text) {
        case 'a': {
            print('A');
        }
        case 'b': {
            print('B');
        }
        default: {
            print('?');
        }
    }

    Mode mode = Mode.BETA;
    switch (mode) {
        case Mode.ALPHA: {
            print('alpha');
        }
        case Mode.BETA: {
            print('beta');
        }
        default: {
            print('none');
        }
    }

    return 0;
}
