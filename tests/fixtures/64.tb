record Pair(int a, int b);

int main(string[] args) {
    set<Pair> seen = {Pair(1, 2)};
    seen.add(Pair(3, 4));

    map<int, int[]> arrs = {1: [2, 4]};
    map<int, Pair> pairs = {2: Pair(5, 6)};
    map<int, set<Pair>> groups = {3: seen};

    Pair p = pairs[2];
    print(arrs[1][0] + arrs[1][1]);
    print(p.a + p.b);
    if (groups[3].contains(Pair(1, 2))) {
        print(1);
    } else {
        print(0);
    }
    print(seen.length());
    return 0;
}
