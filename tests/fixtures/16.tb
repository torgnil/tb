int main(string[] args) {
    int current = 50;
    int hits = 0;

    string[] lines = read_lines('test-files/16.in');
    for (string line : lines) {
        string direction = line[0];
        int distance = line.substring(1).to_int();

        if (direction == 'L') {
            current = current - distance;
        } else {
            current = current + distance;
        }

        if (current < 0) {
            current = current + 100;
        } else {
            if (current >= 100) {
                current = current - 100;
            }
        }

        if (current == 0) {
            hits += 1;
        }
    }

    print(hits);
    return 0;
}
