int main(string[] args) {
    int current = 50;
    int hits = 0;

    string[] lines = read_lines('test-files/17.in');
    for (string line : lines) {
        string direction = line[0];
        int distance = line.substring(1).to_int();

        current = direction == 'L' ? current - distance : current + distance;
        current = current < 0 ? current + 100 : current % 100;
        hits += current == 0 ? 1 : 0;
    }

    print(hits);
    return 0;
}
