record Item(int value, int order);

int compare_items(Item left, Item right):
    if (left.value < right.value):
        return -1
    if (left.value > right.value):
        return 1
    if (left.order < right.order):
        return -1
    if (left.order > right.order):
        return 1
    return 0

int main(string[] args):
    Item[] items = [
        Item(5, 2),
        Item(1, 9),
        Item(5, 1),
        Item(3, 7),
        Item(1, 4)
    ]
    items.sort(compare_items)

    for (Item item : items):
        print(item.value * 10 + item.order)
    return 0
