int plus_one(int x):
    return x + 1

int main(string[] args):
    thread_pool pool = thread_pool(2)
    future<int> a = pool.submit(plus_one, 0)
    future<int> b = pool.submit(plus_one, 1)
    future<int> c = pool.submit(plus_one, 2)
    future<int> d = pool.submit(plus_one, 3)
    future<int> e = pool.submit(plus_one, 4)
    future<int> f = pool.submit(plus_one, 5)
    future<int> g = pool.submit(plus_one, 6)
    future<int> h = pool.submit(plus_one, 7)
    print(a.await() + b.await() + c.await() + d.await() + e.await() + f.await() + g.await() + h.await())
    return 0
