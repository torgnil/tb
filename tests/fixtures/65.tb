int choose(int code):
    int result = 0
    switch (code):
        case 1:
            result = 10
        case 2:
            result = 20
        default:
            result = 30
    return result

int main(string[] args):
    int total = 0
    string[] items = ['x', 'y']

    for (string item in items):
        if (item == 'x'):
            total += choose(1)
        else:
            total += choose(2)

    while (total < 35):
        total += 5

    if (total == 35) {
        print('ok');
    } else {
        print('bad');
    }

    print(total)
    return 0
