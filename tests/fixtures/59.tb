int main(string[] args) {
    # This test demonstrates the scoping issue with bool variables
    # declared and modified inside a loop, then used outside

    int i = 0;
    while (i < 3) {
        bool is_fresh = false;

        if (i > 0) {
            is_fresh = true;
        }

        # This reference to is_fresh inside the same scope works
        if (is_fresh) {
            print('fresh');
        }

        i = i + 1;
    }
    print('done');
    return 0;
}
