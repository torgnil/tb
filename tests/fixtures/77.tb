int main(string[] args):
    int[][] rows = []
    rows.push([1, 2])

    int[] tail = [3, 4, 5]
    rows.push(tail)

    int total = 0
    for (int[] row : rows):
        print(row.sum())
        total += row[0]
        total += row[1]

    print(rows.length())
    print(rows[1][2])
    print(total)
    return 0
