int best_bank(string line) {
    int best = 0;
    int size = line.length();

    for (int i = 0; i < size; i++) {
        int first = to_int(line[i]);

        for (int j = i + 1; j < size; j++) {
            int second = to_int(line[j]);
            int candidate = first * 10 + second;

            if (candidate > best) {
                best = candidate;
            }
        }
    }

    return best;
}

int main(string[] args) {
    int total = 0;
    string[] lines = read_lines('test-files/25.in');

    for (string line : lines) {
        if (!line.is_empty()) {
            total += best_bank(line);
        }
    }

    print(total);
    return 0;
}
