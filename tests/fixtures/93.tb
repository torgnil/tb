int text_length(string text):
    return text.length()

bool starts_with_t(string text):
    return text.starts_with('t')

string decorate(string text):
    return '<' + text + '>'

int main(string[] args):
    thread_pool pool = thread_pool(3)
    future<int> a = pool.submit(text_length, 'hello')
    future<bool> b = pool.submit(starts_with_t, 'tb')
    future<string> c = pool.submit(decorate, 'x')
    print(a.await())
    print(b.await())
    print(c.await())
    return 0
