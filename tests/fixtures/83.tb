int main(string[] args):
    string trimmed = '  tb-core  '.trim()
    string first = trimmed.char_at(0)
    string tail = trimmed.substring(3)
    string[] parts = 'a,b,c'.split(',')
    string joined = parts.join('-')
    string replaced = 'abcabc'.replace('ab', 'X')
    string labeled = joined + '-' + 42
    print(trimmed)
    print(first)
    print(tail)
    print(joined)
    print(replaced)
    print(labeled)
    return 0
