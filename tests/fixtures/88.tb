int increment(int x):
    return x + 1

int main(string[] args):
    thread_pool pool = thread_pool(3)
    future<int> a = pool.submit(increment, 1)
    future<int> b = pool.submit(increment, 40)
    future<int> c = pool.submit(increment, -1)
    print(a.await() + b.await() + c.await())
    return 0
