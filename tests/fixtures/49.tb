/*
* Test reversing a string using recursion.
*/
string reverse(string s) {
    if (s.length() == 0) {
        return '';
    }
    if (s.length() == 1) {
        return s[0];
    }
    return s[-1] + reverse(s[0:-1]);
}

int main(string[] args) {
    string s = 'desrever';
    print(reverse(s));
    return 0;
}
