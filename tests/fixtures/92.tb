string describe_int(int x):
    return 'value=' + x

string describe_bool(bool flag):
    if (flag):
        return 'yes'
    return 'no'

int main(string[] args):
    thread_pool pool = thread_pool(2)
    future<string> a = pool.submit(describe_int, 7)
    future<string> b = pool.submit(describe_bool, false)
    print(a.await())
    print(b.await())
    return 0
