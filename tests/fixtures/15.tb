int main(string[] args) {
    int a = 2;

    if (a == 1) {
        print('one');
    } else {
        print('not one');
    }

    if (a != 1) {
        print('not equal');
    }

    if (a < 3) {
        print('less than three');
    }

    if (a <= 2) {
        print('at most two');
    }

    if (a > 2) {
        print('too big');
    } else {
        print('not too big');
    }

    if (a >= 2) {
        if (a == 2) {
            print('exactly two');
        }
    }
    return 0;
}
