record Node(string name, int value);

int main(string[] args) {
    Node[] my_array = [Node('a', 2), Node('b', 3), Node('c', 1)];
    prio_q<Node> pq = my_array.create_prio_q((Node a, Node b) -> b.value - a.value);
    pq.push(Node('d', 4));
    my_array.push(Node('e', 5));
    while (!pq.is_empty()) {
        print(pq.pop().name);
    }
}