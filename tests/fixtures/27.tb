int main(string[] args) {
    string[] lines = read_lines('test-files/27.in');

    string[][] grid = [[]];

    for (int i = 0; i < lines.length(); i++) {
        string line = lines[i];
        string[] chars = line.split('');
        grid[i] = chars;
    }

    for (string[] row : grid) {
        print(row.join(''));
    }
    return 0;
}
