int main(string[] args) {
    string source = read_file('test-files/35.in');
    string[] lines = source.split_lines();
    print('tb-core'.starts_with('tb'));
    print('tb-core'.starts_with_at('core', 3));
    print('tb-core'.char_at(3));
    print('tb-core'.ends_with('core'));
    print(lines[0].is_alpha());
    print('abcabc'.replace('ab', 'X'));
    print(lines.length());
    print(lines[1]);
    print('7'.is_digit());
    print('Q'.is_alpha());
    print(' '.is_whitespace());
    return 0;
}
