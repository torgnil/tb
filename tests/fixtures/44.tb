int main(string[] args) {
    int[] nums = [1, 2, 3];
    string[] words = ['alpha', 'beta'];
    bool[] flags = [true, false];
    set<int> seen = {2, 4, 6};

    print(2 in nums);
    print(5 in nums);
    print('beta' in words);
    print('gamma' in words);
    print(true in flags);
    print(4 in seen);
    print(3 in seen);
    return 0;
}
