record Mask(int value);

int main(string[] args) {
    for (int value : [1, 2, 3, 4, 5]) {
        if (value % 2 == 0) {
            continue;
        }
        print(value);
    }

    int number = 3;
    number *= 2;
    number |= 1;
    number &= 7;
    number ^= 2;
    number <<= 1;
    number >>= 2;
    number /= 2;
    number %= 3;
    print(number);

    int[] nums = [8];
    nums[0] >>= 1;
    nums[0] *= 3;
    print(nums[0]);

    Mask mask = Mask(4);
    mask.value |= 1;
    mask.value <<= 1;
    print(mask.value);

    return 0;
}
