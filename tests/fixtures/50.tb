string[] lines = ['hello'];

int no_lines() {
    return lines.length();
}

record Pos(int x, int y);

cached int pos_sum(Pos p) {
    return p.x + p.y;
}

int main(string[] args) {
    lines = ['hello', 'world'];
    for (string line in lines) {
        print(line);
    }
    print('Number of lines: ' + no_lines());
    print('Sum of position: ' + pos_sum(Pos(3, 4)));
    return 0;
}

