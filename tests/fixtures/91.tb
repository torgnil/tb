int bool_to_int(bool flag):
    if (flag):
        return 11
    return 4

bool invert(bool flag):
    return !flag

int main(string[] args):
    thread_pool pool = thread_pool(2)
    future<int> a = pool.submit(bool_to_int, true)
    future<bool> b = pool.submit(invert, false)
    print(a.await())
    print(b.await())
    return 0
