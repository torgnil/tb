int main(string[] args):
    map<int, int> counts = {0: 0}
    int seed = args.length()

    for (int i = 1; i < 257; i++):
        counts[i] = 0

    for (int i = 0; i < 20000; i++):
        int key = (i * 17 + seed) % 257
        counts[key] = counts[key] + 1

    int total = 0
    for (int i = 0; i < 257; i++):
        total += counts[i] * (i % 13)

    print(total)
    return 0
