int main(string[] args) {
    set<int> seen = {};
    int seed = args.length();

    for (int i = 0; i < 20000; i++) {
        seen.add((i * 37 + seed) % 4096);
    }

    int total = 0;
    for (int i = 0; i < 4096; i++) {
        if (i in seen) {
            total += i % 97;
        }
    }

    print(total + seen.length());
    return 0;
}

