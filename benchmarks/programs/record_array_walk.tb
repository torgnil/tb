record Point(int x, int y)

int main(string[] args):
    Point[] points = []
    int seed = args.length()

    for (int i = 0; i < 5000; i++):
        points.push(Point(i + seed, (i * 3) % 31))

    int total = 0
    for (Point point : points):
        total += point.x + point.y * 2

    print(total)
    return 0
