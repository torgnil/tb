int mix(int value, int index) {
    value = value + index * 17;
    value = value ^ (index << 2);
    value = value - (index % 11);
    return value & 1048575;
}

int main(string[] args) {
    int result = args.length();
    for (int i = 0; i < 200000; i++) {
        result = mix(result, i);
    }
    print(result);
    return 0;
}

