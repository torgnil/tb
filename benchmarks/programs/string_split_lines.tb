string make_text(int repeats):
    string text = ''
    for (int i = 0; i < repeats; i++):
        text += 'line-' + i + '-value-' + (i % 17) + '\n'
    return text

int main(string[] args):
    string text = make_text(4000 + args.length())
    string[] lines = text.split_lines()
    int total = 0

    for (string line : lines):
        total += line.length()
        total += line.index_of('-')

    print(total + lines.length())
    return 0
