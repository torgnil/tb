record Point(int x, int y, int z);

Point next_point(Point point, int index):
    return Point(
        point.x + index % 7,
        point.y + index % 11,
        point.z + index % 13
    )

int score(Point point):
    return point.x * 3 + point.y * 5 + point.z * 7

int main(string[] args):
    Point point = Point(args.length(), 2, 3)
    int total = 0
    for (int i = 0; i < 50000; i++):
        point = next_point(point, i)
        total += score(point) % 1009
    print(total)
    return 0
