int main(string[] args):
    set<int> seen = {}
    int seed = args.length()

    for (int i = 0; i < 25000; i++):
        seen.add((i * 29 + seed) % 8192)

    int total = 0
    for (int i = 0; i < 12000; i++):
        if (((i * 7) % 8192) in seen):
            total += i % 41

    print(total + seen.length())
    return 0
